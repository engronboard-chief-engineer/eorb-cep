<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>eORB Pro Portable — First Activation</title>
<style>
  :root {
    --bg-0:#0a0d12; --bg-1:#11161e; --bg-2:#1a212c;
    --border:#232b38; --border-soft:#1d2531;
    --text:#e5edf5; --muted:#8896a8;
    --gold:#c9a227; --gold-soft:rgba(201,162,39,0.16);
    --err:#ff6b6b; --ok:#4ade80;
  }
  *{box-sizing:border-box}
  html,body{height:100%;margin:0}
  body{
    background:radial-gradient(1100px 600px at 50% -10%,#1a2433 0%,var(--bg-0) 65%);
    color:var(--text);
    font-family:'Segoe UI',-apple-system,system-ui,sans-serif;
    display:grid;place-items:center;
    -webkit-font-smoothing:antialiased;
    overflow-y:auto;
  }
  .shell{
    width:min(680px,94vw);
    margin:32px auto;
    background:linear-gradient(180deg,var(--bg-1),#0c1118);
    border:1px solid var(--border);
    border-radius:18px;
    padding:32px 36px 28px;
    box-shadow:0 24px 80px rgba(0,0,0,.55),inset 0 1px 0 rgba(255,255,255,.03);
  }
  /* Desktop landscape layout — keep the disclaimer fully visible without scrolling */
  @media (min-width: 900px) {
    .shell{ width:min(1080px,94vw); margin:24px auto; padding:28px 40px 24px; }
    #pane-2 .agreement-card{ max-height:none; }
    .pane-2-grid{
      display:grid;
      grid-template-columns:1.4fr 1fr;
      gap:22px;
      align-items:start;
    }
    .pane-2-grid .agreement-col{min-width:0}
    .pane-2-grid .side-col{
      display:flex;flex-direction:column;gap:14px;
      position:sticky;top:8px;
    }
  }
  header{display:flex;align-items:center;gap:14px;margin-bottom:6px}
  .crest{
    width:46px;height:46px;border-radius:12px;
    background:var(--gold-soft);border:1px solid rgba(201,162,39,.35);
    display:grid;place-items:center;color:var(--gold);
    font-weight:700;font-size:18px;letter-spacing:.06em;
  }
  .title{font-weight:700;font-size:18px;letter-spacing:-0.01em}
  .title .sub{display:block;color:var(--muted);font-size:12px;font-weight:500;margin-top:2px;letter-spacing:0}
  .stepper{
    display:flex;gap:6px;margin:22px 0 18px;
  }
  .stepper .step{flex:1;height:4px;border-radius:3px;background:#1c2330}
  .stepper .step.done{background:var(--gold)}
  .stepper .step.active{background:var(--gold);box-shadow:0 0 0 3px var(--gold-soft)}
  .stepper-meta{display:flex;justify-content:space-between;font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:18px}
  h2{font-size:17px;margin:8px 0 4px;font-weight:700;letter-spacing:-0.01em}
  .lede{color:var(--muted);font-size:13px;line-height:1.55;margin:0 0 18px}
  label{display:block;font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:0.08em;margin:14px 0 6px}
  input.field,select.field,textarea.field{
    width:100%;padding:11px 13px;
    background:var(--bg-2);border:1px solid var(--border);border-radius:8px;
    color:var(--text);font:inherit;font-size:14px;outline:none;
    transition:border-color .15s,background .15s;
  }
  input.field:focus,select.field:focus,textarea.field:focus{
    border-color:var(--gold);background:#1d2532;
  }
  .grid-2{display:grid;grid-template-columns:1fr 1fr;gap:14px}
  .optional{font-size:10px;color:var(--muted);text-transform:none;letter-spacing:0;margin-left:8px;font-weight:400}
  .agreement-card{
    background:#0e131c;border:1px solid var(--border);border-radius:10px;
    padding:18px 20px;max-height:280px;overflow-y:auto;
    font-size:13px;line-height:1.6;color:#cdd6e3;
  }
  .agreement-card p{margin:0 0 10px}
  .agreement-card p:last-child{margin-bottom:0}
  .check-row{
    display:flex;gap:10px;align-items:flex-start;
    margin-top:14px;padding:12px 14px;
    border:1px solid var(--border);border-radius:8px;background:var(--bg-2);
    cursor:pointer;user-select:none;
  }
  .check-row input{margin-top:2px;width:16px;height:16px;accent-color:var(--gold)}
  .check-row .lbl{font-size:13px;line-height:1.5}
  .sig-pad-wrap{
    border:1px dashed var(--border);border-radius:10px;background:#0f141d;
    padding:8px;margin-top:6px;
  }
  #sigCanvas{
    width:100%;height:200px;border-radius:6px;background:#ffffff;display:block;cursor:crosshair;touch-action:none;
  }
  .sig-actions{display:flex;justify-content:space-between;align-items:center;margin-top:8px;font-size:12px;color:var(--muted)}
  .sig-actions button{
    background:transparent;border:1px solid var(--border);color:var(--muted);
    padding:6px 12px;border-radius:6px;cursor:pointer;font-size:12px;
  }
  .sig-actions button:hover{color:var(--text);border-color:var(--gold)}
  .review-table{margin-top:6px;border:1px solid var(--border);border-radius:10px;overflow:hidden}
  .review-table .row{display:grid;grid-template-columns:130px 1fr;padding:10px 14px;border-bottom:1px solid var(--border-soft);font-size:13px}
  .review-table .row:last-child{border-bottom:none}
  .review-table .row .k{color:var(--muted);text-transform:uppercase;font-size:10.5px;letter-spacing:0.08em}
  .review-table .row .v{color:var(--text)}
  .review-table .row .v.muted{color:var(--muted)}
  .privacy{
    margin-top:18px;font-size:11.5px;color:var(--muted);line-height:1.55;
    padding:10px 12px;border-left:2px solid var(--gold);background:rgba(201,162,39,0.05);border-radius:0 6px 6px 0;
  }
  .actions{display:flex;justify-content:space-between;gap:12px;margin-top:24px}
  .btn{
    padding:12px 22px;font:inherit;font-size:14px;font-weight:700;letter-spacing:0.03em;
    border-radius:9px;cursor:pointer;border:none;transition:filter .12s,transform .06s,background .15s;
  }
  .btn.primary{background:var(--gold);color:#1a1300}
  .btn.primary:hover{filter:brightness(1.06)}
  .btn.primary:active{transform:translateY(1px)}
  .btn.primary[disabled]{background:#3a3a3a;color:#888;cursor:not-allowed}
  .btn.ghost{background:transparent;border:1px solid var(--border);color:var(--muted)}
  .btn.ghost:hover{color:var(--text);border-color:var(--gold)}
  .err{
    margin-top:14px;padding:11px 13px;border-radius:8px;font-size:13px;line-height:1.4;
    background:rgba(255,107,107,0.08);border:1px solid rgba(255,107,107,0.35);color:var(--err);
    display:none;
  }
  .err.show{display:block}
  .ok{
    margin-top:14px;padding:11px 13px;border-radius:8px;font-size:13px;line-height:1.4;
    background:rgba(74,222,128,0.08);border:1px solid rgba(74,222,128,0.35);color:var(--ok);
    display:none;
  }
  .ok.show{display:block}
  .footer-meta{
    margin-top:22px;padding-top:14px;border-top:1px dashed var(--border);
    display:flex;justify-content:space-between;font-size:10.5px;color:var(--muted);letter-spacing:0.04em;
  }
  .pane{display:none}
  .pane.active{display:block;animation:fade .18s ease}
  @keyframes fade{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:none}}
  .spinner{
    display:inline-block;width:14px;height:14px;border-radius:50%;
    border:2px solid rgba(255,255,255,0.3);border-top-color:#1a1300;
    animation:spin .7s linear infinite;vertical-align:-3px;margin-right:7px;
  }
  @keyframes spin{to{transform:rotate(360deg)}}
  .success-state{text-align:center;padding:20px 0}
  .success-state .check{
    width:60px;height:60px;border-radius:50%;background:rgba(74,222,128,0.12);
    border:2px solid var(--ok);display:grid;place-items:center;margin:0 auto 16px;color:var(--ok);font-size:30px;font-weight:700;
  }
  .success-state h2{margin:0 0 8px}
  .lid{
    display:inline-block;margin:8px 0 4px;padding:6px 12px;background:var(--bg-2);
    border:1px solid var(--border);border-radius:6px;
    font-family:Consolas,monospace;font-size:13px;color:var(--gold);
  }
</style>
</head>
<body>
  <main class="shell" id="shell">
    <header>
      <div class="crest">CE</div>
      <div class="title">
        Chief Engineer Pro
        <span class="sub">eORB Pro Portable — First Activation</span>
      </div>
    </header>

    <div class="stepper">
      <div class="step active" data-step="1"></div>
      <div class="step" data-step="2"></div>
      <div class="step" data-step="3"></div>
      <div class="step" data-step="4"></div>
    </div>
    <div class="stepper-meta">
      <span id="stepLabel">Step 1 of 4 · Identity</span>
      <span>Requires Internet</span>
    </div>

    <!-- STEP 1 — IDENTITY -->
    <section class="pane active" id="pane-1">
      <h2>Tell us who you are</h2>
      <p class="lede">This information is captured once, only on first activation. It is bound to your license and to the agreement you'll sign on the next step. Required for activation.</p>

      <label for="fullName">Full Name</label>
      <input id="fullName" class="field" type="text" autocomplete="name" placeholder="e.g. Juan Dela Cruz" />

      <label for="email">Email <span class="optional">— the one you used to buy CEP</span></label>
      <input id="email" class="field" type="email" autocomplete="email" placeholder="you@example.com" spellcheck="false" />

      <div class="grid-2">
        <div>
          <label for="country">Country</label>
          <select id="country" class="field">
            <option value="">— Select —</option>
            <option>Philippines</option>
            <option>Singapore</option>
            <option>Greece</option>
            <option>Cyprus</option>
            <option>India</option>
            <option>Indonesia</option>
            <option>United Kingdom</option>
            <option>United States</option>
            <option>Norway</option>
            <option>Denmark</option>
            <option>Germany</option>
            <option>Netherlands</option>
            <option>UAE</option>
            <option>Other</option>
          </select>
        </div>
        <div>
          <label for="rank">Rank</label>
          <select id="rank" class="field">
            <option value="">— Select —</option>
            <option>4th Engineer</option>
            <option>3rd Engineer</option>
            <option>2nd Engineer</option>
            <option>Chief Engineer</option>
            <option>Superintendent</option>
            <option>Cadet</option>
            <option>Other</option>
          </select>
        </div>
      </div>

      <div class="grid-2">
        <div>
          <label for="company">Company <span class="optional">— optional</span></label>
          <input id="company" class="field" type="text" placeholder="e.g. Anglo-Eastern" />
        </div>
        <div>
          <label for="vessel">Vessel <span class="optional">— optional</span></label>
          <input id="vessel" class="field" type="text" placeholder="e.g. MV Pacific Voyager" />
        </div>
      </div>

      <div class="err" id="err1"></div>
      <div class="actions">
        <span></span>
        <button class="btn primary" id="next1" disabled>Continue</button>
      </div>
    </section>

    <!-- STEP 2 — AGREEMENT -->
    <section class="pane" id="pane-2">
      <h2>Authorized User Declaration</h2>
      <p class="lede">Read the agreement below carefully. You must accept it before continuing. Your acceptance is recorded with a timestamp and bound to your license.</p>

      <div class="pane-2-grid">
        <div class="agreement-col">
          <div class="agreement-card" id="agreementText">
            <p>I confirm this license is for my personal authorized use.</p>
            <p>I agree not to redistribute, clone, upload, resell, reverse engineer, or share unauthorized copies of this software or my license key.</p>
            <p>I understand the software may include license verification, telemetry, watermarking, and anti-piracy mechanisms.</p>
            <p>I acknowledge that unauthorized redistribution may result in revocation of my license without refund or notice.</p>
          </div>
        </div>
        <div class="side-col">
          <label class="check-row" for="acceptChk" style="margin-top:0">
            <input type="checkbox" id="acceptChk" />
            <span class="lbl">I have read and I accept the Authorized User Declaration above.</span>
          </label>

          <div class="privacy" style="margin-top:0">
            <strong>Privacy:</strong> Information collected is used only for license verification and anti-piracy protection. No vessel records or operational ORB data are transmitted. Only activation metadata is stored.
          </div>

          <div class="err" id="err2"></div>
          <div class="actions" style="margin-top:6px">
            <button class="btn ghost" id="back2">Back</button>
            <button class="btn primary" id="next2" disabled>Continue</button>
          </div>
        </div>
      </div>
    </section>

    <!-- STEP 3 — SIGNATURE -->
    <section class="pane" id="pane-3">
      <h2>Digital Signature</h2>
      <p class="lede">Sign with your mouse, touchpad, or finger. This signature will appear on your license PDF and be stored as part of your activation record.</p>

      <div class="sig-pad-wrap">
        <canvas id="sigCanvas"></canvas>
      </div>
      <div class="sig-actions">
        <span id="sigHint">Sign anywhere in the white area above</span>
        <button type="button" id="sigClear">Clear</button>
      </div>

      <div class="err" id="err3"></div>
      <div class="actions">
        <button class="btn ghost" id="back3">Back</button>
        <button class="btn primary" id="next3" disabled>Continue</button>
      </div>
    </section>

    <!-- STEP 4 — REVIEW & ACTIVATE -->
    <section class="pane" id="pane-4">
      <h2>Review &amp; Activate</h2>
      <p class="lede">Final check. Clicking <strong>Activate</strong> will contact our server, generate your license, and create a signed PDF copy. You only need internet for this one step — the app works offline forever afterwards.</p>

      <div class="review-table" id="reviewTable"></div>

      <div class="err" id="err4"></div>
      <div class="ok" id="ok4"></div>
      <div class="actions">
        <button class="btn ghost" id="back4">Back</button>
        <button class="btn primary" id="activateBtn">Activate</button>
      </div>
    </section>

    <!-- SUCCESS -->
    <section class="pane" id="pane-success">
      <div class="success-state">
        <div class="check">✓</div>
        <h2>Activation complete</h2>
        <p class="lede">Your license has been issued and a signed PDF copy has been saved to your USB and to our records.</p>
        <div class="lid" id="successLid"></div>
        <div class="actions" style="justify-content:center;margin-top:18px">
          <button class="btn primary" id="openAppBtn">Open eORB Simulator</button>
        </div>
      </div>
    </section>

    <div class="footer-meta">
      <span id="metaVer">eORB Pro Portable</span>
      <span>USB-bound license</span>
    </div>
  </main>

<script>
(function(){
  const state = {
    step: 1,
    identity: { fullName:'', email:'', country:'', rank:'', company:'', vessel:'' },
    accepted: false,
    signatureDataUrl: null
  };

  const $ = (id) => document.getElementById(id);
  const panes = { 1: $('pane-1'), 2: $('pane-2'), 3: $('pane-3'), 4: $('pane-4'), success: $('pane-success') };

  function showStep(n){
    state.step = n;
    Object.values(panes).forEach(p => p.classList.remove('active'));
    if (n === 'success') {
      panes.success.classList.add('active');
      document.querySelectorAll('.stepper .step').forEach(el => el.classList.add('done'));
      $('stepLabel').textContent = 'Activated';
      return;
    }
    panes[n].classList.add('active');
    document.querySelectorAll('.stepper .step').forEach(el => {
      const i = Number(el.dataset.step);
      el.classList.toggle('done', i < n);
      el.classList.toggle('active', i === n);
    });
    const labels = { 1:'Identity', 2:'Agreement', 3:'Signature', 4:'Review' };
    $('stepLabel').textContent = `Step ${n} of 4 · ${labels[n]}`;
  }

  // ----- STEP 1: identity -----
  function validateStep1(){
    const fullName = $('fullName').value.trim();
    const email = $('email').value.trim().toLowerCase();
    const country = $('country').value;
    const rank = $('rank').value;
    const ok = fullName.length >= 2 && email.includes('@') && country && rank;
    $('next1').disabled = !ok;
    return ok;
  }
  ['fullName','email','country','rank','company','vessel'].forEach(id => {
    $(id).addEventListener('input', validateStep1);
    $(id).addEventListener('change', validateStep1);
  });
  $('next1').addEventListener('click', () => {
    if (!validateStep1()) return;
    state.identity = {
      fullName: $('fullName').value.trim(),
      email: $('email').value.trim().toLowerCase(),
      country: $('country').value,
      rank: $('rank').value,
      company: $('company').value.trim(),
      vessel: $('vessel').value.trim()
    };
    showStep(2);
  });

  // ----- STEP 2: agreement -----
  $('acceptChk').addEventListener('change', () => {
    state.accepted = $('acceptChk').checked;
    $('next2').disabled = !state.accepted;
  });
  $('back2').addEventListener('click', () => showStep(1));
  $('next2').addEventListener('click', () => {
    if (!state.accepted) return;
    showStep(3);
    setTimeout(setupSigPad, 30);  // canvas needs to be visible to size correctly
  });

  // ----- STEP 3: signature pad -----
  let sigCtx = null, sigHasStrokes = false, sigDrawing = false, sigLastX = 0, sigLastY = 0;

  function setupSigPad(){
    const c = $('sigCanvas');
    const rect = c.getBoundingClientRect();
    // Set internal resolution to match displayed size (with DPR for crisp lines).
    const dpr = window.devicePixelRatio || 1;
    c.width = Math.floor(rect.width * dpr);
    c.height = Math.floor(rect.height * dpr);
    sigCtx = c.getContext('2d');
    sigCtx.scale(dpr, dpr);
    sigCtx.lineCap = 'round';
    sigCtx.lineJoin = 'round';
    sigCtx.strokeStyle = '#101820';
    sigCtx.lineWidth = 2.4;
    sigCtx.fillStyle = '#ffffff';
    sigCtx.fillRect(0, 0, c.width, c.height);

    sigHasStrokes = false;
    $('next3').disabled = true;
    $('sigHint').textContent = 'Sign anywhere in the white area above';

    function pos(e){
      const r = c.getBoundingClientRect();
      const t = (e.touches && e.touches[0]) || e;
      return { x: t.clientX - r.left, y: t.clientY - r.top };
    }
    function start(e){
      e.preventDefault();
      sigDrawing = true;
      const p = pos(e);
      sigLastX = p.x; sigLastY = p.y;
    }
    function move(e){
      if (!sigDrawing) return;
      e.preventDefault();
      const p = pos(e);
      sigCtx.beginPath();
      sigCtx.moveTo(sigLastX, sigLastY);
      sigCtx.lineTo(p.x, p.y);
      sigCtx.stroke();
      sigLastX = p.x; sigLastY = p.y;
      if (!sigHasStrokes) {
        sigHasStrokes = true;
        $('next3').disabled = false;
        $('sigHint').textContent = 'Signature captured. Continue or Clear to retry.';
      }
    }
    function end(e){
      if (e) e.preventDefault();
      sigDrawing = false;
    }

    c.onmousedown = start;
    c.onmousemove = move;
    c.onmouseup = end;
    c.onmouseleave = end;
    c.ontouchstart = start;
    c.ontouchmove = move;
    c.ontouchend = end;
    c.ontouchcancel = end;
  }

  $('sigClear').addEventListener('click', () => setupSigPad());
  $('back3').addEventListener('click', () => showStep(2));
  $('next3').addEventListener('click', () => {
    if (!sigHasStrokes) return;
    state.signatureDataUrl = $('sigCanvas').toDataURL('image/png');
    buildReview();
    showStep(4);
  });

  // ----- STEP 4: review + activate -----
  function buildReview(){
    const id = state.identity;
    const rows = [
      ['Full Name', id.fullName],
      ['Email', id.email],
      ['Country', id.country],
      ['Rank', id.rank],
      ['Company', id.company || '—'],
      ['Vessel', id.vessel || '—'],
      ['Agreement', 'Accepted'],
      ['Signature', state.signatureDataUrl ? 'Provided' : 'Missing']
    ];
    $('reviewTable').innerHTML = rows.map(([k, v]) => `
      <div class="row"><div class="k">${k}</div><div class="v${(!v || v==='—') ? ' muted' : ''}">${escapeHtml(v)}</div></div>
    `).join('');
  }
  function escapeHtml(s){
    return String(s||'').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
  }

  $('back4').addEventListener('click', () => showStep(3));
  $('activateBtn').addEventListener('click', async () => {
    const btn = $('activateBtn');
    const errBox = $('err4'), okBox = $('ok4');
    errBox.classList.remove('show'); okBox.classList.remove('show');
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner"></span> Activating…';

    try {
      const payload = {
        identity: state.identity,
        agreement: { version: '1.0' },
        signatureDataUrl: state.signatureDataUrl
      };
      const res = await window.eORB.agreement.submit(payload);
      if (res && res.ok) {
        $('successLid').textContent = res.license_id;
        showStep('success');
        return;
      }
      const msg = mapError(res && res.error);
      errBox.textContent = msg;
      errBox.classList.add('show');
      btn.disabled = false;
      btn.textContent = 'Try Again';
    } catch (e) {
      errBox.textContent = 'Unexpected error: ' + (e && e.message);
      errBox.classList.add('show');
      btn.disabled = false;
      btn.textContent = 'Try Again';
    }
  });

  function mapError(code){
    const map = {
      usb_unreadable: 'We could not read the USB stick you are running from. Plug eORB.exe into a real USB drive and try again.',
      invalid_signature: 'Signature was not captured properly. Go back and sign again.',
      invalid_email: 'The email you entered is not valid.',
      missing_name: 'Full name is required.',
      missing_signature: 'A digital signature is required.',
      missing_usb_hash: 'Could not identify your USB drive. Make sure you are running eORB.exe from a USB.',
      agreement_not_accepted: 'You must accept the Authorized User Declaration to continue.',
      not_member: 'No CEP account found for this email. Register at chiefengineerpro.com.',
      free_tier: 'eORB Pro Portable requires Accelerator tier or higher.',
      device_limit: 'Device limit reached for this account. Email support@chiefengineerpro.com.',
      revoked: 'This license has been deactivated. Contact support@chiefengineerpro.com.',
      timeout: 'The activation server did not respond. Check your internet connection and try again.',
      network: 'Could not reach the activation server. Connect to the internet and try again.',
      pdf_render_failed: 'We could not generate your license PDF. Restart the app and try again.',
      write_failed: 'Could not write license file to your USB. Make sure the drive is not write-protected.'
    };
    return map[code] || ('Activation failed (' + (code || 'unknown') + '). Please try again.');
  }

  // ----- SUCCESS -----
  $('openAppBtn').addEventListener('click', async () => {
    try { await window.eORB.agreement.openApp(); } catch (_) {}
  });

  // ----- INIT -----
  try {
    if (window.eORB && window.eORB.build) {
      $('metaVer').textContent = `${window.eORB.build.productName || 'eORB Pro Portable'} · v${window.eORB.build.version || ''}`;
    }
  } catch (_) {}

  // Re-size sigpad if window resizes while on step 3.
  window.addEventListener('resize', () => {
    if (state.step === 3) {
      const data = sigHasStrokes ? $('sigCanvas').toDataURL('image/png') : null;
      setupSigPad();
      if (data) {
        const img = new Image();
        img.onload = () => sigCtx.drawImage(img, 0, 0, $('sigCanvas').width / (window.devicePixelRatio||1), $('sigCanvas').height / (window.devicePixelRatio||1));
        img.src = data;
        sigHasStrokes = true;
        $('next3').disabled = false;
      }
    }
  });

  showStep(1);
})();
</script>
</body>
</html>
