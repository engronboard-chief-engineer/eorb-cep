        <span>ROB Dashboard</span>
      </button>

      <button class="nav-item" onclick="switchTab('entry')" id="nav-btn-entry">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/></svg>
        <span>New Entry</span>
      </button>

      <button class="nav-item" onclick="switchTab('log')" id="nav-btn-log">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        <span>ORB Log</span>
      </button>

      <div class="sidebar-section-label">Setup</div>

      <button class="nav-item" onclick="switchTab('tankmap')" id="nav-btn-tankmap">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
        <span>Tank Condition</span>
      </button>

      <button class="nav-item" onclick="switchTab('tanks')" id="nav-btn-tanks">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/></svg>
        <span>Tank Editor</span>
      </button>

      <button class="nav-item" onclick="switchTab('crew')" id="nav-btn-crew">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        <span>Crew</span>
      </button>

      <button class="nav-item" onclick="switchTab('equipment')" id="nav-btn-equipment">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
        <span>Equipment</span>
      </button>

      <button class="nav-item" onclick="switchTab('reference')" id="nav-btn-reference">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <span>Reference</span>
      </button>
    </nav>

    <div class="sidebar-footer">
      <button class="sidebar-footer-btn" onclick="toggleTheme()" id="theme-toggle-btn">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
        <span id="theme-toggle-label">Light Mode</span>
      </button>
      <button class="sidebar-footer-btn" onclick="loadSampleDataNow()" style="color:var(--amber);">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
        <span>Load Sample Data</span>
      </button>
      <div class="disc-banner" style="font-size:9px;text-align:center;">Educational Use Only</div>
    </div>
  </aside>

  <!-- MAIN AREA -->
  <div class="main-area">

    <!-- Top bar -->
    <div class="topbar">
      <button class="mobile-menu-btn" type="button" aria-label="Open menu" onclick="toggleMobileSidebar()">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
      <div class="topbar-page-title" id="topbar-page-title">ROB Dashboard</div>
      <div class="topbar-right">
        <div class="app-version-chip" id="app-version-chip" title="Application version">v1.3.7 · Portable Edition</div>
        <div class="disc-banner">MARPOL / Educational</div>
      </div>
    </div>

  <!-- Tab content -->
  <div class="tab-content">

    <!-- TAB 1: ROB DASHBOARD -->
    <div class="tab-pane active" id="tab-dashboard">
      <div class="section-title">Tank ROB Overview</div>
      <div class="edu-banner">
        <strong>Educational Simulator.</strong> Tank values shown here are for practice and familiarization purposes only. Actual ROB figures must be obtained from onboard soundings and measurement procedures per vessel SMS.
      </div>
      <div style="display:flex;gap:10px;margin-bottom:16px;flex-wrap:wrap;align-items:center;">
        <button class="btn btn-secondary btn-sm" onclick="openRobEditModal(null)">Manual ROB Adjustment</button>
        <button class="btn btn-secondary btn-sm" onclick="switchTab('tanks')">Edit Tanks</button>
        <div style="margin-left:auto;display:flex;gap:8px;">
          <span style="font-family:var(--sans);font-size:11px;color:var(--text3);text-transform:uppercase;letter-spacing:.1em;align-self:center;">Vessel Type:</span>
          <button class="btn btn-sm" id="vtype-dry" onclick="setVesselType('dry')">Dry Fleet</button>
          <button class="btn btn-sm" id="vtype-tanker" onclick="setVesselType('tanker')">Tanker</button>
        </div>
      </div>
      <div id="rob-dashboard-table"></div>
    </div>

    <!-- TAB 2: NEW ENTRY -->
    <div class="tab-pane" id="tab-entry">
      <div style="padding:12px 20px 0;flex-shrink:0;">
        <div class="edu-banner" style="margin-bottom:10px;display:flex;justify-content:space-between;align-items:center;gap:10px;flex-wrap:wrap;">
          <div style="flex:1;min-width:0;">
            <strong>Educational Sample Only.</strong> Entry previews follow MEPC.1/Circ.736/Rev.6 guidance for familiarization. Actual entries must follow vessel SMS, IOPP Certificate, and Chief Engineer instructions.
          </div>
          <button type="button" id="master-clock-chip" class="master-clock-chip" onclick="openMasterClockModal()" title="Master clock (click to edit). Used as the default time for new entries.">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><polyline points="12 7 12 12 15 14"/></svg>
            <span id="master-clock-display">--:--</span>
          </button>
        </div>
      </div>
      <div class="entry-layout" id="entry-layout" data-mobile-step="cat" style="flex:1;margin:0 20px 20px;">
        <!-- LEFT: Category list -->
        <div class="entry-panel" id="panel-cat">
          <div class="entry-panel-header">Categories</div>
          <div id="cat-list"></div>
        </div>
        <!-- MIDDLE: Activity list -->
        <div class="entry-panel" id="panel-act">
          <button class="entry-mobile-back entry-mobile-back--act" type="button" onclick="setWizardStep('cat')">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
            Categories
          </button>
          <div class="entry-panel-header" style="display:flex;align-items:center;justify-content:space-between;">
            <span>Activities</span>
            <button id="act-mode-toggle" type="button" onclick="toggleActMode()" style="font-size:10px;padding:2px 7px;border-radius:10px;border:1px solid var(--border);background:var(--bg3);color:var(--text2);cursor:pointer;font-family:var(--sans);letter-spacing:0.02em;">Code</button>
          </div>
          <div id="act-list"><div class="act-info-panel">Select a category to view activities.</div></div>
        </div>
        <!-- RIGHT: Form panel -->
        <div class="entry-panel" id="panel-form">
          <button class="entry-mobile-back entry-mobile-back--form" type="button" onclick="setWizardStep('act')">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
            Activities
          </button>
          <div class="entry-form-panel" id="entry-form-content">
            <div style="color:var(--text3);font-family:var(--sans);font-size:13px;padding-top:20px;">Select an activity from the left panels to begin recording.</div>
          </div>
        </div>
      </div>
    </div>

    <!-- TAB 3: ORB LOG -->
    <div class="tab-pane" id="tab-log">
      <div class="section-title">ORB Entry Log</div>
      <div class="edu-banner">
        <strong>Practice Log Only.</strong> These entries are educational simulations. They do not constitute a legal Oil Record Book.
      </div>
      <div style="display:flex;gap:10px;margin-bottom:16px;flex-wrap:wrap;">
        <button class="btn btn-primary btn-sm" onclick="openBookPreview()">View as Record Book</button>
        <button class="btn btn-secondary btn-sm" onclick="exportLog()">Export JSON</button>
        <button class="btn btn-secondary btn-sm" onclick="importLog()">Import JSON</button>
        <button class="btn btn-secondary btn-sm no-print" onclick="printRecordBook()">Print Record Book</button>
        <button class="btn btn-danger btn-sm" onclick="clearLog()">Clear All Entries</button>
      </div>
      <div id="orb-log-table"></div>
      <input type="file" id="import-file" accept=".json" style="display:none" onchange="handleImport(event)">
    </div>

    <!-- TAB 4: TANK EDITOR -->
    <div class="tab-pane" id="tab-tanks">
      <div class="section-title">Tank Configuration</div>
      <div class="edu-banner">
        Customize your practice vessel tank arrangement. Changes are saved to your browser and used in the operation simulator.
      </div>
      <div style="display:flex;gap:10px;margin-bottom:16px;flex-wrap:wrap;">
        <button class="btn btn-primary btn-sm" onclick="openAddTankModal()">Add Tank</button>
        <button class="btn btn-secondary btn-sm" onclick="resetDefaultTanks('dry')">Reset — Dry Fleet Defaults</button>
        <button class="btn btn-secondary btn-sm" onclick="resetDefaultTanks('tanker')">Reset — Tanker Defaults</button>
      </div>
      <div id="tank-editor-table"></div>
    </div>

    <!-- TAB 5: REFERENCE -->
    <div class="tab-pane" id="tab-reference">
      <div class="section-title">Reference — MARPOL / ORB / PSC</div>
      <div id="reference-content"></div>
    </div>

    <!-- TAB: CREW -->
    <div class="tab-pane" id="tab-crew">
      <div class="section-title">Crew Roster</div>
      <div class="edu-banner">
        Add engine room crew here. Their names appear as dropdowns in operation forms — no need to retype each time.
      </div>
      <div style="display:flex;gap:10px;margin-bottom:20px;flex-wrap:wrap;align-items:center;">
        <button class="btn btn-primary btn-sm" onclick="openCrewModal(null)">Add Crew Member</button>
        <span style="font-family:var(--sans);font-size:11px;color:var(--text3);margin-left:4px;" id="crew-count-label"></span>
      </div>
      <div id="crew-list-container"></div>
    </div>

    <!-- TAB: EQUIPMENT (item E) -->
    <div class="tab-pane" id="tab-equipment">
      <div class="section-title">Equipment &mdash; Pumps &amp; Discharge Rates</div>
      <div class="edu-banner">
        Configure your pumps, incinerator and boiler with their rated capacity (m3/hour). New entries that exceed a unit's rated rate &mdash; e.g. transferring 5 m3 of OWS effluent in 1 hour through a 3 m3/h pump, or burning 1 m3 of sludge in 1 hour through a 0.5 m3/h incinerator &mdash; will be flagged before save.
      </div>
      <div style="display:flex;gap:10px;margin-bottom:16px;flex-wrap:wrap;">
        <button class="btn btn-primary btn-sm" onclick="openEquipmentModal(null)">+ Add Equipment</button>
      </div>
      <div id="equipment-list-container"></div>
      <div class="section-title" style="margin-top:24px;">OWS Discharge Sequence Rule</div>
      <div class="edu-banner">
        A manual or auto OWS overboard discharge (Code D / E) is blocked unless a Code I OCM / recirculation test of at least the duration below has been recorded, and the overboard valve has been unsealed.
      </div>
      <div class="form-group" style="max-width:360px;">
        <label class="form-label" for="eq-ows-min-minutes">Min. OCM / recirculation test duration before OWS discharge (minutes)</label>
        <input class="form-input" type="number" id="eq-ows-min-minutes" min="0" step="1" oninput="saveOwsMinMinutes()" onchange="saveOwsMinMinutes()">
      </div>
    </div>

    <!-- TAB 6: TANK CONDITION -->
    <div class="tab-pane" id="tab-tankmap">
      <div class="section-title">Tank Condition — Visual ROB Overview</div>
      <div class="edu-banner">
        <strong>Visual reference only.</strong> Tank fill levels are proportional to ROB vs. capacity. Bilge wells (no capacity) are shown as status indicators.
      </div>
      <div id="tankmap-legend" class="tm-legend"></div>
      <div id="tankmap-groups"></div>
    </div>

  </div><!-- /tab-content -->
  </div><!-- /main-area -->
</div><!-- /app -->

<!-- Mobile sidebar scrim -->
<div class="sidebar-scrim" id="sidebar-scrim" onclick="closeMobileSidebar()"></div>

<!-- ============================================================
     MODAL: VESSEL SETTINGS
     ============================================================ -->
<div class="modal-overlay hidden" id="vessel-modal">
  <div class="modal-box" style="max-width:400px">
    <div class="modal-head">
      <h3>Vessel Settings</h3>
      <button class="modal-close" onclick="closeModal('vessel-modal')">&times;</button>
    </div>
    <div class="modal-body">
      <div class="form-group">
        <label class="form-label" for="vs-name">Vessel Name</label>
        <input class="form-input" id="vs-name" placeholder="MV PRACTICE VESSEL">
      </div>
      <div class="form-group">
        <label class="form-label" for="vs-type">Vessel Type</label>
        <select class="form-select" id="vs-type">
          <option value="dry">Dry Cargo / Bulk Carrier</option>
          <option value="tanker">Oil Tanker</option>
          <option value="other">Other / General</option>
        </select>
      </div>
      <div class="form-group">
        <label class="form-label" for="vs-flag">Flag State (Educational)</label>
        <input class="form-input" id="vs-flag" placeholder="e.g. Panama">
      </div>
      <div class="form-group">
        <label class="form-label" for="vs-imo">IMO Number (Educational)</label>
        <input class="form-input" id="vs-imo" placeholder="e.g. IMO 1234567">
      </div>
    </div>
    <div class="modal-foot">
      <button class="btn btn-secondary" onclick="closeModal('vessel-modal')">Cancel</button>
      <button class="btn btn-primary" onclick="saveVesselSettings()">Save Settings</button>
    </div>
  </div>
</div>

<!-- ============================================================
     MODAL: CREW
     ============================================================ -->
<div class="modal-overlay hidden" id="crew-modal">
  <div class="modal-box" style="max-width:380px">
    <div class="modal-head">
      <h3 id="crew-modal-title">Add Crew Member</h3>
      <button class="modal-close" onclick="closeModal('crew-modal')">&times;</button>
    </div>
    <div class="modal-body">
      <input type="hidden" id="crew-edit-id">
      <div class="form-group">
        <label class="form-label" for="crew-name">Full Name</label>
        <input class="form-input" id="crew-name" placeholder="e.g. J.D. REYES">
      </div>
      <div class="form-group">
        <label class="form-label" for="crew-rank">Rank</label>
        <select class="form-select" id="crew-rank">
          <option value="Chief Engineer">Chief Engineer (CE)</option>
          <option value="2nd Engineer">2nd Engineer (2E)</option>
          <option value="3rd Engineer">3rd Engineer (3E)</option>
          <option value="4th Engineer">4th Engineer (4E)</option>
          <option value="Junior 4th Engineer">Junior 4th Engineer (J4E)</option>
          <option value="First Assistant Engineer">First Assistant Engineer (1AE)</option>
          <option value="Second Assistant Engineer">Second Assistant Engineer (2AE)</option>
          <option value="Third Assistant Engineer">Third Assistant Engineer (3AE)</option>
          <option value="Fourth Assistant Engineer">Fourth Assistant Engineer (4AE)</option>
          <option value="Electrician">Electrician (ELC)</option>
          <option value="Motorman">Motorman (MTM)</option>
          <option value="Oiler">Oiler (OLR)</option>
          <option value="Other">Other</option>
        </select>
      </div>
    </div>
    <div class="modal-foot">
      <button class="btn btn-secondary" onclick="closeModal('crew-modal')">Cancel</button>
      <button class="btn btn-primary" onclick="saveCrew()">Save</button>
    </div>
  </div>
</div>

<!-- ============================================================
     MODAL: EQUIPMENT (item E)
     ============================================================ -->
<div class="modal-overlay hidden" id="equipment-modal">
  <div class="modal-box" style="max-width:420px">
    <div class="modal-head">
      <h3 id="equipment-modal-title">Add Equipment</h3>
      <button class="modal-close" onclick="closeModal('equipment-modal')">&times;</button>
    </div>
    <div class="modal-body">
      <input type="hidden" id="equipment-edit-id">
      <div class="form-group">
        <label class="form-label" for="equipment-name">Equipment Name</label>
        <input class="form-input" id="equipment-name" placeholder="e.g. OWS Pump, Sludge Transfer Pump, Cargo Pump #2">
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label" for="equipment-type">Type</label>
          <select class="form-select" id="equipment-type">
            <option value="ows">OWS / 15ppm overboard</option>
            <option value="bilge">Bilge transfer pump</option>
            <option value="sludge">Sludge transfer pump</option>
            <option value="incinerator">Incinerator / sludge burner</option>
            <option value="boiler">Boiler (sludge burning)</option>
            <option value="cargo">Cargo pump</option>
            <option value="other">Other</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label" for="equipment-rate">Rated Capacity (m3/h)</label>
          <input class="form-input" type="number" id="equipment-rate" min="0" step="0.1" placeholder="3.0">
        </div>
      </div>
      <div class="form-group">
        <label class="form-label" for="equipment-notes">Notes (optional)</label>
        <input class="form-input" id="equipment-notes" placeholder="Maker, model, certification, etc.">
      </div>
    </div>
    <div class="modal-foot">
      <button class="btn btn-secondary" onclick="closeModal('equipment-modal')">Cancel</button>
      <button class="btn btn-primary" onclick="saveEquipment()">Save</button>
    </div>
  </div>
</div>

<!-- ============================================================
     MODAL: ROB ADJUSTMENT
     ============================================================ -->
<div class="modal-overlay hidden" id="rob-edit-modal">
  <div class="modal-box">
    <div class="modal-head">
      <h3>Manual ROB Adjustment</h3>
      <button class="modal-close" onclick="closeModal('rob-edit-modal')">&times;</button>
    </div>
    <div class="modal-body">
      <div class="edu-banner">Manual ROB adjustments are for educational scenario setup and sounding practice. All changes are logged with timestamp and reason.</div>
      <div class="form-group">
        <label class="form-label" for="rob-edit-tank">Tank</label>
        <select class="form-select" id="rob-edit-tank" onchange="updateRobEditFields()"></select>
      </div>
      <div id="rob-edit-current" style="margin-bottom:16px;font-family:var(--mono);font-size:13px;color:var(--text2);"></div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label" for="rob-edit-value">New ROB Value</label>
          <input class="form-input" type="number" id="rob-edit-value" min="0" step="0.01" oninput="updateRobDownReasonVisibility()">
        </div>
        <div class="form-group">
          <label class="form-label" for="rob-edit-unit">Unit</label>
          <select class="form-select" id="rob-edit-unit">
            <option value="m3">m3</option>
            <option value="liters">liters</option>
            <option value="MT">MT</option>
          </select>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label" for="rob-edit-reason">Reason for Adjustment</label>
        <select class="form-select" id="rob-edit-reason">
          <option value="Sounding correction">Sounding correction</option>
          <option value="Manual adjustment">Manual adjustment</option>
          <option value="Educational scenario setup">Educational scenario setup</option>
          <option value="Transfer correction">Transfer correction</option>
          <option value="Tank cleaning">Tank cleaning</option>
          <option value="Daily ROB update">Daily ROB update</option>
          <option value="Other">Other</option>
        </select>
      </div>
      <div class="form-group">
        <label class="form-label" for="rob-edit-remarks">Remarks (optional)</label>
        <input class="form-input" id="rob-edit-remarks" placeholder="Additional notes...">
      </div>
      <div class="form-group" id="rob-edit-downreason-group" style="display:none;">
        <div class="edu-banner" style="background:rgba(224,0,85,0.08);border-color:rgba(224,0,85,0.4);color:#c70042;">
          <strong>ROB-DOWN detected.</strong> Lowering ROB without a corresponding transfer/discharge breaks mass-balance. Provide a justification for this manual decrease — the reason is saved permanently to the tank history.
        </div>
        <label class="form-label" for="rob-edit-downreason">Justification for ROB Decrease <span style="color:#e05;">*</span></label>
        <textarea class="form-input" id="rob-edit-downreason" rows="2" placeholder="e.g., recalibrated sounding gauge — previous figure was over-read by 0.5 m3"></textarea>
      </div>
    </div>
    <div class="modal-foot">
      <button class="btn btn-secondary" onclick="closeModal('rob-edit-modal')">Cancel</button>
      <button class="btn btn-primary" onclick="saveRobEdit()">Apply Adjustment</button>
    </div>
  </div>
</div>

<!-- ============================================================
     MODAL: ADD / EDIT TANK
     ============================================================ -->
<div class="modal-overlay hidden" id="tank-modal">
  <div class="modal-box">
    <div class="modal-head">
      <h3 id="tank-modal-title">Add Tank</h3>
      <button class="modal-close" onclick="closeModal('tank-modal')">&times;</button>
    </div>
    <div class="modal-body">
      <input type="hidden" id="tank-edit-id">
      <div class="form-group">
        <label class="form-label" for="tank-name">Tank Name</label>
        <input class="form-input" id="tank-name" placeholder="e.g. Sludge Tank No.1">
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label" for="tank-type">Tank Type</label>
          <select class="form-select" id="tank-type">
            <option value="bilge">Bilge Holding</option>
            <option value="sludge">Sludge</option>
            <option value="waste">Waste Oil</option>
            <option value="dirty">Dirty Oil</option>
            <option value="hfo">HFO</option>
            <option value="vlsfo">VLSFO</option>
            <option value="ulsfo">ULSFO</option>
            <option value="mdo">MDO</option>
            <option value="mgo">MGO</option>
            <option value="lsmgo">LSMGO</option>
            <option value="lo">Lube Oil</option>
            <option value="lo-settle">LO Settling</option>
            <option value="lo-service">LO Service</option>
            <option value="fo-settle">FO Settling</option>
            <option value="fo-service">FO Service</option>
            <option value="do-service">DO Service</option>
            <option value="scav">Scavenge Drain</option>
            <option value="slop">Slop Tank</option>
            <option value="cargo">Cargo Oil</option>
            <option value="dirty-ballast">Dirty Ballast</option>
            <option value="pumproom">Pump Room Bilge</option>
            <option value="bilgewell">Bilge Well (no ROB)</option>
            <option value="other">Other</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label" for="tank-unit">Unit</label>
          <select class="form-select" id="tank-unit">
            <option value="m3">m3 (volume)</option>
            <option value="liters">liters (volume)</option>
            <option value="MT">MT (mass)</option>
          </select>
        </div>
      </div>
      <div id="tank-capacity-row" class="form-row">
        <div class="form-group">
          <label class="form-label" for="tank-capacity">Capacity</label>
          <input class="form-input" type="number" id="tank-capacity" min="0" step="0.01" placeholder="0.00">
        </div>
        <div class="form-group">
          <label class="form-label" for="tank-rob">Current ROB</label>
          <input class="form-input" type="number" id="tank-rob" min="0" step="0.01" placeholder="0.00">
        </div>
      </div>
      <div class="form-group">
        <label class="form-label" for="tank-ioppc">IOPPC Section Reference (Educational)</label>
        <input class="form-input" id="tank-ioppc" placeholder="e.g. 3.1 / 3.2 / 3.3 — optional">
        <div class="form-hint">3.1 = sludge, 3.2 = OWS/overboard, 3.3 = bilge holding</div>
      </div>
      <div class="form-group">
        <label class="form-label" for="tank-frameno">Frame Numbers (optional)</label>
        <input class="form-input" id="tank-frameno" placeholder="e.g. 25 36 or 25-36">
        <div class="form-hint">Auto-formatted as FR: 25 - 36. Enter one or two frame numbers.</div>
      </div>
    </div>
    <div class="modal-foot">
      <button class="btn btn-secondary" onclick="closeModal('tank-modal')">Cancel</button>
      <button class="btn btn-primary" onclick="saveTank()">Save Tank</button>
    </div>
  </div>
</div>

<!-- ============================================================
     MODAL: CHANGELOG  (item I)
     One-time welcome modal that fires on first launch after an update.
     ============================================================ -->
<div class="modal-overlay hidden" id="changelog-modal">
  <div class="modal-box" style="max-width:520px;">
    <div class="modal-head">
      <h3 id="changelog-modal-title">What&rsquo;s new</h3>
      <button class="modal-close" onclick="dismissChangelogModal()">&times;</button>
    </div>
    <div class="modal-body">
      <div id="changelog-modal-body"></div>
    </div>
    <div class="modal-foot">
      <button class="btn btn-primary" onclick="dismissChangelogModal()">Got it</button>
    </div>
  </div>
</div>

<!-- ============================================================
     MODAL: SIG ROLE ABBREVIATION (mobile only, one-time)
     Explains the OIC / CE shorthand used on small screens.
     ============================================================ -->
<div class="modal-overlay hidden" id="sig-abbrev-modal" style="z-index:1100;">
  <div class="modal-box" style="max-width:440px;">
    <div class="modal-head">
      <h3>Signature labels on mobile</h3>
      <button class="modal-close" onclick="dismissSigAbbrevModal()">&times;</button>
    </div>
    <div class="modal-body">
      <p style="margin:0 0 10px; font-size:13px; line-height:1.5;">
        To keep dates and signatures on one line, the record book uses two short labels on small screens:
      </p>
      <ul style="margin:0 0 10px 18px; padding:0; font-size:13px; line-height:1.7;">
        <li><strong>OIC</strong> &mdash; Officer in Charge</li>
        <li><strong>CE</strong> &mdash; Chief Engineer</li>
      </ul>
      <p style="margin:0; font-size:12px; color:var(--text2);">
        Open the book on a tablet or desktop to see the full labels printed beside each signature.
      </p>
    </div>
    <div class="modal-foot">
      <button class="btn btn-primary" onclick="dismissSigAbbrevModal()">Got it</button>
    </div>
  </div>
</div>

<!-- ============================================================
     MODAL: MASTER CLOCK  (item C)
     Single source of truth for the entry-page "now" time.
     ============================================================ -->
<div class="modal-overlay hidden" id="master-clock-modal">
  <div class="modal-box">
    <div class="modal-head">
      <h3>Master Clock</h3>
      <button class="modal-close" onclick="closeModal('master-clock-modal')">&times;</button>
    </div>
    <div class="modal-body">
      <div class="edu-banner" style="margin-bottom:14px;">
        New entry forms default their Start/Stop time fields to this value. Edit it once at the start of your watch — every wizard form below will pick it up.
      </div>
      <div class="form-group">
        <label class="form-label" for="master-clock-input">Current Watch Time (HH:MM, 24h)</label>
        <input class="form-input" type="time" id="master-clock-input">
      </div>
    </div>
    <div class="modal-foot">
      <button class="btn btn-secondary" onclick="closeModal('master-clock-modal')">Cancel</button>
      <button class="btn btn-primary" onclick="saveMasterClock()">Save</button>
    </div>
  </div>
</div>

<!-- ============================================================
     MODAL: TANK SAVE IMPACT WARNING  (items 4a + 4b)
     Shows affected entries on rename + capacity-vs-history conflicts.
     ============================================================ -->
<div class="modal-overlay hidden" id="tank-impact-modal">
  <div class="modal-box wide">
    <div class="modal-head">
      <h3>Review Tank Changes</h3>
      <button class="modal-close" onclick="closeModal('tank-impact-modal')">&times;</button>
    </div>
    <div class="modal-body">
      <div class="edu-banner" style="background:rgba(246,173,85,0.12);border-color:rgba(246,173,85,0.4);">
        <strong>Heads-up.</strong> The edit you are about to save affects existing ORB log entries or breaks tank constraints. Review the changes below before continuing.
      </div>
      <div id="tank-impact-body" style="font-family:var(--sans);font-size:13px;color:var(--text2);"></div>
    </div>
    <div class="modal-foot">
      <button class="btn btn-secondary" onclick="closeModal('tank-impact-modal')">Cancel</button>
      <button class="btn btn-secondary" id="tank-impact-skip" onclick="confirmSaveTank(false)" style="display:none;">Save Without Updating Entries</button>
      <button class="btn btn-primary" onclick="confirmSaveTank(true)">Apply &amp; Update Entries</button>
    </div>
  </div>
</div>

<!-- ============================================================
     MODAL: TANK DELETE CONFIRMATION  (item 4d)
     Lists referenced entries before allowing delete.
     ============================================================ -->
<div class="modal-overlay hidden" id="tank-delete-modal">
  <div class="modal-box">
    <div class="modal-head">
      <h3>Delete Tank</h3>
      <button class="modal-close" onclick="closeModal('tank-delete-modal')">&times;</button>
    </div>
    <div class="modal-body">
      <div class="edu-banner" style="background:rgba(255,99,132,0.12);border-color:rgba(255,99,132,0.55);color:#ff8aa3;">
        <strong style="color:#ffb3c1;">This action cannot be undone.</strong> Deleting a tank removes it from the simulator. Past ORB entries that mention this tank by name will remain in your log, but new wizard forms will no longer offer it.
      </div>
      <div id="tank-delete-body" style="font-family:var(--sans);font-size:13px;color:var(--text2);"></div>
    </div>
    <div class="modal-foot">
      <button class="btn btn-secondary" onclick="closeModal('tank-delete-modal')">Cancel</button>
      <button class="btn btn-danger" onclick="confirmDeleteTank()">Delete Tank</button>
    </div>
  </div>
</div>

