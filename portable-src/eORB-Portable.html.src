<!-- ============================================================
     MODAL: SIGNATURE CONFIRMATION
     ============================================================ -->
<div class="modal-overlay hidden" id="sig-modal">
  <div class="modal-box" style="max-width:440px">
    <div class="modal-head">
      <h3>Confirm Entry — Educational</h3>
      <button class="modal-close" onclick="closeModal('sig-modal')">&times;</button>
    </div>
    <div class="modal-body">
      <div class="edu-banner"><strong>Educational confirmation only.</strong> This simulates the officer signature step for practice awareness.</div>
      <div id="sig-preview-summary" style="margin-bottom:16px;"></div>
      <div id="sig-officer-block">
        <div class="form-group">
          <label class="form-label">Officer-in-Charge</label>
          <select class="form-select" id="sig-name-select"></select>
          <input type="hidden" id="sig-name">
          <input type="hidden" id="sig-rank">
        </div>
      </div>

      <div class="sig-pad-block" id="sig-officer-pad-block">
        <span class="sig-pad-label">Officer-in-Charge Signature</span>
        <div class="sig-pad-wrap">
          <canvas id="sig-canvas-officer" height="80"></canvas>
        </div>
        <div class="sig-pad-actions">
          <button class="sig-pad-clear" type="button" onclick="clearSigPad('sig-canvas-officer')">Clear</button>
        </div>
      </div>

      <div id="sig-ce-name-block" style="display:none;">
        <div class="form-group">
          <label class="form-label">Chief Engineer</label>
          <select class="form-select" id="sig-ce-name-select"></select>
          <input type="hidden" id="sig-ce-name">
        </div>
      </div>

      <div class="sig-pad-block">
        <span class="sig-pad-label" id="sig-ce-pad-label">Chief Engineer Signature</span>
        <div class="sig-pad-wrap">
          <canvas id="sig-canvas-ce" height="80"></canvas>
        </div>
        <div class="sig-pad-actions">
          <button class="sig-pad-clear" type="button" onclick="clearSigPad('sig-canvas-ce')">Clear</button>
        </div>
      </div>
    </div>
    <div class="modal-foot">
      <button class="btn btn-secondary" onclick="closeModal('sig-modal')">Cancel</button>
      <button class="btn btn-green" onclick="confirmEntry()">Confirm &amp; Save Entry</button>
    </div>
  </div>
</div>

<!-- ============================================================
     MODAL: ORB ENTRY PREVIEW (popup so Confirm button is always reachable)
     ============================================================ -->
<div class="modal-overlay hidden" id="preview-modal">
  <div class="modal-box wide" style="display:flex;flex-direction:column;overflow:hidden;">
    <div class="modal-head" style="flex:0 0 auto;">
      <h3>ORB Entry Preview — Educational Sample</h3>
      <button class="modal-close" onclick="closeModal('preview-modal')">&times;</button>
    </div>
    <div class="modal-body" id="preview-modal-body" style="flex:1 1 auto;overflow-y:auto;min-height:0;"></div>
    <div class="modal-foot" id="preview-modal-foot" style="flex:0 0 auto;"></div>
  </div>
</div>

<!-- ============================================================
     MODAL: BOOK PREVIEW (Electronic Record Book View)
     ============================================================ -->
<div class="modal-overlay hidden" id="book-modal" style="align-items:center;justify-content:center;padding:16px;">
  <div id="book-modal-box">
    <div id="book-modal-topbar">
      <div id="book-modal-title-text">OIL RECORD BOOK — PART I (Machinery Space Operations)</div>
      <div style="display:flex;align-items:center;gap:10px;">
        <span id="book-edu-badge">EDUCATIONAL SAMPLE ONLY</span>
        <button id="book-close-btn" onclick="closeModal('book-modal')" title="Close">&times;</button>
      </div>
    </div>
    <div id="book-pages-container"></div>
  </div>
</div>

<!-- Hidden container for printing the record book -->
<div id="print-record-container" style="display:none;"></div>

<script>
// ============================================================
// PORTABLE EDITION — no DevTools watcher.
// Anti-copy protection for this build is the hardware copy-protected
// USB drive, not JavaScript. The DevTools lockout was removed because
// on shared/unfamiliar ship desktops it false-positives and wipes the
// user's license.
// ============================================================

// ============================================================
// DATA MODEL + STORAGE
// ============================================================
const STORE_TANKS    = 'orb_tanks';
const STORE_ENTRIES  = 'orb_entries';
const STORE_SETTINGS = 'orb_settings';
const STORE_DISC     = 'orb_disc_ack';
const STORE_CREW     = 'orb_crew';
const STORE_EQUIPMENT = 'orb_equipment';
const STORE_LICENSE  = 'orb_lic_token';      // v1 legacy plaintext token
const STORE_LIC_A    = 'orb_lic_a';          // v2 encrypted token half A
const STORE_LIC_B    = 'orb_lic_b';          // v2 encrypted token half B
const STORE_FP_BIND  = 'orb_fp_bind';        // v2 stable+drift fingerprint snapshot
const STORE_ACT_EMAIL = 'orb_act_email';
const STORE_SEEDED   = 'orb_sample_seeded';
const ORB_ACTIVATE_URL = 'https://n8n.srv1083339.hstgr.cloud/webhook/orb-activate';

// Obfuscated key segment A — schema version marker
const _schV = [51,54,54,49];
// App version reference constant — portable build identifies itself to the
// activation webhook so the server can issue an email-bound (not device-bound) token
const _fmtV = 'orb-portable';
// Public app version — shown in topbar, fed into activation payload, gates changelog modal
const APP_VERSION = '1.3.7-portable';
// Portable Edition: re-check the license online every 180 days (6 months).
const PORTABLE_RECHECK_DAYS = 180;
const STORE_CHECKED_AT = 'orb_portable_checked_at';

// Item I — Changelog entries. Add a NEW entry each release; the modal fires
// once per user per APP_VERSION at startup. Bumping APP_VERSION without an
// entry below = silent (no modal). Newest-first order.
const CHANGELOG = [
  {
    version: '1.3.7',
    date: '2026-05-26',
    title: 'Preview opens as a popup',
    items: [
      'Preview ORB Entry now opens in a popup window so the Confirm with Signature button is always visible — fixes the desktop bug where the button stayed below the fold even after the v1.3.6 scroll fix',
      'Update check now follows redirects, so future in-app update banners reach you reliably'
    ]
  },
  {
    version: '1.3.6',
    date: '2026-05-26',
    title: 'Preview scroll fix',
    items: [
      'Clicking Preview ORB Entry now scrolls the preview into view so the Confirm with Signature button is reachable on desktop'
    ]
  },
  {
    version: '1.3.5',
    date: '2026-05-25',
    title: 'Version sync',
    items: [
      'Brought in line with the latest PWA release — same simulator logic, no functional change in the Portable Edition'
    ]
  },
  {
    version: '1.3.4',
    date: '2026-05-25',
    title: 'Bug fixes & new features',
    items: [
      'OWS prerequisites (Code I OCM test + valve unsealing) now strictly enforced before preview',
      'Missing position or stop time now blocks preview for all applicable operations',
      'Bilge transfer pump: pump name field added, rate against pump capacity now enforced',
      'Tank frame numbers: new input field, auto-formatted as FR: N - M',
      'Activity list toggle: switch between Activity name mode and Letter Code mode',
      'Mobile: signature no longer overlaps date on narrow screens',
      'Mobile: disclaimer fits screen without scrolling on landscape/small devices',
      'Mobile: Android clock selector Set button no longer clipped',
      'iOS: fixed stuck scroll in entry panels requiring pinch-to-resume'
    ]
  },
  {
    version: '1.3.2',
    date: '2026-05-21',
    title: 'OWS discharge sequence check',
    items: [
      'A manual or auto OWS overboard discharge (Code D / E) is now blocked unless a Code I OCM / recirculation test and a valve-unsealing entry were recorded first',
      'Once the overboard valve is unsealed, no new entry can be made until you record the reseal',
      'Set the minimum required test duration in the Equipment tab'
    ]
  },
  {
    version: '1.3.1',
    date: '2026-05-20',
    title: 'iPhone & iPad fix',
    items: [
      'Fixed a false "Security check failed" message that could appear on iPhone and iPad while simply scrolling or rotating the screen',
      'Your activation stays intact'
    ]
  },
  {
    version: '1.3.0',
    date: '2026-05-20',
    title: 'Automatic updates',
    items: [
      'The app now updates itself — open it with internet and you always get the latest version, no reinstall needed',
      'New app icon: the Chief Engineer Pro crest',
      'Still works fully offline'
    ]
  },
  {
    version: '1.1.0',
    date: '2026-05-19',
    title: 'Mobile polish + tighter logic',
    items: [
      'Record book reads cleanly on iPhone: no horizontal scroll, signature row fits, CORRECTED stamp is smaller',
      'Bilge transfer rows stay on one row (select + volume + remove)',
      'Code-letter rows always carry a date; page breaks now show "(continued)" on the next page',
      'Time validation auto-clears the warning when you correct the time',
      'Tank rename now lists affected log entries and lets you skip rewriting them',
      'Capacity edits warn when historical or current ROB exceeds the new capacity',
      'Manual ROB-down now requires a written justification before saving',
      'Bunkering / topping / collection: 90% capacity warning + 100% hard block',
      'New "Equipment" tab — set OWS / sludge pump rates; transfers above pump capacity are blocked',
      'Master clock chip in the entry tab — set once, every new form picks it up',
      'Legal property notice on the welcome screen and on every record-book page'
    ]
  }
];

function loadTanks()    { try { return JSON.parse(localStorage.getItem(STORE_TANKS))    || null; } catch(e) { return null; } }
function _lsSave(key, data) {
  try {
    localStorage.setItem(key, JSON.stringify(data));
  } catch(e) {
    if (e && (e.name === 'QuotaExceededError' || e.code === 22 || e.code === 1014)) {
      alert('Storage full. Your browser\'s local storage is full.\n\nPlease export a backup (ORB Log → Export JSON) then clear some old data to free up space.');
    } else {
      alert('Save failed: ' + (e && e.message ? e.message : 'Unknown error'));
    }
  }
}
function saveTanks(d)   { _lsSave(STORE_TANKS,    d); }
function loadEntries()  { try { return JSON.parse(localStorage.getItem(STORE_ENTRIES))  || []; }  catch(e) { return []; } }
function saveEntries(d) { _lsSave(STORE_ENTRIES,  d); }
function loadSettings() { try { const s = JSON.parse(localStorage.getItem(STORE_SETTINGS)) || {}; if (s.ceName) delete s.ceName; return s; }  catch(e) { return {}; } }
function saveSettings(d){ _lsSave(STORE_SETTINGS, d); }
function loadCrew()      { try { return JSON.parse(localStorage.getItem(STORE_CREW))     || []; }  catch(e) { return []; } }
function saveCrewData(d) { _lsSave(STORE_CREW,     d); }

// Item E — equipment storage. Seeds two undeletable defaults on first read:
// OWS pump @ 3.0 m3/h and sludge transfer pump @ 5.0 m3/h. Users can edit
// rates and add custom pumps, but cannot delete the two builtins.
function loadEquipment() {
  let arr;
  try { arr = JSON.parse(localStorage.getItem(STORE_EQUIPMENT)) || null; } catch(e) { arr = null; }
  if (!arr || !arr.length) {
    arr = [
      { id: 'eq-ows-default',    name: 'OWS / 15ppm Overboard Pump', type: 'ows',         rate: 3.0, notes: '', builtin: true },
      { id: 'eq-bilge-default',  name: 'Bilge Transfer Pump',        type: 'bilge',       rate: 5.0, notes: '', builtin: true },
      { id: 'eq-sludge-default', name: 'Sludge Transfer Pump',       type: 'sludge',      rate: 5.0, notes: '', builtin: true },
      { id: 'eq-incin-default',  name: 'Sludge Incinerator',         type: 'incinerator', rate: 0.5, notes: '', builtin: true },
      { id: 'eq-boiler-default', name: 'Boiler (sludge burning)',    type: 'boiler',      rate: 0.5, notes: '', builtin: true }
    ];
    _lsSave(STORE_EQUIPMENT, arr);
  }
  return arr;
}
function saveEquipmentData(d) { _lsSave(STORE_EQUIPMENT, d); }

function uid() { return Date.now().toString(36) + Math.random().toString(36).slice(2,6); }
function now() { return new Date().toISOString(); }
function fmtDate(iso) {
  if (!iso) return '';
  const d = new Date(iso);
  const M = ['JAN','FEB','MAR','APR','MAY','JUN','JUL','AUG','SEP','OCT','NOV','DEC'];
  return String(d.getDate()).padStart(2,'0') + '-' + M[d.getMonth()] + '-' + d.getFullYear();
}
function fmtTime(iso) {
  if (!iso) return '';
  const d = new Date(iso);
  return String(d.getHours()).padStart(2,'0') + ':' + String(d.getMinutes()).padStart(2,'0');
}
function fmtDateInput() {
  const d = new Date();
  return d.toISOString().slice(0,10);
}
// Item C — master clock. If the user has set one, every wizard form defaults
// its Start/Stop time fields to that value. If not, fall back to wall time.
function fmtTimeInput() {
  const stored = (function(){ try { return localStorage.getItem('orb_masterTime') || ''; } catch(e){ return ''; } })();
  if (stored && /^\d{2}:\d{2}$/.test(stored)) return stored;
  const d = new Date();
  return String(d.getHours()).padStart(2,'0') + ':' + String(d.getMinutes()).padStart(2,'0');
}
function openMasterClockModal() {
  const cur = (function(){ try { return localStorage.getItem('orb_masterTime') || ''; } catch(e){ return ''; } })();
  const input = document.getElementById('master-clock-input');
  if (input) input.value = cur || fmtTimeInput();
  openModal('master-clock-modal');
}
function saveMasterClock() {
  const v = (document.getElementById('master-clock-input') || {}).value || '';
  if (!/^\d{2}:\d{2}$/.test(v)) { alert('Enter a valid time in HH:MM (24h) format.'); return; }
  try {
    localStorage.setItem('orb_masterTime', v);
    localStorage.setItem('orb_masterTimeEdited', 'true');
  } catch(e) {}
  closeModal('master-clock-modal');
  updateMasterClockDisplay();
}
function updateMasterClockDisplay() {
  const span = document.getElementById('master-clock-display');
  if (!span) return;
  const cur = (function(){ try { return localStorage.getItem('orb_masterTime') || ''; } catch(e){ return ''; } })();
  span.textContent = cur && /^\d{2}:\d{2}$/.test(cur) ? cur : fmtTimeInput();
}

// Item I — one-time changelog modal. Fires only when a CHANGELOG entry
// exists for the current APP_VERSION AND the user hasn't dismissed it yet.
function checkChangelogModal() {
  const entry = CHANGELOG.find(c => c.version === APP_VERSION);
  if (!entry) return; // silent on hotfixes without a changelog entry
  const seenKey = 'orb_seen_changelog_' + APP_VERSION;
  let seen = false;
  try { seen = !!localStorage.getItem(seenKey); } catch(e) {}
  if (seen) return;
  const body = document.getElementById('changelog-modal-body');
  if (!body) return;
  let html = `<div style="font-family:var(--sans);font-size:13px;color:var(--text2);">`;
  html += `<div style="font-weight:700;color:var(--amber);font-size:11px;letter-spacing:.1em;text-transform:uppercase;margin-bottom:4px;">v${esc(entry.version)} &mdash; ${esc(entry.date)}</div>`;
  html += `<div style="font-size:15px;color:var(--text);margin-bottom:12px;font-weight:600;">${esc(entry.title)}</div>`;
  html += `<ul style="margin:0 0 0 18px;padding:0;">`;
  entry.items.forEach(it => { html += `<li style="margin-bottom:6px;line-height:1.5;">${esc(it)}</li>`; });
  html += `</ul></div>`;
  body.innerHTML = html;
  openModal('changelog-modal');
}

function dismissChangelogModal() {
  try { localStorage.setItem('orb_seen_changelog_' + APP_VERSION, '1'); } catch(e) {}
  closeModal('changelog-modal');
}

