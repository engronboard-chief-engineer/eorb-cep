// Current wizard form data
let wiz = {};
let _formDirty = false;

function guardDirtyForm(proceed) {
  if (!_formDirty) { proceed(); return; }
  if (confirm('You have unsaved changes in the current form. Discard and continue?')) {
    _formDirty = false;
    proceed();
  }
}

function wizReset() {
  wiz = {};
  _activeOp = null;
  _formDirty = false;
  renderCatList();
  renderActList(_activeCat);
  document.getElementById('entry-form-content').innerHTML =
    '<div style="color:var(--text3);font-family:var(--sans);font-size:13px;padding-top:20px;">Select an activity to begin.</div>';
}

function buildWizForm(op) {
  const tanks  = getTanks();
  const sludgeTanks  = tanks.filter(t => ['sludge','waste','dirty','scav'].includes(t.type) && !t.isBilgeWell);
  const bilgeTanks   = tanks.filter(t => ['bilge','pumproom'].includes(t.type) && !t.isBilgeWell);
  const bilgeWells   = tanks.filter(t => t.isBilgeWell);
  const allTanks     = tanks.filter(t => !t.isBilgeWell);
  const fuelTanks    = tanks.filter(t => ['hfo','vlsfo','ulsfo','mdo','mgo','lsmgo','fo-settle','fo-service','do-service'].includes(t.type) && !t.isBilgeWell);
  const loTanks      = tanks.filter(t => ['lo','lo-settle','lo-service'].includes(t.type) && !t.isBilgeWell);
  const el = document.getElementById('wiz-form');

  // Operation date row (common). The previous separate TIME field was removed
  // (Issue 7) — the Master Clock chip at the top of the entry tab now supplies
  // the entry's "now" time, and forms with start/stop already carry their own
  // start/stop times. A small master-clock indicator is also rendered inside
  // the form so the value is visible without scrolling back to the header.
  const masterT = (function () {
    try { return localStorage.getItem('orb_masterTime') || ''; } catch (e) { return ''; }
  })() || fmtTimeInput();
  const dateHtml = `
    <div style="display:flex;gap:12px;align-items:flex-end;flex-wrap:wrap;margin-bottom:12px;">
      <div class="form-group" style="margin-bottom:0;">
        <label class="form-label">Entry Date</label>
        <input class="form-input" type="date" id="wf-date" value="${fmtDateInput()}" style="max-width:180px;">
      </div>
      <button type="button" class="master-clock-chip" onclick="openMasterClockModal()" title="Master clock (click to edit). Sets the default time for all entries." style="height:38px;">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><polyline points="12 7 12 12 15 14"/></svg>
        <span>Master ${esc(masterT)}</span>
      </button>
    </div>`;

  function tankOpts(arr) {
    return arr.map(t => `<option value="${t.id}">${esc(t.name)} [ROB: ${fmt2(t.rob)} ${t.unit}]</option>`).join('');
  }
  function allTankOpts() { return tankOpts(allTanks); }

  // -------- FORM BUILDERS BY OP --------
  let formHtml = '';

  if (op.id === 'C11-inv') {
    const invTanks = sludgeTanks.length ? sludgeTanks : allTanks;
    const s = loadSettings();
    const crew = loadCrew();
    const ceMember = crew.find(c => c.rank === 'Chief Engineer');
    const ceName = s.ceName || (ceMember ? ceMember.name : '');
    const hasCrew = crew.filter(c => c.rank !== 'Chief Engineer').length > 0;
    const tankRows = invTanks.map((t, i) => `
      <tr style="border-bottom:1px solid var(--border);">
        <td style="padding:8px 10px;font-family:var(--mono);font-size:12px;color:var(--text);word-break:break-word;">
          ${esc(t.name)}
        </td>
        <td style="padding:8px 10px;text-align:right;">
          <span style="font-family:var(--mono);font-size:12px;color:var(--text3);">${fmt3(t.rob)} m3</span>
        </td>
        <td style="padding:6px 10px;">
          <input class="form-input" type="number" id="wf-inv-rob-${i}" data-tankid="${esc(t.id)}" data-cap="${t.capacity}" data-prevrob="${t.rob}"
            min="0" step="0.001" placeholder="${fmt3(t.rob)}"
            style="width:100%;padding:5px 8px;font-size:12px;box-sizing:border-box;">
        </td>
        <td style="padding:8px 10px;text-align:right;">
          <span style="font-family:var(--mono);font-size:12px;color:var(--text3);">${fmt3(t.capacity)} m3</span>
        </td>
        <td style="padding:6px 10px;" colspan="2">
          <select class="form-select" id="wf-inv-officer-${i}" data-mode="crew"
            style="padding:5px 8px;font-size:12px;width:100%;"
            onchange="syncInvOfficerRank(${i})">
            ${crewOptsForRank('')}
          </select>
        </td>
      </tr>`).join('');
    formHtml = `
      ${dateHtml}
      <div class="form-group" style="margin-bottom:6px;">
        <div style="font-family:var(--sans);font-size:11px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--text2);margin-bottom:8px;">All Sludge / Waste Oil Tanks (Item 11)</div>
        <div style="background:var(--bg3);border:1px solid var(--border);border-radius:var(--radius-sm);overflow:hidden;">
          <table style="width:100%;border-collapse:collapse;table-layout:fixed;">
            <thead>
              <tr style="border-bottom:1px solid var(--border);">
                <th style="padding:7px 10px;text-align:left;font-family:var(--sans);font-size:10px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--text3);width:35%;">Tank Name</th>
                <th style="padding:7px 10px;text-align:right;font-family:var(--sans);font-size:10px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--text3);width:15%;">Current ROB</th>
                <th style="padding:7px 10px;font-family:var(--sans);font-size:10px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--blue);width:15%;">New ROB (m3)</th>
                <th style="padding:7px 10px;font-family:var(--sans);font-size:10px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--text3);width:14%;">Capacity (m3)</th>
                <th style="padding:7px 10px;font-family:var(--sans);font-size:10px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--amber);width:21%;" colspan="2">Officer-in-Charge</th>
              </tr>
            </thead>
            <tbody id="wf-inv-rows">
              ${tankRows}
            </tbody>
          </table>
        </div>
        <div style="font-size:11px;color:var(--text3);margin-top:5px;font-family:var(--sans);">Current ROB is shown for guidance only. Enter measured ROB in the blue column. Leave blank to keep current value. Officer names come from the <a href="#" onclick="switchTab('crew');return false;" style="color:var(--blue);">Crew Roster</a>.</div>
      </div>
      <div class="form-group" style="max-width:400px;">
        <label class="form-label">Chief Engineer Name <span style="color:var(--text3);font-weight:400;">(signed once, applied to all tanks)</span></label>
        <input class="form-input" id="wf-inv-ce-name" placeholder="From Crew tab" value="${esc(ceName)}">
        <div style="font-size:11px;color:var(--text3);margin-top:4px;">Update default in Vessel Settings.</div>
      </div>
      <div class="form-group" style="max-width:500px;">
        <label class="form-label">Remarks (optional)</label>
        <input class="form-input" id="wf-remarks">
      </div>`;
  }

  else if (op.id === 'C11-coll') {
    formHtml = `
      ${dateHtml}
      <div class="form-group" style="max-width:400px;">
        <label class="form-label">Sludge Tank</label>
        <select class="form-select" id="wf-src" onchange="updateTankRobChip('wf-src')">${tankOpts(sludgeTanks.length ? sludgeTanks : allTanks)}</select>
        ${robChipDiv('wf-src')}
      </div>
      <div class="form-row" style="max-width:500px;">
        <div class="form-group">
          <label class="form-label">Current Capacity (m3)</label>
          <input class="form-input" type="number" id="wf-cap" min="0" step="0.01" readonly tabindex="-1">
        </div>
        <div class="form-group">
          <label class="form-label">Quantity Retained (m3)</label>
          <input class="form-input" type="number" id="wf-qty" min="0" step="0.01" placeholder="ROB">
        </div>
      </div>
      <div class="form-group" style="max-width:400px;">
        <label class="form-label">Quantity Collected From</label>
        <input class="form-input" id="wf-src2" placeholder="e.g. FO separator drain tank">
      </div>
      <div class="form-group" style="max-width:200px;">
        <label class="form-label">Collected Quantity (m3)</label>
        <input class="form-input" type="number" id="wf-qty2" min="0" step="0.01">
      </div>
      <div class="form-group" style="max-width:500px;">
        <label class="form-label">Remarks (optional)</label>
        <input class="form-input" id="wf-remarks">
      </div>`;
  }

  else if (['C12-shore','C12-xfer','C12-incin','C12-boil','C12-evap','C12-regen'].includes(op.id)) {
    formHtml = `
      ${dateHtml}
      <div class="form-group" style="max-width:400px;">
        <label class="form-label">Source Sludge Tank</label>
        <select class="form-select" id="wf-src" onchange="updateTankRobChip('wf-src')">${tankOpts(sludgeTanks.length ? sludgeTanks : allTanks)}</select>
        ${robChipDiv('wf-src')}
      </div>
      <div class="form-group" style="max-width:220px;">
        <label class="form-label">Source Capacity (m3)</label>
        <input class="form-input" type="number" id="wf-cap" min="0" step="0.001" readonly tabindex="-1">
      </div>
      <div class="form-row" style="max-width:500px;">
        <div class="form-group">
          <label class="form-label">Quantity Disposed / Transferred (m3)</label>
          <input class="form-input" type="number" id="wf-qty" min="0" step="0.01" onchange="validateTransferQtyLive()">
          <div class="wf-err" id="err-wf-qty"></div>
        </div>
        <div class="form-group">
          <label class="form-label">Quantity Retained After (m3)</label>
          <input class="form-input" type="number" id="wf-qty-ret" min="0" step="0.01" onchange="validateRetainedLive()">
          <div class="form-hint">Leave blank to auto-calculate from ROB</div>
          <div class="wf-err" id="err-wf-qty-ret"></div>
        </div>
      </div>
      ${op.id==='C12-shore'?`
        <div class="form-group" style="max-width:400px;">
          <label class="form-label">Receiver (barge / truck / shore facility)</label>
          <input class="form-input" id="wf-receiver" placeholder="Identity or name of receiver">
        </div>
        <div class="form-group" style="max-width:300px;">
          <label class="form-label">Port Name</label>
          <input class="form-input" id="wf-port" placeholder="Port name">
        </div>`:''}
      ${op.id==='C12-xfer'?`
        <div class="form-group" style="max-width:400px;">
          <label class="form-label">Destination Tank</label>
          <select class="form-select" id="wf-dest" onchange="updateTankRobChip('wf-dest');validateDestCapacityLive()">${tankOpts(sludgeTanks.length ? sludgeTanks : allTanks)}</select>
          ${robChipDiv('wf-dest')}
          <div class="wf-err" id="err-wf-dest"></div>
        </div>`:''}
      ${op.id==='C12-incin'?`
        <div class="form-group" style="max-width:300px;">
          <label class="form-label">Incineration Duration (hours)</label>
          <input class="form-input" type="number" id="wf-hours" min="0" step="0.1" placeholder="e.g. 2.5">
        </div>`:''}
      ${op.id==='C12-boil'?`
        <div class="form-group" style="max-width:300px;">
          <label class="form-label">Boiler Burn Duration (hours)</label>
          <input class="form-input" type="number" id="wf-hours" min="0" step="0.1">
        </div>`:''}
      ${op.id==='C12-regen'?`
        <div class="form-row" style="max-width:500px;">
          <div class="form-group">
            <label class="form-label">Fuel Regenerated (m3) to</label>
            <input class="form-input" id="wf-regen-fuel" placeholder="Fuel tank name">
          </div>
          <div class="form-group">
            <label class="form-label">Water Recovered (m3) to</label>
            <input class="form-input" id="wf-regen-water" placeholder="Bilge tank name">
          </div>
        </div>`:''}
      <div class="form-group" style="max-width:500px;">
        <label class="form-label">Remarks (optional)</label>
        <input class="form-input" id="wf-remarks">
      </div>`;
  }

  else if (op.id === 'D-tank') {
    const destOpts = tankOpts(bilgeTanks.length ? bilgeTanks : allTanks);
    wiz.bilgeWellInputs = wiz.bilgeWellInputs || (bilgeWells.length ? bilgeWells.map(w => ({ tankId: w.id, vol: '' })) : [{ tankId: '', vol: '' }]);
    formHtml = `
      ${dateHtml}
      <div class="form-row" style="max-width:720px;">
        <div class="form-group">
          <label class="form-label">Start Date</label>
          <input class="form-input" type="date" id="wf-start-date" value="${fmtDateInput()}" oninput="validateTimePair()" onchange="validateTimePair()">
        </div>
        <div class="form-group">
          <label class="form-label">Start Time</label>
          <input class="form-input" type="time" id="wf-start" value="${fmtTimeInput()}" oninput="validateTimePair()" onchange="validateTimePair()">
        </div>
        <div class="form-group">
          <label class="form-label">Stop Date</label>
          <input class="form-input" type="date" id="wf-stop-date" value="${fmtDateInput()}" oninput="validateTimePair()" onchange="validateTimePair()">
        </div>
        <div class="form-group">
          <label class="form-label">Stop Time</label>
          <input class="form-input" type="time" id="wf-stop" oninput="validateTimePair()" onblur="validateTimePair()">
          <div class="wf-err" id="err-wf-stop"></div>
        </div>
      </div>
      <div class="form-group" style="max-width:640px;">
        <label class="form-label">Source — Engine Room Bilge Wells</label>
        <div id="wf-bilge-wells-list"></div>
        <button class="btn btn-secondary btn-sm" type="button" onclick="addBilgeWellRow()" style="margin-top:8px;">+ Add Bilge Well</button>
      </div>
      <div style="max-width:500px;background:var(--bg3);border:1px solid var(--border);border-radius:2px;padding:10px 14px;margin-bottom:16px;font-family:var(--mono);font-size:13px;">
        <span style="color:var(--text3);font-size:11px;font-family:var(--sans);font-weight:600;letter-spacing:0.1em;text-transform:uppercase;">Total Volume Transferred</span><br>
        <span id="wf-total-vol" style="color:var(--amber);font-size:16px;font-weight:bold;">0.00 m3</span>
        <input type="hidden" id="wf-qty" value="0">
        <div class="wf-err" id="err-wf-bilge-total" style="margin-top:6px;"></div>
      </div>
      <div class="form-group" style="max-width:400px;">
        <label class="form-label">Destination — Bilge Holding Tank (Section 3.3)</label>
        <select class="form-select" id="wf-dest" onchange="updateBilgeTankPreview();validateBilgeTotalLive()">${destOpts}</select>
        <div class="wf-err" id="err-wf-dest"></div>
      </div>
      <div id="wf-bilge-tank-preview" style="max-width:500px;background:var(--bg3);border:1px solid var(--border);border-radius:2px;padding:10px 14px;margin-bottom:16px;font-family:var(--mono);font-size:12px;display:none;">
        <span style="color:var(--text3);font-size:11px;font-family:var(--sans);font-weight:600;letter-spacing:0.1em;text-transform:uppercase;">Bilge Holding Tank</span><br>
        <span id="wf-bht-before" style="color:var(--text2);"></span>
        <span style="color:var(--amber);margin:0 6px;">&#8594;</span>
        <span id="wf-bht-after" style="color:var(--green);"></span>
      </div>
      <div class="form-row" style="max-width:600px;">
        <div class="form-group">
          <label class="form-label">Bilge Transfer Pump Name</label>
          <input class="form-input" id="wf-bilge-pump-name" placeholder="${(()=>{ const eq=loadEquipment().find(e=>e.type==='bilge'); return eq?eq.name:'Bilge Transfer Pump'; })()}">
          <div style="font-size:11px;color:var(--text3);margin-top:3px;">Editable. Set rated capacity in Equipment tab.</div>
        </div>
        <div class="form-group" style="max-width:160px;">
          <label class="form-label">Duration (hours)</label>
          <input class="form-input" type="number" id="wf-hours" min="0" step="0.1" placeholder="e.g. 2.5">
          <div style="font-size:11px;color:var(--text3);margin-top:3px;">Used to check pump rate.</div>
        </div>
      </div>
      <div class="form-group" style="max-width:500px;">
        <label class="form-label">Remarks (optional)</label>
        <input class="form-input" id="wf-remarks">
      </div>`;
  }

  else if (['D-ows','D-sludge','D-slop'].includes(op.id)) {
    const srcOpts = bilgeTanks.length ? tankOpts(bilgeTanks) + (bilgeWells.length ? '<optgroup label="Bilge Wells">' + tankOpts(bilgeWells) + '</optgroup>' : '') : tankOpts(bilgeWells);
    const destOpts = op.id==='D-sludge' ? tankOpts(sludgeTanks.length?sludgeTanks:allTanks) : tankOpts(bilgeTanks.length?bilgeTanks:allTanks);
    formHtml = `
      ${dateHtml}
      <div class="form-row" style="max-width:720px;">
        <div class="form-group">
          <label class="form-label">Start Date</label>
          <input class="form-input" type="date" id="wf-start-date" value="${fmtDateInput()}" oninput="validateTimePair()" onchange="validateTimePair()">
        </div>
        <div class="form-group">
          <label class="form-label">Start Time</label>
          <input class="form-input" type="time" id="wf-start" value="${fmtTimeInput()}" oninput="validateTimePair()" onchange="validateTimePair()">
        </div>
        <div class="form-group">
          <label class="form-label">Stop Date</label>
          <input class="form-input" type="date" id="wf-stop-date" value="${fmtDateInput()}" oninput="validateTimePair()" onchange="validateTimePair()">
        </div>
        <div class="form-group">
          <label class="form-label">Stop Time</label>
          <input class="form-input" type="time" id="wf-stop" oninput="validateTimePair()" onblur="validateTimePair()">
          <div class="wf-err" id="err-wf-stop"></div>
        </div>
      </div>
      <div class="form-group" style="max-width:400px;">
        <label class="form-label">Source (bilge well or holding tank)</label>
        <select class="form-select" id="wf-src" onchange="updateTankRobChip('wf-src');validateTransferQtyLive()">${srcOpts}</select>
        ${robChipDiv('wf-src')}
      </div>
      <div class="form-row" style="max-width:500px;">
        <div class="form-group">
          <label class="form-label">Quantity (m3)</label>
          <input class="form-input" type="number" id="wf-qty" min="0" step="0.01" onchange="validateTransferQtyLive()">
          <div class="wf-err" id="err-wf-qty"></div>
        </div>
        <div class="form-group">
          <label class="form-label">Source Capacity (m3)</label>
          <input class="form-input" type="number" id="wf-cap" min="0" step="0.001" readonly tabindex="-1">
        </div>
      </div>
      ${op.id==='D-ows'?`
        <div class="form-group" style="max-width:680px;">
          <label class="form-label">Position at Start</label>
          <div class="pos-row">
            <div><div class="pos-label">Deg</div><input class="form-input" id="wf-pos-start-latd" placeholder="45" type="number" min="0" max="90" step="any"></div>
            <div><div class="pos-label">Min</div><input class="form-input" id="wf-pos-start-latm" placeholder="35.2" type="number" min="0" max="59.9999" step="any"></div>
            <div><div class="pos-label">N/S</div><select class="form-select" id="wf-pos-start-ns"><option>N</option><option>S</option></select></div>
          </div>
          <div class="pos-row" style="margin-top:8px;">
            <div><div class="pos-label">Deg</div><input class="form-input" id="wf-pos-start-lond" placeholder="34" type="number" min="0" max="180" step="any"></div>
            <div><div class="pos-label">Min</div><input class="form-input" id="wf-pos-start-lonm" placeholder="45.2" type="number" min="0" max="59.9999" step="any"></div>
            <div><div class="pos-label">E/W</div><select class="form-select" id="wf-pos-start-ew"><option>E</option><option>W</option></select></div>
          </div>
        </div>
        <div class="form-group" style="max-width:680px;">
          <label class="form-label">Position at Stop</label>
          <div class="pos-row">
            <div><div class="pos-label">Deg</div><input class="form-input" id="wf-pos-stop-latd" placeholder="45" type="number" min="0" max="90" step="any"></div>
            <div><div class="pos-label">Min</div><input class="form-input" id="wf-pos-stop-latm" placeholder="35.2" type="number" min="0" max="59.9999" step="any"></div>
            <div><div class="pos-label">N/S</div><select class="form-select" id="wf-pos-stop-ns"><option>N</option><option>S</option></select></div>
          </div>
          <div class="pos-row" style="margin-top:8px;">
            <div><div class="pos-label">Deg</div><input class="form-input" id="wf-pos-stop-lond" placeholder="34" type="number" min="0" max="180" step="any"></div>
            <div><div class="pos-label">Min</div><input class="form-input" id="wf-pos-stop-lonm" placeholder="45.2" type="number" min="0" max="59.9999" step="any"></div>
            <div><div class="pos-label">E/W</div><select class="form-select" id="wf-pos-stop-ew"><option>E</option><option>W</option></select></div>
          </div>
        </div>`:''}
      ${(op.id!=='D-ows')?`
        <div class="form-group" style="max-width:400px;">
          <label class="form-label">Destination Tank</label>
          <select class="form-select" id="wf-dest" onchange="updateTankRobChip('wf-dest');validateDestCapacityLive()">${op.id==='D-slop'?tankOpts(allTanks):destOpts}</select>
          ${robChipDiv('wf-dest')}
          <div class="wf-err" id="err-wf-dest"></div>
        </div>`:''}
      <div class="form-group" style="max-width:500px;">
        <label class="form-label">Remarks (optional)</label>
        <input class="form-input" id="wf-remarks">
      </div>`;
  }

  else if (['E-ows','E-tank'].includes(op.id)) {
    formHtml = `
      ${dateHtml}
      <div class="form-group" style="max-width:400px;">
        <label class="form-label">Source Tank</label>
        <select class="form-select" id="wf-src" onchange="updateTankRobChip('wf-src');validateTransferQtyLive()">${bilgeWells.length?tankOpts(bilgeWells)+tankOpts(bilgeTanks):tankOpts(allTanks)}</select>
        ${robChipDiv('wf-src')}
      </div>
      <div class="form-row" style="max-width:680px;">
        <div class="form-group">
          <label class="form-label">Pump Start Time</label>
          <input class="form-input" type="time" id="wf-start" value="${fmtTimeInput()}" oninput="validateTimePair()" onchange="validateTimePair()">
        </div>
        <div class="form-group">
          <label class="form-label">Stop Time</label>
          <input class="form-input" type="time" id="wf-stop" oninput="validateTimePair()" onblur="validateTimePair()">
          <div class="wf-err" id="err-wf-stop"></div>
        </div>
      </div>
      ${op.id==='E-ows'?`
        <div class="form-group" style="max-width:680px;">
          <label class="form-label">Position at Start (auto-start)</label>
          <div class="pos-row">
            <div><div class="pos-label">Deg</div><input class="form-input" id="wf-pos-start-latd" placeholder="45" type="number" min="0" max="90" step="any"></div>
            <div><div class="pos-label">Min</div><input class="form-input" id="wf-pos-start-latm" placeholder="35.2" type="number" min="0" max="59.9999" step="any"></div>
            <div><div class="pos-label">N/S</div><select class="form-select" id="wf-pos-start-ns"><option>N</option><option>S</option></select></div>
          </div>
          <div class="pos-row" style="margin-top:8px;">
            <div><div class="pos-label">Deg</div><input class="form-input" id="wf-pos-start-lond" placeholder="34" type="number" min="0" max="180" step="any"></div>
            <div><div class="pos-label">Min</div><input class="form-input" id="wf-pos-start-lonm" placeholder="45.2" type="number" min="0" max="59.9999" step="any"></div>
            <div><div class="pos-label">E/W</div><select class="form-select" id="wf-pos-start-ew"><option>E</option><option>W</option></select></div>
          </div>
        </div>`:''}
      ${op.id==='E-tank'?`
        <div class="form-group" style="max-width:400px;">
          <label class="form-label">Destination Tank</label>
          <select class="form-select" id="wf-dest" onchange="updateTankRobChip('wf-dest');validateDestCapacityLive()">${tankOpts(bilgeTanks.length?bilgeTanks:allTanks)}</select>
          ${robChipDiv('wf-dest')}
          <div class="wf-err" id="err-wf-dest"></div>
        </div>`:''}
      <div class="form-group" style="max-width:400px;">
        <label class="form-label">Quantity (m3)</label>
        <input class="form-input" type="number" id="wf-qty" min="0" step="0.01" onchange="validateTransferQtyLive()">
        <div class="wf-err" id="err-wf-qty"></div>
      </div>
      <div class="form-group" style="max-width:500px;">
        <label class="form-label">Remarks (optional)</label>
        <input class="form-input" id="wf-remarks">
      </div>`;
  }

  else if (['F-fail','F-rest'].includes(op.id)) {
    formHtml = `
      <div style="background:rgba(220,53,69,0.08);border:1px solid rgba(220,53,69,0.45);border-radius:6px;padding:12px 16px;margin-bottom:16px;font-size:13px;color:#c0392b;line-height:1.6;">
        <strong>MEPC.1/Circ.736 Requirement:</strong> You must also record a Code I entry —
        <ul style="margin:6px 0 0 18px;padding:0;">
          <li>When logging a <strong>failure</strong>: record <strong>I-seal</strong> (overboard valve sealed shut).</li>
          <li>When logging a <strong>restoration</strong>: record <strong>I-unseal</strong> (overboard valve unsealed).</li>
        </ul>
      </div>
      ${dateHtml}
      <div class="form-row" style="max-width:500px;">
        <div class="form-group">
          <label class="form-label">Failure Time (Item 19)</label>
          <input class="form-input" type="time" id="wf-start" value="${fmtTimeInput()}">
        </div>
        <div class="form-group">
          <label class="form-label">Restored Time (Item 20) — if known</label>
          <input class="form-input" type="time" id="wf-stop">
        </div>
      </div>
      <div class="form-group" style="max-width:500px;">
        <label class="form-label">Reason for Failure (Item 21)</label>
        <input class="form-input" id="wf-reason" placeholder="e.g. OCM sensor failure, OWS membrane blocked">
      </div>
      <div class="form-group" style="max-width:500px;">
        <label class="form-label">Equipment Description</label>
        <input class="form-input" id="wf-equip" placeholder="e.g. 15 ppm Oily Water Separator">
      </div>
      <div class="form-group" style="max-width:500px;">
        <label class="form-label">Remarks (optional)</label>
        <input class="form-input" id="wf-remarks">
      </div>`;
  }

  else if (op.id === 'G-acc') {
    formHtml = `
      ${dateHtml}
      <div class="form-group" style="max-width:300px;">
        <label class="form-label">Time of Discovery (Item 22)</label>
        <input class="form-input" type="time" id="wf-start" value="${fmtTimeInput()}">
      </div>
      <div class="form-group" style="max-width:680px;">
        <label class="form-label">Position (Item 23)</label>
        <div class="pos-row">
          <div><div class="pos-label">Deg</div><input class="form-input" id="wf-pos-start-latd" placeholder="45" type="number" min="0" max="90" step="any"></div>
          <div><div class="pos-label">Min</div><input class="form-input" id="wf-pos-start-latm" placeholder="35.2" type="number" min="0" max="59.9999" step="any"></div>
          <div><div class="pos-label">N/S</div><select class="form-select" id="wf-pos-start-ns"><option>N</option><option>S</option></select></div>
        </div>
        <div class="pos-row" style="margin-top:8px;">
          <div><div class="pos-label">Deg</div><input class="form-input" id="wf-pos-start-lond" placeholder="34" type="number" min="0" max="180" step="any"></div>
          <div><div class="pos-label">Min</div><input class="form-input" id="wf-pos-start-lonm" placeholder="45.2" type="number" min="0" max="59.9999" step="any"></div>
          <div><div class="pos-label">E/W</div><select class="form-select" id="wf-pos-start-ew"><option>E</option><option>W</option></select></div>
        </div>
      </div>
      <div class="form-row" style="max-width:680px;">
        <div class="form-group">
          <label class="form-label">Type of Oily Residue (Item 24)</label>
          <input class="form-input" id="wf-reason" placeholder="e.g. HFO, bilge water, lube oil">
        </div>
        <div class="form-group">
          <label class="form-label">Estimated Quantity</label>
          <input class="form-input" type="number" id="wf-qty" min="0" step="0.01" placeholder="m3">
        </div>
      </div>
      <div class="form-group" style="max-width:680px;">
        <label class="form-label">Circumstances of Discharge (Item 25)</label>
        <textarea class="form-textarea" id="wf-remarks" placeholder="e.g. Fuel tank overflow during bunkering. Pump failed to auto-stop."></textarea>
      </div>`;
  }

  else if (op.id.startsWith('H-')) {
    const grade = { 'H-hfo':'HFO','H-vlsfo':'VLSFO','H-ulsfo':'ULSFO','H-mdo':'MDO','H-mgo':'MGO','H-lsmgo':'LSMGO','H-lube':'Bulk Lube Oil' }[op.id];
    const isLube = op.id === 'H-lube';
    formHtml = `
      ${dateHtml}
      <div class="form-group" style="max-width:400px;">
        <label class="form-label">Port Name (Item 26.1)</label>
        <input class="form-input" id="wf-port" placeholder="e.g. Manila, Philippines">
      </div>
      <div class="form-row" style="max-width:680px;">
        <div class="form-group">
          <label class="form-label">Bunkering Start (Item 26.2)</label>
          <input class="form-input" type="datetime-local" id="wf-start">
        </div>
        <div class="form-group">
          <label class="form-label">Bunkering Stop (Item 26.2)</label>
          <input class="form-input" type="datetime-local" id="wf-stop">
        </div>
      </div>
      <div class="form-group" style="max-width:400px;">
        <label class="form-label">Grade</label>
        <input class="form-input" id="wf-grade" value="${grade}" readonly>
      </div>
      ${!isLube?`
      <div class="form-row" style="max-width:680px;">
        <div class="form-group">
          <label class="form-label">ISO Specification</label>
          <input class="form-input" id="wf-iso" placeholder="e.g. ISO-RMG-380">
        </div>
        <div class="form-group">
          <label class="form-label">Sulphur Content (%)</label>
          <input class="form-input" type="number" id="wf-sulphur" min="0" max="5" step="0.01" placeholder="e.g. 0.50">
        </div>
      </div>`:''}
      <div class="form-group" style="max-width:300px;">
        <label class="form-label">Total Quantity Bunkered (MT)</label>
        <input class="form-input" type="number" id="wf-qty" min="0" step="0.1">
      </div>
      <div style="font-family:var(--sans);font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--text3);margin-bottom:8px;">Tanks Receiving</div>
      <div id="wf-bunk-tanks"></div>
      <button class="btn btn-secondary btn-sm" onclick="addBunkTank()" style="margin-bottom:16px;">+ Add Tank</button>
      <div class="form-group" style="max-width:500px;">
        <label class="form-label">Remarks (optional)</label>
        <input class="form-input" id="wf-remarks">
      </div>`;
  }

  else if (op.id === 'I-cargo') {
    formHtml = `
      ${dateHtml}
      <div class="form-group" style="max-width:500px;">
        <label class="form-label">Quantity (m3)</label>
        <input class="form-input" type="number" id="wf-qty" min="0" step="0.01">
      </div>
      <div class="form-group" style="max-width:400px;">
        <label class="form-label">Destination Holding Tank</label>
        <select class="form-select" id="wf-dest">${tankOpts(bilgeTanks.length?bilgeTanks:allTanks)}</select>
      </div>
      <div class="form-group" style="max-width:500px;">
        <label class="form-label">Remarks (optional)</label>
        <input class="form-input" id="wf-remarks">
      </div>`;
  }

  else if (op.id === 'I-missed') {
    // Build grouped op options (exclude I-missed itself)
    const missedGroups = {};
    OPERATIONS.filter(o => o.id !== 'I-missed').forEach(o => {
      if (!missedGroups[o.group]) missedGroups[o.group] = [];
      missedGroups[o.group].push(o);
    });
    const missedOptsHtml = Object.keys(missedGroups).map(g =>
      `<optgroup label="${esc(g)}">${missedGroups[g].map(o => `<option value="${o.id}">${esc(o.label)}</option>`).join('')}</optgroup>`
    ).join('');
    formHtml = `
      <div style="max-width:680px;background:var(--amber-dim);border:1px solid rgba(246,173,85,0.3);border-radius:var(--radius-sm);padding:10px 14px;margin-bottom:16px;font-family:var(--sans);font-size:12px;color:var(--amber2);">
        <strong>Code I — Missed Entry:</strong> Date (1) = original operation date. Date (2) = today (entry date). The ORB will show Code I on Date 2, then the actual operation on Date 1.
      </div>
      <div class="form-row" style="max-width:680px;">
        <div class="form-group">
          <label class="form-label">Date (1) — Original Operation Date</label>
          <input class="form-input" type="date" id="wf-orig-date">
        </div>
        <div class="form-group">
          <label class="form-label">Date (2) — Current Entry Date</label>
          <input class="form-input" type="date" id="wf-date" value="${fmtDateInput()}">
        </div>
      </div>
      <div class="form-group" style="max-width:680px;">
        <label class="form-label">Missed Operation Type</label>
        <select class="form-select" id="wf-missed-op" onchange="buildMissedSubForm(this.value)">
          <option value="">-- Select the operation that was missed --</option>
          ${missedOptsHtml}
        </select>
      </div>
      <div id="missed-sub-form" style="margin-top:4px;"></div>`;
  }

  else if (op.id === 'I-debunk') {
    formHtml = `
      ${dateHtml}
      <div class="form-group" style="max-width:400px;">
        <label class="form-label">Source Tank</label>
        <select class="form-select" id="wf-src" onchange="updateTankRobChip('wf-src')">${tankOpts(fuelTanks.length?fuelTanks:allTanks)}</select>
        ${robChipDiv('wf-src')}
      </div>
      <div class="form-group" style="max-width:220px;">
        <label class="form-label">Source Capacity (MT)</label>
        <input class="form-input" type="number" id="wf-cap" min="0" step="0.001" readonly tabindex="-1">
      </div>
      <div class="form-row" style="max-width:680px;">
        <div class="form-group">
          <label class="form-label">Quantity De-bunkered (MT)</label>
          <input class="form-input" type="number" id="wf-qty" min="0" step="0.1">
        </div>
        <div class="form-group">
          <label class="form-label">Quantity Retained After (MT)</label>
          <input class="form-input" type="number" id="wf-qty-ret" min="0" step="0.1">
        </div>
      </div>
      <div class="form-row" style="max-width:680px;">
        <div class="form-group">
          <label class="form-label">Grade & ISO Spec</label>
          <input class="form-input" id="wf-iso" placeholder="e.g. ISO-RMG-380 HFO 0.50%S">
        </div>
        <div class="form-group">
          <label class="form-label">Receiver</label>
          <input class="form-input" id="wf-receiver" placeholder="Name of barge / truck / shore">
        </div>
      </div>
      <div class="form-group" style="max-width:300px;">
        <label class="form-label">Port</label>
        <input class="form-input" id="wf-port" placeholder="Port name">
      </div>
      <div class="form-row" style="max-width:680px;">
        <div class="form-group">
          <label class="form-label">Start</label>
          <input class="form-input" type="datetime-local" id="wf-start">
        </div>
        <div class="form-group">
          <label class="form-label">Stop</label>
          <input class="form-input" type="datetime-local" id="wf-stop">
        </div>
      </div>
      <div class="form-group" style="max-width:500px;">
        <label class="form-label">Remarks (optional)</label>
        <input class="form-input" id="wf-remarks">
      </div>`;
  }

  else if (op.id === 'I-seal' || op.id === 'I-unseal') {
    const isUnseal = op.id === 'I-unseal';
    formHtml = `
      ${dateHtml}
      <div class="form-group" style="max-width:400px;">
        <label class="form-label">Valve Number / Description</label>
        <input class="form-input" id="wf-valve" placeholder="e.g. OWS Overboard Valve V-101">
      </div>
      <div class="form-group" style="max-width:300px;">
        <label class="form-label">Seal Number</label>
        <input class="form-input" id="wf-seal" placeholder="e.g. 2026-0514-001">
      </div>
      ${isUnseal?`<div class="form-group" style="max-width:400px;">
        <label class="form-label">Reason for Unsealing</label>
        <input class="form-input" id="wf-reason" placeholder="e.g. For normal operation of 15 ppm unit">
      </div>`:''}
      <div class="form-group" style="max-width:500px;">
        <label class="form-label">Remarks (optional)</label>
        <input class="form-input" id="wf-remarks">
      </div>`;
  }

  else if (op.id === 'I-inv') {
    const firstBilge = bilgeTanks.length ? bilgeTanks[0] : (allTanks[0] || null);
    formHtml = `
      ${dateHtml}
      <div class="form-group" style="max-width:400px;">
        <label class="form-label">Bilge Holding Tank (Section 3.3)</label>
        <select class="form-select" id="wf-src" onchange="updateBilgeInvCapDisplay()">${tankOpts(bilgeTanks.length?bilgeTanks:allTanks)}</select>
      </div>
      <div class="form-row" style="max-width:500px;">
        <div class="form-group">
          <label class="form-label">Capacity (m3)</label>
          <div id="bilge-inv-cap-display" style="font-family:var(--mono);font-size:14px;color:var(--text3);padding:9px 12px;background:var(--bg3);border:1px solid var(--border);border-radius:var(--radius-sm);">${firstBilge ? fmt3(firstBilge.capacity) : '—'}</div>
        </div>
        <div class="form-group">
          <label class="form-label">Quantity Retained (m3)</label>
          <input class="form-input" type="number" id="wf-qty" min="0" step="0.001">
        </div>
      </div>
      <div class="form-group" style="max-width:500px;">
        <label class="form-label">Remarks (optional)</label>
        <input class="form-input" id="wf-remarks">
      </div>`;
  }

  else if (op.id === 'I-owstest') {
    formHtml = `
      ${dateHtml}
      <div class="form-group" style="max-width:500px;">
        <label class="form-label">Equipment Tested</label>
        <input class="form-input" id="wf-equip" value="15 ppm Oily Water Separator (OWS)" placeholder="e.g. 15 ppm Oily Water Separator (OWS)">
      </div>
      <div class="form-group" style="max-width:300px;">
        <label class="form-label">Recirculation Test Duration (minutes)</label>
        <input class="form-input" type="number" id="wf-duration" min="0" step="1" placeholder="e.g. 15">
      </div>
      <div class="form-group" style="max-width:500px;">
        <label class="form-label">Remarks (optional)</label>
        <input class="form-input" id="wf-remarks" placeholder="e.g. 15 PPM alarm activated at 14 ppm, 3-way valve operated correctly">
      </div>`;
  }

  else if (op.id === 'I-bunksample') {
    formHtml = `
      ${dateHtml}
      <div class="form-group" style="max-width:400px;">
        <label class="form-label">Fuel Grade</label>
        <input class="form-input" id="wf-grade" placeholder="e.g. HFO, LSMGO">
      </div>
      <div class="form-group" style="max-width:300px;">
        <label class="form-label">BDN / Sample Reference No.</label>
        <input class="form-input" id="wf-seal" placeholder="e.g. BDN-2025-001">
      </div>
      <div class="form-group" style="max-width:400px;">
        <label class="form-label">Disposal Method</label>
        <select class="form-select" id="wf-reason">
          <option value="disposed to sludge tank">Disposed to sludge tank</option>
          <option value="disposed to waste oil tank">Disposed to waste oil tank</option>
          <option value="landed ashore">Landed ashore</option>
        </select>
      </div>
      <div class="form-group" style="max-width:200px;">
        <label class="form-label">Quantity (liters)</label>
        <input class="form-input" type="number" id="wf-qty" min="0" step="0.1" placeholder="e.g. 4.0">
      </div>
      <div class="form-group" style="max-width:500px;">
        <label class="form-label">Remarks (optional)</label>
        <input class="form-input" id="wf-remarks">
      </div>`;
  }

  else if (op.id === 'I-bilgshore') {
    formHtml = `
      ${dateHtml}
      <div class="form-group" style="max-width:400px;">
        <label class="form-label">Source Tank</label>
        <select class="form-select" id="wf-src" onchange="updateTankRobChip('wf-src')">${tankOpts(bilgeTanks.length?bilgeTanks:allTanks)}</select>
        ${robChipDiv('wf-src')}
      </div>
      <div class="form-group" style="max-width:220px;">
        <label class="form-label">Source Capacity (m3)</label>
        <input class="form-input" type="number" id="wf-cap" min="0" step="0.01" readonly tabindex="-1">
      </div>
      <div class="form-row" style="max-width:500px;">
        <div class="form-group">
          <label class="form-label">Quantity (m3)</label>
          <input class="form-input" type="number" id="wf-qty" min="0" step="0.01">
        </div>
        <div class="form-group">
          <label class="form-label">Quantity Retained After (m3)</label>
          <input class="form-input" type="number" id="wf-qty-ret" min="0" step="0.01">
          <div class="form-hint">Leave blank to auto-calculate</div>
        </div>
      </div>
      <div class="form-group" style="max-width:400px;">
        <label class="form-label">Receiver (barge / truck / shore facility)</label>
        <input class="form-input" id="wf-receiver" placeholder="Name or identity of receiver">
      </div>
      <div class="form-group" style="max-width:300px;">
        <label class="form-label">Port Name</label>
        <input class="form-input" id="wf-port" placeholder="e.g. Manila, Philippines">
      </div>
      <div class="form-group" style="max-width:500px;">
        <label class="form-label">Remarks (optional)</label>
        <input class="form-input" id="wf-remarks">
      </div>`;
  }

  else if (op.id === 'M-correction') {
    const allEntries = loadEntries().filter(e => e.operationType !== 'Correction of Entry (I)');
    const entryOpts = allEntries.length
      ? allEntries.slice().reverse().map(e =>
          `<option value="${esc(e.id)}">${esc(e.date)} — Code ${esc(e.code)}: ${esc(e.operationType)}</option>`
        ).join('')
      : '<option value="">-- No entries in log yet --</option>';
    const corrCrew = loadCrew();
    const corrCE = corrCrew.find(c => c.rank === 'Chief Engineer');
    const corrCEName = (loadSettings().ceName) || (corrCE ? corrCE.name : '');
    formHtml = `
      ${dateHtml}
      <div style="max-width:720px;background:var(--amber-dim);border:1px solid rgba(246,173,85,0.3);border-radius:var(--radius-sm);padding:10px 14px;margin-bottom:16px;font-family:var(--sans);font-size:12px;color:var(--amber2);">
        <strong>Correction of Entry (MARPOL Reg. 17 / MEPC.1/Circ.736):</strong> Select the incorrect entry. It will be struck through with a single line and stamped with the CE name and date. You will then re-enter the same operation type with the correct data -- that new entry becomes the official corrected record.
      </div>
      <div class="form-group" style="max-width:720px;">
        <label class="form-label">Select Incorrect Entry to Strike Through</label>
        <select class="form-select" id="wf-corr-entry">${entryOpts}</select>
      </div>
      <div class="form-group" style="max-width:400px;">
        <label class="form-label">Chief Engineer Name</label>
        <input class="form-input" id="wf-corr-ce" value="${esc(corrCEName)}" placeholder="Chief Engineer full name">
      </div>`;
  }

  // Attachment zone — for bunkering, sludge shore, OWS overboard, bilge shore reception
  const attachOps = ['H-hfo','H-vlsfo','H-ulsfo','H-mdo','H-mgo','H-lsmgo','H-lube','C12-shore','D-ows','E-ows','I-bilgshore'];
  const attachLabels = {
    'H-hfo':'Attach BDN (PDF / JPG / PNG)',
    'H-vlsfo':'Attach BDN (PDF / JPG / PNG)',
    'H-ulsfo':'Attach BDN (PDF / JPG / PNG)',
    'H-mdo':'Attach BDN (PDF / JPG / PNG)',
    'H-mgo':'Attach BDN (PDF / JPG / PNG)',
    'H-lsmgo':'Attach BDN (PDF / JPG / PNG)',
    'H-lube':'Attach BDN / Delivery Note (PDF / JPG / PNG)',
    'C12-shore':'Attach Shore Reception Facility Receipt (PDF / JPG / PNG)',
    'D-ows':'Attach OWS Log / Overboard Permit (PDF / JPG / PNG)',
    'E-ows':'Attach OWS Log / Overboard Permit (PDF / JPG / PNG)',
    'I-bilgshore':'Attach Shore Reception Facility Receipt (PDF / JPG / PNG)',
  };

  const attachHtml = attachOps.includes(op.id) ? `
    <div class="form-group" style="max-width:640px;">
      <label class="form-label">${esc(attachLabels[op.id] || 'Attach Supporting Document')}</label>
      <div class="attach-zone" id="attach-zone"
           onclick="document.getElementById('wf-attach-file').click()"
           ondragover="event.preventDefault();this.classList.add('drag-over')"
           ondragleave="this.classList.remove('drag-over')"
           ondrop="handleAttachDrop(event)">
        <div class="attach-zone-label">Add File</div>
        <div class="attach-zone-sub">Simply drag and drop &mdash; PDF, JPG, PNG (max 5 MB)</div>
      </div>
      <input type="file" id="wf-attach-file" accept=".pdf,.jpg,.jpeg,.png" style="display:none" onchange="handleAttachSelect(event)">
      <div id="attach-preview-area"></div>
    </div>` : '';

  el.innerHTML = `
    ${formHtml}
    ${attachHtml}
    <div style="display:flex;gap:10px;margin-top:16px;">
      <button class="btn btn-primary" onclick="wizPreview()">Preview ORB Entry</button>
      <button class="btn btn-secondary" onclick="wizReset()">Clear Form</button>
    </div>
  `;
  _formDirty = false;
  const wizFormEl = document.getElementById('wiz-form');
  if (wizFormEl) {
    wizFormEl.addEventListener('input',  () => { _formDirty = true; });
    wizFormEl.addEventListener('change', () => { _formDirty = true; });
  }

  // Render bunkering tank rows if applicable
  if (op.id.startsWith('H-')) {
    wiz.bunkTanks = wiz.bunkTanks || [];
    renderBunkTanks();
  }

  // Render bilge well rows for D-tank
  if (op.id === 'D-tank') {
    renderBilgeWellRows();
    updateBilgeTankPreview();
  }

  // Show ROB chips on initial load for forms with tank selects
  if (['C11-coll','C12-shore','C12-xfer','C12-incin','C12-boil','C12-evap','C12-regen'].includes(op.id)) {
    updateTankRobChip('wf-src');
  }
  if (op.id === 'C12-xfer') {
    updateTankRobChip('wf-dest');
  }
  if (['D-ows','D-sludge','D-slop'].includes(op.id)) {
    updateTankRobChip('wf-src');
    if (op.id !== 'D-ows') updateTankRobChip('wf-dest');
  }
  if (['E-ows','E-tank'].includes(op.id)) {
    updateTankRobChip('wf-src');
    if (op.id === 'E-tank') updateTankRobChip('wf-dest');
  }
  if (['I-bilgshore','I-debunk'].includes(op.id)) {
    updateTankRobChip('wf-src');
  }
  // Prefill wf-cap from first selected tank on load
  prefillCapFromSrc();
}

// ============================================================
// MISSED ENTRY — SUB-FORM BUILDER
// Renders the operation-specific fields inside #missed-sub-form
// when the user selects a missed op from the dropdown.
// Date fields are omitted (uses wf-orig-date from parent form).
// ============================================================
function buildMissedSubForm(opId) {
  const container = document.getElementById('missed-sub-form');
  if (!container) return;
  if (!opId) { container.innerHTML = ''; return; }
  const op = OPERATIONS.find(o => o.id === opId);
  if (!op) { container.innerHTML = ''; return; }

  const tanks = getTanks();
  const sludgeTanks = tanks.filter(t => ['sludge','waste','dirty','scav'].includes(t.type) && !t.isBilgeWell);
  const bilgeTanks  = tanks.filter(t => ['bilge','pumproom'].includes(t.type) && !t.isBilgeWell);
  const bilgeWells  = tanks.filter(t => t.isBilgeWell);
  const allTanks    = tanks.filter(t => !t.isBilgeWell);
  const fuelTanks   = tanks.filter(t => ['hfo','vlsfo','ulsfo','mdo','mgo','lsmgo','fo-settle','fo-service','do-service'].includes(t.type) && !t.isBilgeWell);

  function to(arr) {
    return arr.map(t => `<option value="${t.id}">${esc(t.name)} [ROB: ${fmt2(t.rob)} ${t.unit}]</option>`).join('');
  }

  let html = `<div style="border-top:1px solid var(--border);padding-top:16px;margin-top:4px;">
    <div style="font-family:var(--sans);font-size:11px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--blue);margin-bottom:12px;">Operation Details — ${esc(op.label)}</div>`;

  if (op.id === 'C11-inv') {
    const invTanks = sludgeTanks.length ? sludgeTanks : allTanks;
    const s = loadSettings(); const ceName = s.ceName || '';
    let rows = invTanks.map((t,i) => `
      <tr>
        <td style="padding:6px 8px;font-family:var(--mono);font-size:12px;">${esc(t.name)}</td>
        <td style="padding:6px 8px;text-align:right;font-family:var(--mono);font-size:12px;">${fmt3(t.rob)}</td>
        <td style="padding:6px 8px;"><input class="form-input" type="number" id="wf-inv-rob-${i}" min="0" step="0.001" placeholder="${fmt3(t.rob)}" data-tankid="${t.id}" data-prevrob="${t.rob}" data-cap="${t.capacity}"></td>
        <td style="padding:6px 8px;font-family:var(--mono);font-size:12px;">${fmt3(t.capacity)}</td>
        <td style="padding:6px 8px;"><input class="form-input" id="wf-inv-officer-${i}" placeholder="Name|Rank"></td>
      </tr>`).join('');
    html += `<table style="width:100%;border-collapse:collapse;margin-bottom:12px;"><thead><tr>
      <th style="padding:6px 8px;text-align:left;font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--text3);">Tank</th>
      <th style="padding:6px 8px;text-align:right;font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--text3);">Current ROB</th>
      <th style="padding:6px 8px;font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--blue);">New ROB (m3)</th>
      <th style="padding:6px 8px;font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--text3);">Capacity</th>
      <th style="padding:6px 8px;font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--amber);">Officer-in-Charge</th>
      </tr></thead><tbody id="wf-inv-rows">${rows}</tbody></table>
      <div class="form-group" style="max-width:300px;"><label class="form-label">Chief Engineer Name</label><input class="form-input" id="wf-inv-ce-name" value="${esc(ceName)}"></div>`;
  } else if (op.id === 'C11-coll') {
    html += `<div class="form-row" style="max-width:680px;">
      <div class="form-group"><label class="form-label">Sludge Tank</label><select class="form-select" id="wf-src" onchange="prefillCapFromSrc()">${to(sludgeTanks.length?sludgeTanks:allTanks)}</select></div>
      <div class="form-group"><label class="form-label">Capacity (m3)</label><input class="form-input" type="number" id="wf-cap" min="0" step="0.001" readonly tabindex="-1"></div>
    </div>
    <div class="form-row" style="max-width:680px;">
      <div class="form-group"><label class="form-label">Source of Collection</label><input class="form-input" id="wf-src2" placeholder="e.g. engine room bilge well"></div>
      <div class="form-group"><label class="form-label">Quantity Collected (m3)</label><input class="form-input" type="number" id="wf-qty2" min="0" step="0.001"></div>
    </div>`;
  } else if (op.id === 'C12-shore') {
    html += `<div class="form-row" style="max-width:680px;">
      <div class="form-group"><label class="form-label">Source Sludge Tank</label><select class="form-select" id="wf-src" onchange="prefillCapFromSrc()">${to(sludgeTanks.length?sludgeTanks:allTanks)}</select></div>
      <div class="form-group"><label class="form-label">Source Capacity (m3)</label><input class="form-input" type="number" id="wf-cap" min="0" step="0.001" readonly tabindex="-1"></div>
    </div>
    <div class="form-row" style="max-width:680px;">
      <div class="form-group"><label class="form-label">Qty Disposed (m3)</label><input class="form-input" type="number" id="wf-qty" min="0" step="0.01"></div>
      <div class="form-group"><label class="form-label">Qty Retained (m3)</label><input class="form-input" type="number" id="wf-qty-ret" min="0" step="0.01"></div>
    </div>
    <div class="form-row" style="max-width:680px;">
      <div class="form-group"><label class="form-label">Shore Receiver</label><input class="form-input" id="wf-receiver" placeholder="Name of facility"></div>
      <div class="form-group"><label class="form-label">Port</label><input class="form-input" id="wf-port" placeholder="Port name"></div>
    </div>`;
  } else if (op.id === 'C12-xfer') {
    html += `<div class="form-row" style="max-width:680px;">
      <div class="form-group"><label class="form-label">Source Tank</label><select class="form-select" id="wf-src" onchange="prefillCapFromSrc()">${to(sludgeTanks.length?sludgeTanks:allTanks)}</select></div>
      <div class="form-group"><label class="form-label">Source Capacity (m3)</label><input class="form-input" type="number" id="wf-cap" min="0" step="0.001" readonly tabindex="-1"></div>
    </div>
    <div class="form-row" style="max-width:680px;">
      <div class="form-group"><label class="form-label">Destination Tank</label><select class="form-select" id="wf-dest">${to(sludgeTanks.length?sludgeTanks:allTanks)}</select></div>
      <div class="form-group"></div>
    </div>
    <div class="form-row" style="max-width:680px;">
      <div class="form-group"><label class="form-label">Qty Transferred (m3)</label><input class="form-input" type="number" id="wf-qty" min="0" step="0.01"></div>
      <div class="form-group"><label class="form-label">Qty Retained in Source (m3)</label><input class="form-input" type="number" id="wf-qty-ret" min="0" step="0.01"></div>
    </div>`;
  } else if (op.id === 'C12-incin') {
    html += `<div class="form-row" style="max-width:680px;">
      <div class="form-group"><label class="form-label">Source Tank</label><select class="form-select" id="wf-src" onchange="prefillCapFromSrc()">${to(sludgeTanks.length?sludgeTanks:allTanks)}</select></div>
      <div class="form-group"><label class="form-label">Source Capacity (m3)</label><input class="form-input" type="number" id="wf-cap" min="0" step="0.001" readonly tabindex="-1"></div>
    </div>
    <div class="form-row" style="max-width:680px;">
      <div class="form-group"><label class="form-label">Qty Incinerated (m3)</label><input class="form-input" type="number" id="wf-qty" min="0" step="0.01"></div>
      <div class="form-group"><label class="form-label">Qty Retained (m3)</label><input class="form-input" type="number" id="wf-qty-ret" min="0" step="0.01"></div>
    </div>
    <div class="form-group" style="max-width:300px;"><label class="form-label">Duration (hours)</label><input class="form-input" type="number" id="wf-hours" min="0" step="0.1"></div>`;
  } else if (['C12-boil','C12-evap','C12-regen'].includes(op.id)) {
    html += `<div class="form-row" style="max-width:680px;">
      <div class="form-group"><label class="form-label">Source Tank</label><select class="form-select" id="wf-src" onchange="prefillCapFromSrc()">${to(sludgeTanks.length?sludgeTanks:allTanks)}</select></div>
      <div class="form-group"><label class="form-label">Source Capacity (m3)</label><input class="form-input" type="number" id="wf-cap" min="0" step="0.001" readonly tabindex="-1"></div>
    </div>
    <div class="form-row" style="max-width:680px;">
      <div class="form-group"><label class="form-label">Qty Disposed (m3)</label><input class="form-input" type="number" id="wf-qty" min="0" step="0.01"></div>
      <div class="form-group"><label class="form-label">Qty Retained (m3)</label><input class="form-input" type="number" id="wf-qty-ret" min="0" step="0.01"></div>
    </div>
    ${op.id==='C12-boil'?`<div class="form-group" style="max-width:300px;"><label class="form-label">Duration (hours)</label><input class="form-input" type="number" id="wf-hours" min="0" step="0.1"></div>`:''}
    ${op.id==='C12-regen'?`<div class="form-row" style="max-width:680px;"><div class="form-group"><label class="form-label">Regenerated Fuel Type</label><input class="form-input" id="wf-regen-fuel" placeholder="e.g. HFO"></div><div class="form-group"><label class="form-label">Water Separated (m3)</label><input class="form-input" id="wf-regen-water" placeholder="0.00"></div></div>`:''}`;
  } else if (op.id === 'D-tank') {
    const destOpts = to(bilgeTanks.length?bilgeTanks:allTanks);
    html += `<div class="form-row" style="max-width:500px;">
      <div class="form-group"><label class="form-label">Start Time</label><input class="form-input" type="time" id="wf-start" value="${fmtTimeInput()}"></div>
      <div class="form-group"><label class="form-label">Stop Time</label><input class="form-input" type="time" id="wf-stop"></div>
    </div>
    <div class="form-group" style="max-width:640px;"><label class="form-label">Bilge Wells</label>
      <div id="wf-bilge-wells-list"></div>
      <button class="btn btn-secondary btn-sm" type="button" onclick="addBilgeWellRow()" style="margin-top:8px;">+ Add Bilge Well</button>
    </div>
    <input type="hidden" id="wf-qty" value="0">
    <div class="form-group" style="max-width:400px;"><label class="form-label">Destination Holding Tank</label><select class="form-select" id="wf-dest">${destOpts}</select></div>
    <div class="form-group" style="max-width:500px;"><label class="form-label">Remarks (optional)</label><input class="form-input" id="wf-remarks"></div>`;
  } else if (['D-ows','D-sludge','D-slop'].includes(op.id)) {
    const srcOpts2 = bilgeTanks.length ? to(bilgeTanks)+(bilgeWells.length?'<optgroup label="Bilge Wells">'+to(bilgeWells)+'</optgroup>':'') : to(bilgeWells);
    const destOpts2 = op.id==='D-sludge' ? to(sludgeTanks.length?sludgeTanks:allTanks) : to(bilgeTanks.length?bilgeTanks:allTanks);
    html += `<div class="form-row" style="max-width:500px;">
      <div class="form-group"><label class="form-label">Start Time</label><input class="form-input" type="time" id="wf-start" value="${fmtTimeInput()}"></div>
      <div class="form-group"><label class="form-label">Stop Time</label><input class="form-input" type="time" id="wf-stop"></div>
    </div>
    <div class="form-row" style="max-width:680px;">
      <div class="form-group"><label class="form-label">Source Tank</label><select class="form-select" id="wf-src" onchange="prefillCapFromSrc()">${srcOpts2}</select></div>
      <div class="form-group"><label class="form-label">Source Capacity (m3)</label><input class="form-input" type="number" id="wf-cap" min="0" step="0.001" readonly tabindex="-1"></div>
    </div>
    ${op.id!=='D-ows'?`<div class="form-group" style="max-width:400px;"><label class="form-label">Destination Tank</label><select class="form-select" id="wf-dest">${destOpts2}</select></div>`:''}
    <div class="form-row" style="max-width:680px;">
      <div class="form-group"><label class="form-label">Qty Transferred (m3)</label><input class="form-input" type="number" id="wf-qty" min="0" step="0.001"></div>
      <div class="form-group"><label class="form-label">Qty Retained (m3)</label><input class="form-input" type="number" id="wf-qty-ret" min="0" step="0.001"></div>
    </div>`;
  } else if (['E-ows','E-tank'].includes(op.id)) {
    html += `<div class="form-row" style="max-width:500px;">
      <div class="form-group"><label class="form-label">Start Time</label><input class="form-input" type="time" id="wf-start" value="${fmtTimeInput()}"></div>
      <div class="form-group"><label class="form-label">Stop Time</label><input class="form-input" type="time" id="wf-stop"></div>
    </div>
    <div class="form-row" style="max-width:680px;">
      <div class="form-group"><label class="form-label">Source Tank</label><select class="form-select" id="wf-src" onchange="prefillCapFromSrc()">${to(bilgeTanks.length?bilgeTanks:allTanks)}</select></div>
      <div class="form-group"><label class="form-label">Source Capacity (m3)</label><input class="form-input" type="number" id="wf-cap" min="0" step="0.001" readonly tabindex="-1"></div>
    </div>
    ${op.id==='E-tank'?`<div class="form-group" style="max-width:400px;"><label class="form-label">Destination Tank</label><select class="form-select" id="wf-dest">${to(bilgeTanks.length?bilgeTanks:allTanks)}</select></div>`:''}
    <div class="form-row" style="max-width:680px;">
      <div class="form-group"><label class="form-label">Qty Processed (m3)</label><input class="form-input" type="number" id="wf-qty" min="0" step="0.001"></div>
      <div class="form-group"><label class="form-label">Qty Retained (m3)</label><input class="form-input" type="number" id="wf-qty-ret" min="0" step="0.001"></div>
    </div>`;
  } else if (['F-fail','F-rest'].includes(op.id)) {
    html += `<div class="form-group" style="max-width:500px;"><label class="form-label">Equipment</label><input class="form-input" id="wf-equip" placeholder="e.g. OWS, 15 PPM Alarm, 3-way valve"></div>
    <div class="form-group" style="max-width:680px;"><label class="form-label">Description</label><textarea class="form-textarea" id="wf-remarks" placeholder="Describe the failure or restoration"></textarea></div>`;
  } else if (op.id === 'G-acc') {
    html += `<div class="form-group" style="max-width:680px;"><label class="form-label">Circumstances / Description</label><textarea class="form-textarea" id="wf-remarks" rows="3"></textarea></div>
    <div class="form-row" style="max-width:680px;">
      <div class="form-group"><label class="form-label">Estimated Quantity (m3)</label><input class="form-input" type="number" id="wf-qty" min="0" step="0.001"></div>
      <div class="form-group"><label class="form-label">Position / Location</label><input class="form-input" id="wf-port" placeholder="Port or position"></div>
    </div>
    <div class="form-group" style="max-width:500px;"><label class="form-label">Steps Taken to Minimize Discharge</label><textarea class="form-textarea" id="wf-steps" rows="2"></textarea></div>`;
  } else if (op.id.startsWith('H-')) {
    const grade = op.id==='H-hfo'?'HFO':op.id==='H-vlsfo'?'VLSFO':op.id==='H-ulsfo'?'ULSFO':op.id==='H-mdo'?'MDO':op.id==='H-mgo'?'MGO':op.id==='H-lsmgo'?'LSMGO':op.id==='H-lube'?'Lube Oil':'';
    html += `<div class="form-group" style="max-width:680px;"><label class="form-label">Grade / ISO Spec</label><input class="form-input" id="wf-iso" placeholder="e.g. ISO-RMG-380 HFO 0.50%S" value="${grade}"></div>
    <div id="wf-bunk-tanks-list"></div>
    <button class="btn btn-secondary btn-sm" type="button" onclick="addBunkTank()" style="margin-bottom:12px;">+ Add Receiving Tank</button>
    <div class="form-row" style="max-width:680px;">
      <div class="form-group"><label class="form-label">Bunker Barge / Vessel</label><input class="form-input" id="wf-receiver" placeholder="Name of bunker barge or terminal"></div>
      <div class="form-group"><label class="form-label">Port</label><input class="form-input" id="wf-port" placeholder="Port name"></div>
    </div>
    <div class="form-row" style="max-width:680px;">
      <div class="form-group"><label class="form-label">Start</label><input class="form-input" type="datetime-local" id="wf-start"></div>
      <div class="form-group"><label class="form-label">Stop</label><input class="form-input" type="datetime-local" id="wf-stop"></div>
    </div>`;
  } else if (op.id === 'I-cargo') {
    html += `<div class="form-row" style="max-width:680px;">
      <div class="form-group"><label class="form-label">Qty Transferred (m3)</label><input class="form-input" type="number" id="wf-qty" min="0" step="0.01"></div>
      <div class="form-group"><label class="form-label">Destination Tank</label><select class="form-select" id="wf-dest">${to(bilgeTanks.length?bilgeTanks:allTanks)}</select></div>
    </div>
    <div class="form-group" style="max-width:500px;"><label class="form-label">Remarks (optional)</label><input class="form-input" id="wf-remarks"></div>`;
  } else if (op.id === 'I-debunk') {
    html += `<div class="form-row" style="max-width:680px;">
      <div class="form-group"><label class="form-label">Source Tank</label><select class="form-select" id="wf-src" onchange="prefillCapFromSrc()">${to(fuelTanks.length?fuelTanks:allTanks)}</select></div>
      <div class="form-group"><label class="form-label">Source Capacity (MT)</label><input class="form-input" type="number" id="wf-cap" min="0" step="0.001" readonly tabindex="-1"></div>
    </div>
    <div class="form-row" style="max-width:680px;">
      <div class="form-group"><label class="form-label">Qty De-bunkered (MT)</label><input class="form-input" type="number" id="wf-qty" min="0" step="0.1"></div>
      <div class="form-group"><label class="form-label">Qty Retained After (MT)</label><input class="form-input" type="number" id="wf-qty-ret" min="0" step="0.1"></div>
    </div>
    <div class="form-row" style="max-width:680px;">
      <div class="form-group"><label class="form-label">Grade & ISO Spec</label><input class="form-input" id="wf-iso" placeholder="e.g. ISO-RMG-380 HFO 0.50%S"></div>
      <div class="form-group"><label class="form-label">Receiver</label><input class="form-input" id="wf-receiver" placeholder="Name of barge / truck / shore"></div>
    </div>
    <div class="form-row" style="max-width:680px;">
      <div class="form-group"><label class="form-label">Port</label><input class="form-input" id="wf-port" placeholder="Port name"></div>
    </div>
    <div class="form-row" style="max-width:680px;">
      <div class="form-group"><label class="form-label">Start</label><input class="form-input" type="datetime-local" id="wf-start"></div>
      <div class="form-group"><label class="form-label">Stop</label><input class="form-input" type="datetime-local" id="wf-stop"></div>
    </div>`;
  } else if (op.id === 'I-seal') {
    html += `<div class="form-row" style="max-width:680px;">
      <div class="form-group"><label class="form-label">Valve Name / Location</label><input class="form-input" id="wf-valve" placeholder="e.g. OWS overboard valve"></div>
      <div class="form-group"><label class="form-label">Seal Number</label><input class="form-input" id="wf-seal" placeholder="e.g. 001234"></div>
    </div>`;
  } else if (op.id === 'I-unseal') {
    html += `<div class="form-row" style="max-width:680px;">
      <div class="form-group"><label class="form-label">Valve Name / Location</label><input class="form-input" id="wf-valve" placeholder="e.g. OWS overboard valve"></div>
      <div class="form-group"><label class="form-label">Seal Number</label><input class="form-input" id="wf-seal" placeholder="e.g. 001234"></div>
    </div>
    <div class="form-group" style="max-width:400px;"><label class="form-label">Reason for Unsealing</label><input class="form-input" id="wf-reason" placeholder="e.g. normal operation"></div>`;
  } else if (op.id === 'I-inv') {
    html += `<div class="form-group" style="max-width:400px;"><label class="form-label">Bilge Holding Tank</label><select class="form-select" id="wf-src">${to(bilgeTanks.length?bilgeTanks:allTanks)}</select></div>
    <div class="form-group" style="max-width:400px;"><label class="form-label">New ROB (m3)</label><input class="form-input" type="number" id="wf-qty" min="0" step="0.001"></div>`;
  } else if (op.id === 'I-owstest') {
    html += `<div class="form-row" style="max-width:680px;">
      <div class="form-group"><label class="form-label">Start Time</label><input class="form-input" type="time" id="wf-start" value="${fmtTimeInput()}"></div>
      <div class="form-group"><label class="form-label">Stop Time</label><input class="form-input" type="time" id="wf-stop"></div>
    </div>
    <div class="form-group" style="max-width:680px;"><label class="form-label">Test Results / Remarks</label><textarea class="form-textarea" id="wf-remarks" placeholder="PPM reading, 3-way valve operation, outcome..."></textarea></div>`;
  } else if (op.id === 'I-bunksample') {
    html += `<div class="form-group" style="max-width:680px;"><label class="form-label">Description</label><textarea class="form-textarea" id="wf-remarks" placeholder="Sample details, grade, disposal method..."></textarea></div>`;
  } else if (op.id === 'I-bilgshore') {
    html += `<div class="form-row" style="max-width:680px;">
      <div class="form-group"><label class="form-label">Source Tank</label><select class="form-select" id="wf-src" onchange="prefillCapFromSrc()">${to(bilgeTanks.length?bilgeTanks:allTanks)}</select></div>
      <div class="form-group"><label class="form-label">Source Capacity (m3)</label><input class="form-input" type="number" id="wf-cap" min="0" step="0.001" readonly tabindex="-1"></div>
    </div>
    <div class="form-row" style="max-width:680px;">
      <div class="form-group"><label class="form-label">Qty Transferred (m3)</label><input class="form-input" type="number" id="wf-qty" min="0" step="0.001"></div>
      <div class="form-group"><label class="form-label">Qty Retained (m3)</label><input class="form-input" type="number" id="wf-qty-ret" min="0" step="0.001"></div>
    </div>
    <div class="form-row" style="max-width:680px;">
      <div class="form-group"><label class="form-label">Shore Receiver</label><input class="form-input" id="wf-receiver" placeholder="Name of reception facility"></div>
      <div class="form-group"><label class="form-label">Port</label><input class="form-input" id="wf-port" placeholder="Port name"></div>
    </div>`;
  } else {
    html += `<div class="form-group" style="max-width:680px;"><label class="form-label">Remarks / Description</label><textarea class="form-textarea" id="wf-remarks" placeholder="Describe the missed operation..."></textarea></div>`;
  }

  html += '</div>';
  container.innerHTML = html;

  // Post-render: init bunkering rows if H-*
  if (op.id.startsWith('H-')) {
    wiz.bunkTanks = [];
    renderBunkTanks();
  }
  if (op.id === 'D-tank') {
    renderBilgeWellRows();
  }
  // Prefill wf-cap from first selected tank on load
  prefillCapFromSrc();
}

function addBunkTank() {
  if (!wiz.bunkTanks) wiz.bunkTanks = [];
  wiz.bunkTanks.push({ tankId: '', qtyAdded: '', qtyNow: '' });
  renderBunkTanks();
}

function renderBunkTanks() {
  const opId = wiz.opId || '';
  const allTanks = getTanks().filter(t => !t.isBilgeWell);
  let tanks;
  if (opId === 'H-lube') {
    tanks = allTanks.filter(t => ['lo','lo-settle','lo-service'].includes(t.type));
    if (!tanks.length) tanks = allTanks; // fallback if none configured
  } else if (opId === 'H-mdo' || opId === 'H-mgo' || opId === 'H-lsmgo') {
    tanks = allTanks.filter(t => ['hfo','vlsfo','ulsfo','mdo','mgo','lsmgo','fo-settle','fo-service','do-service'].includes(t.type));
    if (!tanks.length) tanks = allTanks;
  } else if (opId === 'H-hfo' || opId === 'H-vlsfo' || opId === 'H-ulsfo') {
    tanks = allTanks.filter(t => ['hfo','vlsfo','ulsfo','fo-settle','fo-service'].includes(t.type));
    if (!tanks.length) tanks = allTanks;
  } else {
    tanks = allTanks;
  }
  const el = document.getElementById('wf-bunk-tanks');
  if (!el) return;
  let html = '';
  (wiz.bunkTanks || []).forEach((bt, i) => {
    html += `<div style="display:flex;gap:8px;align-items:flex-end;margin-bottom:8px;flex-wrap:wrap;">
      <div style="flex:2;min-width:180px;">
        <label class="form-label">Tank Name</label>
        <select class="form-select" onchange="wiz.bunkTanks[${i}].tankId=this.value">
          <option value="">-- select tank --</option>
          ${tanks.map(t=>`<option value="${t.id}" ${t.id===bt.tankId?'selected':''}>${esc(t.name)} [ROB: ${fmt2(t.rob)} ${t.unit}]</option>`).join('')}
        </select>
      </div>
      <div style="flex:1;min-width:100px;">
        <label class="form-label">Qty Added (MT)</label>
        <input class="form-input" type="number" min="0" step="0.1" value="${bt.qtyAdded}" onchange="wiz.bunkTanks[${i}].qtyAdded=this.value">
      </div>
      <div style="flex:1;min-width:100px;">
        <label class="form-label">Qty Now (MT)</label>
        <input class="form-input" type="number" min="0" step="0.1" value="${bt.qtyNow}" onchange="wiz.bunkTanks[${i}].qtyNow=this.value">
      </div>
      <div>
        <button class="btn btn-danger btn-sm" onclick="removeBunkTank(${i})" style="margin-bottom:2px;">X</button>
      </div>
    </div>`;
  });
  el.innerHTML = html;
}

function removeBunkTank(i) {
  wiz.bunkTanks.splice(i, 1);
  renderBunkTanks();
}

// ============================================================
// BILGE WELL MULTI-SELECT (D-tank)
// ============================================================
function renderBilgeWellRows() {
  const tanks = getTanks();
  const bilgeWells = tanks.filter(t => t.isBilgeWell);
  const el = document.getElementById('wf-bilge-wells-list');
  if (!el) return;
  if (!wiz.bilgeWellInputs || wiz.bilgeWellInputs.length === 0) {
    wiz.bilgeWellInputs = bilgeWells.length ? bilgeWells.map(w => ({ tankId: w.id, vol: '' })) : [{ tankId: '', vol: '' }];
  }
  let html = '';
  wiz.bilgeWellInputs.forEach((row, i) => {
    const showX = wiz.bilgeWellInputs.length > 1;
    html += `<div class="bilge-well-row">
      <div class="bilge-col bilge-col-select">
        <label class="form-label">Bilge Well</label>
        <select class="form-select" onchange="wiz.bilgeWellInputs[${i}].tankId=this.value">
          <option value="">-- select bilge well --</option>
          ${bilgeWells.map(t => `<option value="${t.id}" ${t.id===row.tankId?'selected':''}>${esc(t.name)}</option>`).join('')}
          <option value="__manual__" ${row.tankId==='__manual__'?'selected':''}>Other (manual)</option>
        </select>
      </div>
      <div class="bilge-col bilge-col-vol">
        <label class="form-label">Volume (m3)</label>
        <input class="form-input" type="number" min="0" step="0.001" value="${row.vol}" oninput="wiz.bilgeWellInputs[${i}].vol=this.value;updateBilgeTotalVol()">
      </div>
      ${showX ? `<div class="bilge-col bilge-col-x"><button class="btn btn-danger btn-sm bilge-well-remove" type="button" onclick="removeBilgeWellRow(${i})" aria-label="Remove row">&times;</button></div>` : ''}
    </div>`;
  });
  el.innerHTML = html;
  updateBilgeTotalVol();
}

function addBilgeWellRow() {
  if (!wiz.bilgeWellInputs) wiz.bilgeWellInputs = [];
  wiz.bilgeWellInputs.push({ tankId: '', vol: '' });
  renderBilgeWellRows();
}

function removeBilgeWellRow(i) {
  wiz.bilgeWellInputs.splice(i, 1);
  renderBilgeWellRows();
}

function updateBilgeTotalVol() {
  const total = (wiz.bilgeWellInputs || []).reduce((s, r) => s + (parseFloat(r.vol) || 0), 0);
  const el = document.getElementById('wf-total-vol');
  if (el) el.textContent = total.toFixed(3) + ' m3';
  const hidden = document.getElementById('wf-qty');
  if (hidden) hidden.value = total;
  updateBilgeTankPreview();
  validateBilgeTotalLive();
}

function updateBilgeInvCapDisplay() {
  const sel = document.getElementById('wf-src');
  const display = document.getElementById('bilge-inv-cap-display');
  if (!sel || !display) return;
  const tank = getTanks().find(t => t.id === sel.value);
  display.textContent = tank ? fmt3(tank.capacity) : '—';
}

function updateTankRobChip(selectId) {
  const sel = document.getElementById(selectId);
  const chipId = 'rob-chip-' + selectId;
  const chip = document.getElementById(chipId);
  if (!sel || !chip) return;
  const tank = getTanks().find(t => t.id === sel.value);
  if (!tank) { chip.style.display = 'none'; return; }
  const pct = tank.capacity > 0 ? Math.min(100, (tank.rob / tank.capacity) * 100) : null;
  const color = pct === null ? 'var(--blue)' : pct >= 80 ? 'var(--red)' : pct >= 50 ? 'var(--amber)' : 'var(--green)';
  chip.style.display = 'block';
  chip.innerHTML = `<span style="color:var(--text3);font-size:10px;font-family:var(--sans);font-weight:600;text-transform:uppercase;letter-spacing:0.08em;">Current ROB</span>&nbsp;&nbsp;<span style="font-family:var(--mono);font-size:13px;font-weight:600;color:${color};">${fmt2(tank.rob)} ${tank.unit}</span>${tank.capacity>0?`<span style="color:var(--text3);font-size:11px;"> / ${fmt2(tank.capacity)} ${tank.unit} &nbsp;(${pct.toFixed(0)}%)</span>`:''}`;
  if (selectId === 'wf-src') {
    const capEl = document.getElementById('wf-cap');
    if (capEl) capEl.value = tank.capacity > 0 ? Number(tank.capacity).toFixed(3) : '';
  }
}

function prefillCapFromSrc() {
  const sel = document.getElementById('wf-src');
  const capEl = document.getElementById('wf-cap');
  if (!sel || !capEl) return;
  const tank = getTanks().find(t => t.id === sel.value);
  if (tank) capEl.value = tank.capacity > 0 ? Number(tank.capacity).toFixed(3) : '';
}

function robChipDiv(selectId) {
  return `<div id="rob-chip-${selectId}" style="display:none;background:var(--bg3);border:1px solid var(--border);border-radius:6px;padding:6px 12px;margin-top:4px;margin-bottom:4px;"></div>`;
}

function updateBilgeTankPreview() {
  const tanks = getTanks();
  const destId = (document.getElementById('wf-dest') || {}).value;
  const destTank = tanks.find(t => t.id === destId);
  const total = (wiz.bilgeWellInputs || []).reduce((s, r) => s + (parseFloat(r.vol) || 0), 0);
  const preview = document.getElementById('wf-bilge-tank-preview');
  if (!preview) return;
  if (!destTank) { preview.style.display = 'none'; return; }
  preview.style.display = 'block';
  const before = parseFloat(destTank.rob) || 0;
  const after  = before + total;
  document.getElementById('wf-bht-before').textContent = 'Before: ' + before.toFixed(3) + ' m3';
  document.getElementById('wf-bht-after').textContent  = 'After: '  + after.toFixed(3)  + ' m3';
}

// ============================================================
// FILE ATTACHMENT HANDLERS
// ============================================================
const MAX_ATTACH_BYTES = 5 * 1024 * 1024; // 5 MB

function handleAttachSelect(e) {
  const file = e.target.files[0];
  if (!file) return;
  processAttachFile(file);
  e.target.value = '';
}

function handleAttachDrop(e) {
  e.preventDefault();
  const zone = document.getElementById('attach-zone');
  if (zone) zone.classList.remove('drag-over');
  const file = e.dataTransfer.files[0];
  if (!file) return;
  processAttachFile(file);
}

function processAttachFile(file) {
  const previewArea = document.getElementById('attach-preview-area');
  if (file.size > MAX_ATTACH_BYTES) {
    if (previewArea) previewArea.innerHTML = `<div style="color:var(--red2);font-size:12px;font-family:var(--sans);margin-top:6px;">File too large (${(file.size/1024/1024).toFixed(1)} MB). Maximum 5 MB allowed.</div>`;
    return;
  }
  const isImage = file.type.startsWith('image/');
  const isPDF   = file.type === 'application/pdf';
  if (!isImage && !isPDF) {
    if (previewArea) previewArea.innerHTML = `<div style="color:var(--red2);font-size:12px;font-family:var(--sans);margin-top:6px;">Only PDF, JPG, or PNG files are accepted.</div>`;
    return;
  }
  const reader = new FileReader();
  reader.onload = ev => {
    wiz.attachment = { name: file.name, type: file.type, dataUrl: ev.target.result };
    renderAttachPreview();
  };
  reader.readAsDataURL(file);
}

function renderAttachPreview() {
  const a = wiz.attachment;
  const el = document.getElementById('attach-preview-area');
  if (!el || !a) return;
  const isImage = a.type.startsWith('image/');
  el.innerHTML = `<div class="attach-file-preview">
    ${isImage ? `<img class="attach-thumb" src="${a.dataUrl}" alt="">` : '<span style="font-size:22px;flex-shrink:0;">&#128196;</span>'}
    <span class="attach-name">${esc(a.name)}</span>
    <span style="font-size:11px;color:var(--text3);white-space:nowrap;">${(wiz.attachment ? (wiz.attachment.dataUrl.length * 0.75 / 1024).toFixed(0) : 0)} KB</span>
    <button class="attach-remove" onclick="clearAttachment()" title="Remove file">&times;</button>
  </div>`;
}

function clearAttachment() {
  wiz.attachment = null;
  const el = document.getElementById('attach-preview-area');
  if (el) el.innerHTML = '';
}

// ============================================================
// TRANSFER VALIDATION
// ============================================================

function showFieldError(fieldId, msg) {
  const inp = document.getElementById(fieldId);
  if (inp) inp.classList.add('wf-invalid');
  const errEl = document.getElementById('err-' + fieldId);
  if (errEl) { errEl.textContent = msg; errEl.classList.add('visible'); errEl.classList.remove('wf-warn'); }
}

function showFieldWarn(fieldId, msg) {
  const inp = document.getElementById(fieldId);
  if (inp) inp.classList.remove('wf-invalid');
  const errEl = document.getElementById('err-' + fieldId);
  if (errEl) { errEl.textContent = msg; errEl.classList.add('visible', 'wf-warn'); errEl.style.color = 'var(--amber)'; }
}

function clearFieldError(fieldId) {
  const inp = document.getElementById(fieldId);
  if (inp) inp.classList.remove('wf-invalid');
  const errEl = document.getElementById('err-' + fieldId);
  if (errEl) { errEl.textContent = ''; errEl.classList.remove('visible', 'wf-warn'); errEl.style.color = ''; }
}

function validateTimePair() {
  const startEl     = document.getElementById('wf-start');
  const stopEl      = document.getElementById('wf-stop');
  if (!startEl || !stopEl) return true;
  const startV = startEl.value;
  const stopV  = stopEl.value;
  clearFieldError('wf-stop');
  if (!startV || !stopV) {
    if (stopV && !startV) { showFieldError('wf-start', 'Start time is required'); return false; }
    if (startV && !stopV) { showFieldError('wf-stop', 'Stop time is required'); return false; }
    return true;
  }
  // If date fields exist (D-tank / D-ows / D-sludge / D-slop forms), compare full datetime
  const startDateEl = document.getElementById('wf-start-date');
  const stopDateEl  = document.getElementById('wf-stop-date');
  if (startDateEl && stopDateEl && startDateEl.value && stopDateEl.value) {
    const startDT = new Date(startDateEl.value + 'T' + startV);
    const stopDT  = new Date(stopDateEl.value  + 'T' + stopV);
    if (isNaN(startDT) || isNaN(stopDT)) return true;
    if (stopDT <= startDT) {
      showFieldError('wf-stop', 'Stop date/time must be after start date/time');
      return false;
    }
    clearFieldError('wf-stop');
    return true;
  }
  // Fallback: time-only comparison (no date fields)
  const [sh, sm] = startV.split(':').map(Number);
  const [eh, em] = stopV.split(':').map(Number);
  const startMins = sh * 60 + sm;
  const stopMins  = eh * 60 + em;
  if (stopMins === startMins) {
    showFieldError('wf-stop', 'Stop time must be after start time');
    return false;
  }
  if (stopMins < startMins) {
    const diff = startMins - stopMins;
    if (diff > 360) {
      showFieldError('wf-stop', 'Stop time is more than 6 hours before start -- check your entry');
      return false;
    }
    showFieldWarn('wf-stop', 'Operation spans midnight -- confirm this is intentional');
    return 'warn';
  }
  clearFieldError('wf-stop');
  return true;
}

function validateTransferQtyLive() {
  const tanks = getTanks();
  const srcId = (document.getElementById('wf-src') || {}).value || '';
  const qty   = parseFloat((document.getElementById('wf-qty') || {}).value) || 0;
  const srcTank = tanks.find(t => t.id === srcId);
  clearFieldError('wf-qty');
  if (qty <= 0) { showFieldError('wf-qty', 'Quantity must be greater than 0'); return false; }
  if (srcTank && qty > srcTank.rob + 0.001) {
    showFieldError('wf-qty', 'Cannot transfer ' + qty.toFixed(3) + ' m³ -- source tank only has ' + srcTank.rob.toFixed(3) + ' m³');
    return false;
  }
  validateDestCapacityLive();
  validateRetainedLive();
  return true;
}

function validateDestCapacityLive() {
  const tanks = getTanks();
  const srcId  = (document.getElementById('wf-src')  || {}).value || '';
  const destId = (document.getElementById('wf-dest') || {}).value || '';
  const qty    = parseFloat((document.getElementById('wf-qty') || {}).value) || 0;
  const destTank = tanks.find(t => t.id === destId);
  clearFieldError('wf-dest');
  if (!destTank || !destId) return true;
  if (srcId && destId && srcId === destId) {
    showFieldError('wf-dest', 'Source and destination tanks cannot be the same');
    return false;
  }
  const destRob = parseFloat(destTank.rob) || 0;
  const destCap = parseFloat(destTank.capacity) || 0;
  if (destCap > 0 && destRob + qty > destCap + 0.001) {
    showFieldError('wf-dest', 'Destination would overflow: ' + destRob.toFixed(3) + ' + ' + qty.toFixed(3) + ' m³ > ' + destCap.toFixed(3) + ' m³ capacity');
    return false;
  }
  return true;
}

function validateRetainedLive() {
  const tanks = getTanks();
  const srcId  = (document.getElementById('wf-src')  || {}).value || '';
  const srcTank = tanks.find(t => t.id === srcId);
  const qty    = parseFloat((document.getElementById('wf-qty') || {}).value) || 0;
  const retEl  = document.getElementById('wf-qty-ret');
  if (!retEl) return true;
  const qtyRet = parseFloat(retEl.value);
  clearFieldError('wf-qty-ret');
  if (!isNaN(qtyRet)) {
    if (qtyRet < -0.001) {
      showFieldError('wf-qty-ret', 'Retained quantity cannot be negative');
      return false;
    }
    if (srcTank && (qty + qtyRet) > srcTank.rob + 0.001) {
      showFieldError('wf-qty-ret', 'Transferred + retained (' + (qty + qtyRet).toFixed(3) + ' m³) exceeds tank ROB (' + srcTank.rob.toFixed(3) + ' m³)');
      return false;
    }
  }
  return true;
}

function validateBilgeTotalLive() {
  const tanks = getTanks();
  const destId = (document.getElementById('wf-dest') || {}).value || '';
  const destTank = tanks.find(t => t.id === destId);
  const wellInputs = (wiz.bilgeWellInputs || []);
  const totalVol = wellInputs.reduce((s, r) => s + (parseFloat(r.vol) || 0), 0);
  clearFieldError('wf-bilge-total');
  if (totalVol <= 0) {
    showFieldError('wf-bilge-total', 'Enter volume for at least one bilge well');
    return false;
  }
  if (destTank) {
    const free = (parseFloat(destTank.capacity) || 0) - (parseFloat(destTank.rob) || 0);
    if (totalVol > free + 0.001) {
      showFieldError('wf-bilge-total', 'Total bilge volume (' + totalVol.toFixed(3) + ' m³) exceeds available space in destination tank (' + free.toFixed(3) + ' m³ free)');
      return false;
    }
  }
  return true;
}

function getTransferValidationErrors() {
  const errors = [];
  const opId = wiz.opId || '';
  const hasStartStop = ['D-tank','D-ows','D-sludge','D-slop','E-ows','E-tank'].includes(opId);
  const hasSrcQty    = ['C12-xfer','C12-shore','C12-incin','C12-boil','C12-evap','C12-regen',
                        'D-ows','D-sludge','D-slop','E-ows','E-tank'].includes(opId);
  const hasRetained  = ['C12-xfer','C12-shore','C12-incin','C12-boil','C12-evap','C12-regen'].includes(opId);
  const isBilgeTank  = opId === 'D-tank';

  if (hasStartStop) {
    const r = validateTimePair();
    if (r === false) errors.push('Start/stop time is invalid');
  }
  if (hasSrcQty) {
    const qty = parseFloat((document.getElementById('wf-qty') || {}).value) || 0;
    if (qty <= 0) errors.push('Quantity must be greater than 0');
    const ok = validateTransferQtyLive();
    if (!ok) {
      const tanks = getTanks();
      const srcId = (document.getElementById('wf-src') || {}).value || '';
      const srcTank = tanks.find(t => t.id === srcId);
      if (srcTank && qty > srcTank.rob + 0.001)
        errors.push('Transfer quantity exceeds source tank ROB');
    }
    if (!validateDestCapacityLive()) errors.push('Destination tank would overflow');
    if (hasRetained && !validateRetainedLive()) errors.push('Retained quantity is invalid');
  }
  if (isBilgeTank) {
    if (!validateBilgeTotalLive()) errors.push('Bilge well volumes are invalid or exceed destination tank');
  }

  // OWS overboard discharge (D-ows, E-ows) hard gates
  if (['D-ows', 'E-ows'].includes(opId)) {
    // Gate 1: Code I prerequisites (OCM test + valve unsealing)
    const dateVal = (document.getElementById('wf-date') || {}).value || fmtDateInput();
    const chk = checkOwsDischargePrereqs(dateVal);
    if (!chk.ok) {
      errors.push('OWS prerequisites not met: ' + chk.missing.join('; ') + ' -- record Code I entries first');
    }
    // Gate 2: Position at start required
    const startLatd = ((document.getElementById('wf-pos-start-latd') || {}).value || '').trim();
    const startLond = ((document.getElementById('wf-pos-start-lond') || {}).value || '').trim();
    if (!startLatd || !startLond) {
      errors.push('Position at start is required for OWS overboard discharge');
    }
    // Gate 3: Position at stop required (D-ows only — has both start and stop position fields)
    if (opId === 'D-ows') {
      const stopLatd = ((document.getElementById('wf-pos-stop-latd') || {}).value || '').trim();
      const stopLond = ((document.getElementById('wf-pos-stop-lond') || {}).value || '').trim();
      if (!stopLatd || !stopLond) {
        errors.push('Position at stop is required for OWS overboard discharge');
      }
    }
  }

  return errors;
}

// ============================================================
// OWS DISCHARGE PREREQUISITE LOGIC
// ============================================================

// Minutes between two "HH:MM" strings (handles same-day only). Returns 0 if invalid.
function owsMinutesFromTimes(startT, stopT) {
  if (!startT || !stopT) return 0;
  const ps = startT.split(':'), pe = stopT.split(':');
  if (ps.length < 2 || pe.length < 2) return 0;
  const sMin = parseInt(ps[0],10)*60 + parseInt(ps[1],10);
  const eMin = parseInt(pe[0],10)*60 + parseInt(pe[1],10);
  if (isNaN(sMin) || isNaN(eMin)) return 0;
  return Math.max(0, eMin - sMin);
}

// Configured minimum OCM/recirculation test duration (minutes) before a manual OWS discharge.
function owsMinTestMinutes() {
  const s = loadSettings();
  return (s.owsMinTestMinutes != null && !isNaN(s.owsMinTestMinutes)) ? Number(s.owsMinTestMinutes) : 1;
}

// True if any formatted line of the entry matches the predicate.
function _entryLineMatches(entry, pred) {
  return Array.isArray(entry.formatted) && entry.formatted.some(l => l && typeof l.text === 'string' && pred(l.text));
}

// Entries excluding struck-through originals and correction entries — chronologically sorted.
function _activeChronoEntries() {
  return loadEntries()
    .filter(e => !e.correctionEntryId && e.operationType !== 'Correction of Entry (I)')
    .sort((a, b) => {
      const d = new Date(a.date) - new Date(b.date);
      if (d) return d;
      return new Date(a.savedAt || 0) - new Date(b.savedAt || 0);
    });
}

// Detect an OWS/OCM recirculation test entry by line text (covers direct + missed entries).
function _isOcmTestEntry(e) {
  return _entryLineMatches(e, t => /recirculation line/i.test(t) && /test of ocm/i.test(t));
}
// Effective tested duration for an OCM-test entry: stored field, else parsed from "for N minutes".
function _ocmTestMinutes(e) {
  if (e.owsTestMinutes && e.owsTestMinutes > 0) return e.owsTestMinutes;
  let m = 0;
  if (Array.isArray(e.formatted)) {
    e.formatted.forEach(l => {
      const mt = l && typeof l.text === 'string' && l.text.match(/for\s+(\d+)\s+minutes/i);
      if (mt) m = Math.max(m, parseInt(mt[1],10));
    });
  }
  return m;
}
function _isUnsealEntry(e) { return _entryLineMatches(e, t => /unsealed/i.test(t)); }
function _isSealEntry(e)   { return _entryLineMatches(e, t => /sealed/i.test(t) && !/unsealed/i.test(t)); }

// Verify the Code I preparation sequence exists before a manual/auto OWS discharge.
// Returns { ok, missing:[...] }. Considers only entries dated on/before the discharge date.
function checkOwsDischargePrereqs(dischargeDateStr) {
  const minMin = owsMinTestMinutes();
  const cutoff = dischargeDateStr ? new Date(dischargeDateStr) : null;
  const onOrBefore = e => !cutoff || isNaN(cutoff) || (new Date(e.date) <= cutoff);
  const entries = _activeChronoEntries().filter(onOrBefore);

  const hasOcmTest = entries.some(e => _isOcmTestEntry(e) && _ocmTestMinutes(e) >= minMin);
  const hasUnseal  = entries.some(e => _isUnsealEntry(e));

  const missing = [];
  if (!hasOcmTest) missing.push('OCM test (minimum ' + minMin + ' min)');
  if (!hasUnseal)  missing.push('Overboard valve unsealing entry');
  return { ok: missing.length === 0, missing };
}

// Current standing state of the OWS overboard valve: 'sealed' | 'unsealed'.
// Walks all active entries chronologically; default is 'sealed'.
function owsValveState() {
  let state = 'sealed';
  _activeChronoEntries().forEach(e => {
    if (_isUnsealEntry(e)) state = 'unsealed';
    else if (_isSealEntry(e)) state = 'sealed';
  });
  return state;
}

// ============================================================
// WIZARD PREVIEW
// ============================================================
function wizPreview() {
  const op = OPERATIONS.find(o => o.id === wiz.opId);
  const tanks = getTanks();
  const el = document.getElementById('wiz-preview-area');

  // Gather common fields
  const dateVal  = (document.getElementById('wf-date') || {}).value  || fmtDateInput();
  const timeVal  = (document.getElementById('wf-time') || {}).value  || fmtTimeInput();
  const remarks  = (document.getElementById('wf-remarks') || {}).value || '';
  const qty      = parseFloat((document.getElementById('wf-qty') || {}).value) || 0;
  const qtyRet   = parseFloat((document.getElementById('wf-qty-ret') || {}).value);
  const startT   = (document.getElementById('wf-start') || {}).value || '';
  const stopT    = (document.getElementById('wf-stop')  || {}).value || '';

  const getT = id => document.getElementById(id) ? document.getElementById(id).value : '';
  const buildPos = prefix => {
    const latD = getT(prefix+'-latd').trim();
    const latM = getT(prefix+'-latm').trim();
    const ns   = getT(prefix+'-ns');
    const lonD = getT(prefix+'-lond').trim();
    const lonM = getT(prefix+'-lonm').trim();
    const ew   = getT(prefix+'-ew');
    if (!latD && !lonD) return '';
    return (latD||'xx')+' deg '+(latM||'xx')+' min '+ns+', '+(lonD||'xxx')+' deg '+(lonM||'xx')+' min '+ew;
  };
  const srcId   = getT('wf-src');
  const destId  = getT('wf-dest');
  const srcTank = tanks.find(t => t.id === srcId);
  const destTank= tanks.find(t => t.id === destId);

  // Validation gate — block preview if transfer logic errors exist
  const validationErrs = getTransferValidationErrors();
  if (validationErrs.length) {
    // Scroll entry form panel into view
    const formPanel = document.getElementById('entry-form-content');
    if (formPanel) formPanel.scrollTop = 0;
    alert('Please fix the following before generating a preview:\n\n' + validationErrs.map(e => '-- ' + e).join('\n'));
    return;
  }

  // date string
  const dateStr = (() => {
    if (!dateVal) return '';
    const d = new Date(dateVal + 'T00:00:00');
    const M = ['JAN','FEB','MAR','APR','MAY','JUN','JUL','AUG','SEP','OCT','NOV','DEC'];
    return String(d.getDate()).padStart(2,'0') + '-' + M[d.getMonth()] + '-' + d.getFullYear();
  })();

  // Build formatted lines array
  let lines = [];
  let robChanges = []; // { tankId, before, after, reason }

  // ---- FORMAT BY OP ----
  if (op.id === 'C11-inv') {
    const rows = document.querySelectorAll('#wf-inv-rows tr');
    const ceName = (document.getElementById('wf-inv-ce-name') || {}).value || '';
    rows.forEach((row, i) => {
      const robInput     = document.getElementById('wf-inv-rob-' + i);
      const officerInput = document.getElementById('wf-inv-officer-' + i);
      const rankSel      = document.getElementById('wf-inv-rank-' + i);
      if (!robInput) return;
      const tankId  = robInput.getAttribute('data-tankid');
      const prevRob = parseFloat(robInput.getAttribute('data-prevrob')) || 0;
      const cap     = parseFloat(robInput.getAttribute('data-cap'))     || 0;
      const newRob  = robInput.value !== '' ? parseFloat(robInput.value) : prevRob;
      const tank    = tanks.find(t => t.id === tankId);
      const nm      = tank ? tankLabel(tank) : ('Tank ' + (i+1));
      const sec     = '';
      // crew dropdown value is "NAME|RANK" or empty
      const crewVal = officerInput ? officerInput.value : '';
      const crewParts = crewVal.split('|');
      const officer = crewParts[0] ? crewParts[0].trim() : '';
      const rank    = crewParts[1] ? crewParts[1].trim() : '2nd Engineer';
      lines.push({ date: dateStr, code: 'C', item: '11.1', text: nm + sec });
      lines.push({ date: '',      code: '',   item: '11.2', text: fmt3(cap) + ' m3' });
      lines.push({ date: '',      code: '',   item: '11.3', text: fmt3(newRob) + ' m3' });
      // Per-tank signature marker — rendered as sig rows in book view
      lines.push({ _sigTank: true, officer, rank, ceName, entryDate: dateStr });
      if (tank && robInput.value !== '' && newRob !== prevRob) {
        robChanges.push({ tankId: tank.id, before: prevRob, after: newRob, reason: 'Weekly sludge inventory (C.11)' });
      }
    });
    if (!lines.length) lines = [{ date: dateStr, code: 'C', item: '11.1', text: 'No sludge tanks found' }];
  } else if (op.id === 'C11-coll') {
    const cap = parseFloat(getT('wf-cap')) || (srcTank ? srcTank.capacity : 0);
    const rob = qty || (srcTank ? srcTank.rob : 0);
    const src2 = getT('wf-src2') || 'source';
    const qty2 = parseFloat(getT('wf-qty2')) || 0;
    lines = [
      { date: dateStr, code: 'C', item: '11.1', text: srcTank ? tankLabel(srcTank) : 'Sludge Tank' },
      { date: '',      code: '',  item: '11.2', text: fmt2(cap) + ' m3 (capacity)' },
      { date: '',      code: '',  item: '11.3', text: fmt2(rob) + ' m3 retained' },
      { date: '',      code: '',  item: '11.4', text: fmt2(qty2) + ' m3 collected from ' + src2 },
    ];
    if (srcTank && qty2 > 0) {
      const after = parseFloat(srcTank.rob) + qty2;
      robChanges.push({ tankId: srcTank.id, before: srcTank.rob, after, reason: 'Sludge collection (C.11)' });
    }
  } else if (op.id === 'C12-shore') {
    const retained = isNaN(qtyRet) ? Math.max(0, (srcTank ? srcTank.rob : 0) - qty) : qtyRet;
    const receiver = getT('wf-receiver') || 'shore facility';
    const port = getT('wf-port') || 'port';
    lines = [
      { date: dateStr, code: 'C', item: '12.1', text: fmt2(qty) + ' m3 sludge from ' + (srcTank?tankLabel(srcTank):'sludge tank') + ', ' + fmt2(retained) + ' m3 retained, to "' + receiver + '" during port stay (' + port + ')' },
    ];
    if (srcTank) robChanges.push({ tankId: srcTank.id, before: srcTank.rob, after: retained, reason: 'Sludge shore disposal (C.12.1)' });
  } else if (op.id === 'C12-xfer') {
    const retained = isNaN(qtyRet) ? Math.max(0, (srcTank ? srcTank.rob : 0) - qty) : qtyRet;
    const destAfter = destTank ? (parseFloat(destTank.rob) + qty) : 0;
    lines = [
      { date: dateStr, code: 'C', item: '12.2', text: fmt2(qty) + ' m3 sludge transferred from ' + (srcTank?tankLabel(srcTank):'source tank') + ', ' + fmt2(retained) + ' m3 retained, to ' + (destTank?tankLabel(destTank):'destination tank') + ' retained in tank(s) ' + fmt2(destAfter) + ' m3' },
    ];
    if (srcTank)  robChanges.push({ tankId: srcTank.id,  before: srcTank.rob,  after: retained, reason: 'Sludge transfer source (C.12.2)' });
    if (destTank) robChanges.push({ tankId: destTank.id, before: destTank.rob, after: destAfter, reason: 'Sludge transfer dest (C.12.2)' });
  } else if (op.id === 'C12-incin') {
    const retained = isNaN(qtyRet) ? Math.max(0, (srcTank ? srcTank.rob : 0) - qty) : qtyRet;
    const hrs = parseFloat(getT('wf-hours')) || 0;
    lines = [
      { date: dateStr, code: 'C', item: '12.3', text: fmt2(qty) + ' m3 sludge from ' + (srcTank?tankLabel(srcTank):'sludge tank') + ', ' + fmt2(retained) + ' m3 retained, Burned in Incinerator for ' + fmt2(hrs) + ' hours' },
    ];
    if (srcTank) robChanges.push({ tankId: srcTank.id, before: srcTank.rob, after: retained, reason: 'Sludge incineration (C.12.3)' });
  } else if (['C12-boil','C12-evap','C12-regen'].includes(op.id)) {
    const retained = isNaN(qtyRet) ? Math.max(0, (srcTank ? srcTank.rob : 0) - qty) : qtyRet;
    const hrs = parseFloat(getT('wf-hours')) || 0;
    const subText = op.id==='C12-boil' ? fmt2(qty)+' m3 sludge from '+(srcTank?tankLabel(srcTank):'sludge tank')+', '+fmt2(retained)+' m3 retained, Burned in Boiler for '+fmt2(hrs)+' hours'
                  : op.id==='C12-evap' ? fmt2(qty)+' m3 water evaporated from '+(srcTank?tankLabel(srcTank):'sludge tank')+', '+fmt2(retained)+' m3 retained'
                  : fmt2(qty)+' m3 sludge disposed by regeneration — '+getT('wf-regen-fuel')+' / water '+getT('wf-regen-water');
    lines = [{ date: dateStr, code: 'C', item: '12.4', text: subText }];
    if (srcTank) robChanges.push({ tankId: srcTank.id, before: srcTank.rob, after: retained, reason: 'Sludge disposal (C.12.4)' });
  } else if (op.id === 'D-tank') {
    const wellInputs = wiz.bilgeWellInputs || [];
    const totalVol = wellInputs.reduce((s, r) => s + (parseFloat(r.vol) || 0), 0);
    const allTanksList = getTanks();
    const wellNames = wellInputs
      .filter(r => parseFloat(r.vol) > 0)
      .map(r => {
        const t = allTanksList.find(x => x.id === r.tankId);
        const nm = t ? tankLabel(t) : (r.tankId === '__manual__' ? 'Bilge Well' : 'Bilge Well');
        return nm + ' ' + parseFloat(r.vol).toFixed(3) + ' m3';
      });
    const destAfter = destTank ? (parseFloat(destTank.rob) + totalVol) : totalVol;
    const wellListText = wellNames.length > 1
      ? wellNames.join(', ')
      : (wellNames[0] || 'engine-room bilge wells');
    const startDateV = getT('wf-start-date');
    const stopDateV  = getT('wf-stop-date');
    const fmtDateLabel = v => {
      if (!v) return '';
      const d = new Date(v + 'T00:00:00');
      const mon = ['JAN','FEB','MAR','APR','MAY','JUN','JUL','AUG','SEP','OCT','NOV','DEC'];
      return String(d.getDate()).padStart(2,'0') + '-' + mon[d.getMonth()] + '-' + d.getFullYear() + ' ';
    };
    const startLabel = fmtDateLabel(startDateV) + (startT||'hh:mm') + ' H LT';
    const stopLabel  = fmtDateLabel(stopDateV)  + (stopT||'hh:mm')  + ' H LT';
    const bilgePumpName = (()=>{ const eq=loadEquipment().find(e=>e.type==='bilge'); return eq?eq.name:'Bilge Transfer Pump'; })();
    const bilgeHrs = parseFloat(getT('wf-hours')) || 0;
    lines = [
      { date: dateStr, code: 'D', item: '13',   text: fmt2(totalVol) + ' m3 bilge water from engine-room bilge wells, pump: ' + bilgePumpName },
      { date: '',      code: '',  item: '14',   text: 'Start: ' + startLabel + ', stop: ' + stopLabel },
      { date: '',      code: '',  item: '15.3', text: 'To ' + (destTank ? tankLabel(destTank) : '[Name of sec. 3.3 Tank & Designation]') + ', retained in tank(s) ' + fmt2(destAfter) + ' m3' },
    ];
    if (destTank) robChanges.push({ tankId: destTank.id, before: destTank.rob, after: destAfter, reason: 'Bilge well transfer to holding tank (Code D)' });
  } else if (['D-sludge','D-slop'].includes(op.id)) {
    const destAfter = destTank ? (parseFloat(destTank.rob) + qty) : qty;
    const srcCap = parseFloat(getT('wf-cap')) || (srcTank ? srcTank.capacity : 0);
    const retained = isNaN(qtyRet) ? (srcTank && !srcTank.isBilgeWell ? Math.max(0, srcTank.rob - qty) : 0) : qtyRet;
    const item15 = op.id === 'D-sludge' ? '15.2' : '15.3';
    const startDateV2 = getT('wf-start-date');
    const stopDateV2  = getT('wf-stop-date');
    const fmtDL = v => {
      if (!v) return '';
      const d = new Date(v + 'T00:00:00');
      const mon = ['JAN','FEB','MAR','APR','MAY','JUN','JUL','AUG','SEP','OCT','NOV','DEC'];
      return String(d.getDate()).padStart(2,'0') + '-' + mon[d.getMonth()] + '-' + d.getFullYear() + ' ';
    };
    const startL2 = fmtDL(startDateV2) + (startT||'hh:mm') + ' H LT';
    const stopL2  = fmtDL(stopDateV2)  + (stopT||'hh:mm')  + ' H LT';
    lines = [
      { date: dateStr, code: 'D', item: '13',   text: fmt2(qty) + ' m3 bilge water from ' + (srcTank?tankLabel(srcTank):'Engine Room Bilge Wells') + (srcCap ? ' Capacity ' + fmt2(srcCap) + ' m3' : '') + ', ' + fmt2(retained) + ' m3 retained' },
      { date: '',      code: '',  item: '14',   text: 'start: ' + startL2 + ', stop: ' + stopL2 },
      { date: '',      code: '',  item: item15, text: 'to ' + (destTank?tankLabel(destTank):'destination tank') + '; retained in tank ' + fmt2(destAfter) + ' m3' },
    ];
    if (srcTank && !srcTank.isBilgeWell) robChanges.push({ tankId: srcTank.id, before: srcTank.rob, after: retained, reason: 'Bilge transfer source (Code D)' });
    if (destTank) robChanges.push({ tankId: destTank.id, before: destTank.rob, after: destAfter, reason: 'Bilge transfer destination (Code D)' });
  } else if (op.id === 'D-ows') {
    const posStart = buildPos('wf-pos-start') || 'xx deg xx min N/S, xxx deg xx min E/W';
    const posStop  = buildPos('wf-pos-stop')  || 'xx deg xx min N/S, xxx deg xx min E/W';
    const srcCap = parseFloat(getT('wf-cap')) || (srcTank ? srcTank.capacity : 0);
    const retained = srcTank && !srcTank.isBilgeWell ? Math.max(0, srcTank.rob - qty) : 0;
    const startDateV3 = getT('wf-start-date');
    const stopDateV3  = getT('wf-stop-date');
    const fmtDL3 = v => {
      if (!v) return '';
      const d = new Date(v + 'T00:00:00');
      const mon = ['JAN','FEB','MAR','APR','MAY','JUN','JUL','AUG','SEP','OCT','NOV','DEC'];
      return String(d.getDate()).padStart(2,'0') + '-' + mon[d.getMonth()] + '-' + d.getFullYear() + ' ';
    };
    const startL3 = fmtDL3(startDateV3) + (startT||'hh:mm') + ' H LT';
    const stopL3  = fmtDL3(stopDateV3)  + (stopT||'hh:mm')  + ' H LT';
    lines = [
      { date: dateStr, code: 'D', item: '13',   text: fmt2(qty) + ' m3 bilge water from ' + (srcTank?tankLabel(srcTank):'bilge tank') + ' Capacity ' + fmt2(srcCap) + ' m3, ' + fmt2(retained) + ' m3 retained' },
      { date: '',      code: '',  item: '14',   text: 'start: ' + startL3 + ', stop: ' + stopL3 },
      { date: '',      code: '',  item: '15.1', text: 'Through 15 ppm equipment overboard' },
      { date: '',      code: '',  item: '',     text: 'Position start: ' + posStart },
      { date: '',      code: '',  item: '',     text: 'Position stop: ' + posStop },
    ];
    if (srcTank && !srcTank.isBilgeWell) robChanges.push({ tankId: srcTank.id, before: srcTank.rob, after: retained, reason: 'OWS overboard discharge (Code D)' });
  } else if (['E-ows','E-tank'].includes(op.id)) {
    const pos = buildPos('wf-pos-start') || '';
    const destAfter = destTank ? (parseFloat(destTank.rob) + qty) : qty;
    if (op.id === 'E-ows') {
      lines = [
        { date: dateStr, code: 'E', item: '16', text: 'Pump start ' + (startT||'hh:mm') + ' H LT' + (pos ? ' at ' + pos : '') + ' from ' + (srcTank?tankLabel(srcTank):'bilge tank') },
        { date: '',      code: '',  item: '18', text: 'Stop ' + (stopT||'hh:mm') + ' H LT' },
      ];
    } else {
      lines = [
        { date: dateStr, code: 'E', item: '17', text: 'Transfer start ' + (startT||'hh:mm') + ' H LT to ' + (destTank?tankLabel(destTank):'holding tank') },
        { date: '',      code: '',  item: '18', text: 'Stop ' + (stopT||'hh:mm') + ' H LT' },
      ];
      if (destTank) robChanges.push({ tankId: destTank.id, before: destTank.rob, after: destAfter, reason: 'Auto bilge transfer destination (Code E)' });
    }
  } else if (['F-fail','F-rest'].includes(op.id)) {
    lines = [
      { date: dateStr, code: 'F', item: '19', text: (startT || 'hh:mm') + ' H LT (time of failure)' },
      { date: '',      code: '',  item: '20', text: (stopT ? stopT + ' H LT' : 'hh:mm H LT') + ' (time restored)' },
      { date: '',      code: '',  item: '21', text: getT('wf-reason') || 'Reason for failure' },
    ];
    if (getT('wf-equip')) lines.push({ date:'',code:'',item:'',text:'Equipment: ' + getT('wf-equip') });
  } else if (op.id === 'G-acc') {
    lines = [
      { date: dateStr, code: 'G', item: '22', text: (startT || 'hh:mm') + ' H LT' },
      { date: '',      code: '',  item: '23', text: 'Place or Position: ' + (buildPos('wf-pos-start') || 'unknown') },
      { date: '',      code: '',  item: '24', text: 'Type: ' + (getT('wf-reason')||'unknown') + (qty ? ', Approx. ' + fmt2(qty) + ' m3' : '') },
      { date: '',      code: '',  item: '25', text: 'Circumstances: ' + (remarks || 'describe circumstances') },
    ];
  } else if (op.id.startsWith('H-')) {
    const grade   = getT('wf-grade') || op.id.replace('H-','').toUpperCase();
    const port    = (getT('wf-port') || 'PORT NAME').toUpperCase();
    const iso     = getT('wf-iso')   || '';
    const sulphur = getT('wf-sulphur') || '';
    const isLube  = op.id === 'H-lube';
    const itemNum = isLube ? '26.4' : '26.3';
    // Format datetime: "31-MAY-2025-21:00 H LT"
    function fmtBunkDT(dtVal) {
      if (!dtVal) return 'dd-MONTH-yyyy-hh:mm H LT';
      const d = new Date(dtVal);
      const M = ['JAN','FEB','MAR','APR','MAY','JUN','JUL','AUG','SEP','OCT','NOV','DEC'];
      return String(d.getDate()).padStart(2,'0') + '-' + M[d.getMonth()] + '-' + d.getFullYear()
        + '-' + String(d.getHours()).padStart(2,'0') + ':' + String(d.getMinutes()).padStart(2,'0') + ' H LT';
    }
    let tankLines = '';
    (wiz.bunkTanks||[]).forEach(bt => {
      const tk = tanks.find(t=>t.id===bt.tankId);
      if (tk) {
        tankLines += '\n  ' + parseFloat(bt.qtyAdded||0).toFixed(3) + ' MT added to ' + tankLabel(tk) + ' now containing ' + parseFloat(bt.qtyNow||0).toFixed(3) + ' MT.';
        const newRob = parseFloat(bt.qtyNow) || 0;
        robChanges.push({ tankId: tk.id, before: tk.rob, after: newRob, reason: 'Bunkering ' + grade + ' (Code H)' });
      }
    });
    const gradeStr = isLube ? grade : (iso ? 'ISO-8754 ' + grade + (sulphur ? ' ' + sulphur + '% S' : '') : grade);
    lines = [
      { date: dateStr, code: 'H', item: '26.1', text: port },
      { date: '',      code: '',  item: '26.2', text: 'Start ' + fmtBunkDT(startT) + ',  Stop ' + fmtBunkDT(stopT) },
      { date: '',      code: '',  item: itemNum, text: fmt2(qty) + ' MT of ' + gradeStr + ' bunkered in tanks:' + tankLines },
    ];
  } else if (op.id === 'I-cargo') {
    const destAfter = destTank ? (parseFloat(destTank.rob) + qty) : qty;
    lines = [
      { date: dateStr, code: 'I', item: '', text: fmt2(qty) + ' m3 oily bilge water from Cargo Hold bilge holding tank to ' + (destTank?tankLabel(destTank):'holding tank') },
    ];
    if (destTank) robChanges.push({ tankId: destTank.id, before: destTank.rob, after: destAfter, reason: 'Cargo hold bilge (Code I)' });
  } else if (op.id === 'I-missed') {
    const origDateStr = (() => {
      const v = getT('wf-orig-date');
      if (!v) return 'original date';
      const d = new Date(v + 'T00:00:00');
      const M = ['JAN','FEB','MAR','APR','MAY','JUN','JUL','AUG','SEP','OCT','NOV','DEC'];
      return String(d.getDate()).padStart(2,'0') + '-' + M[d.getMonth()] + '-' + d.getFullYear();
    })();
    const missedOpId = getT('wf-missed-op');
    const missedOp = OPERATIONS.find(o => o.id === missedOpId);
    // Build the actual operation lines using origDateStr in place of dateStr
    let missedLines = [];
    if (missedOp) {
      // Gather fields shared with missed sub-form
      const mQty    = parseFloat((document.getElementById('wf-qty')||{}).value) || 0;
      const mQtyRet = parseFloat((document.getElementById('wf-qty-ret')||{}).value);
      const mSrcId  = getT('wf-src');
      const mDestId = getT('wf-dest');
      const mSrcTank  = tanks.find(t => t.id === mSrcId);
      const mDestTank = tanks.find(t => t.id === mDestId);
      const mRet = isNaN(mQtyRet) ? Math.max(0, (mSrcTank ? mSrcTank.rob : 0) - mQty) : mQtyRet;
      const mStart = getT('wf-start'); const mStop = getT('wf-stop');
      function mFmtDT(v) {
        if (!v) return '';
        const d = new Date(v);
        const M = ['JAN','FEB','MAR','APR','MAY','JUN','JUL','AUG','SEP','OCT','NOV','DEC'];
        return String(d.getDate()).padStart(2,'0')+'-'+M[d.getMonth()]+'-'+d.getFullYear()+'-'+String(d.getHours()).padStart(2,'0')+':'+String(d.getMinutes()).padStart(2,'0')+' H LT';
      }
      if (missedOp.id === 'C12-xfer') {
        const destAfter = mDestTank ? parseFloat(mDestTank.rob) + mQty : mQty;
        missedLines = [{ date: origDateStr, code: missedOp.code, item: '12.2', text: fmt2(mQty)+' m3 sludge transferred from '+(mSrcTank?tankLabel(mSrcTank):'source tank')+', '+fmt2(mRet)+' m3 retained, to '+(mDestTank?tankLabel(mDestTank):'destination tank')+' retained in tank(s) '+fmt2(destAfter)+' m3' }];
      } else if (missedOp.id === 'C12-shore') {
        missedLines = [{ date: origDateStr, code: missedOp.code, item: '12.1', text: fmt2(mQty)+' m3 sludge from '+(mSrcTank?tankLabel(mSrcTank):'sludge tank')+', '+fmt2(mRet)+' m3 retained, to "'+getT('wf-receiver')+'" during port stay ('+getT('wf-port')+')' }];
      } else if (missedOp.id === 'C12-incin') {
        missedLines = [{ date: origDateStr, code: missedOp.code, item: '12.3', text: fmt2(mQty)+' m3 sludge from '+(mSrcTank?tankLabel(mSrcTank):'sludge tank')+', '+fmt2(mRet)+' m3 retained, Burned in Incinerator for '+(parseFloat(getT('wf-hours'))||0)+' hours' }];
      } else if (missedOp.id === 'C12-boil') {
        missedLines = [{ date: origDateStr, code: missedOp.code, item: '12.4', text: fmt2(mQty)+' m3 sludge from '+(mSrcTank?tankLabel(mSrcTank):'sludge tank')+', '+fmt2(mRet)+' m3 retained, Burned in Boiler for '+(parseFloat(getT('wf-hours'))||0)+' hours' }];
      } else if (missedOp.id === 'C12-evap') {
        missedLines = [{ date: origDateStr, code: missedOp.code, item: '12.4', text: fmt2(mQty)+' m3 water evaporated from '+(mSrcTank?tankLabel(mSrcTank):'sludge tank')+', '+fmt2(mRet)+' m3 retained' }];
      } else if (missedOp.id === 'C12-regen') {
        missedLines = [{ date: origDateStr, code: missedOp.code, item: '12.4', text: fmt2(mQty)+' m3 sludge disposed by regeneration -- '+getT('wf-regen-fuel')+' / water '+getT('wf-regen-water') }];
      } else if (missedOp.id === 'C11-inv') {
        // Inventory: read from wf-inv-rows table rendered in #missed-sub-form
        const iRows = document.querySelectorAll('#wf-inv-rows tr');
        iRows.forEach((row, i) => {
          const robInput = document.getElementById('wf-inv-rob-'+i);
          if (!robInput) return;
          const tankId = robInput.getAttribute('data-tankid');
          const prevRob = parseFloat(robInput.getAttribute('data-prevrob'))||0;
          const cap = parseFloat(robInput.getAttribute('data-cap'))||0;
          const newRob = robInput.value !== '' ? parseFloat(robInput.value) : prevRob;
          const t2 = tanks.find(t3 => t3.id === tankId);
          const nm2 = t2 ? tankLabel(t2) : ('Tank '+(i+1));
          missedLines.push({ date: origDateStr, code: missedOp.code, item: '11.1', text: nm2 });
          missedLines.push({ date: '', code: '', item: '11.2', text: fmt3(cap)+' m3' });
          missedLines.push({ date: '', code: '', item: '11.3', text: fmt3(newRob)+' m3' });
        });
        if (!missedLines.length) missedLines = [{ date: origDateStr, code: missedOp.code, item: '11.1', text: 'No sludge tanks' }];
      } else if (missedOp.id === 'C11-coll') {
        missedLines = [
          { date: origDateStr, code: missedOp.code, item: '11.1', text: (mSrcTank?tankLabel(mSrcTank):'Sludge Tank') },
          { date: '', code: '', item: '11.3', text: fmt2(mQty)+' m3 retained' },
          { date: '', code: '', item: '11.4', text: fmt2(parseFloat(getT('wf-qty2'))||0)+' m3 collected from '+(getT('wf-src2')||'source') },
        ];
      } else if (missedOp.id === 'D-tank') {
        const dAfter = mDestTank ? parseFloat(mDestTank.rob) + mQty : mQty;
        missedLines = [
          { date: origDateStr, code: missedOp.code, item: '13',   text: fmt2(mQty)+' m3 bilge water from engine-room bilge wells,' },
          { date: '', code: '', item: '14',   text: 'Start: '+(mStart||'hh:mm')+', stop: '+(mStop||'hh:mm') },
          { date: '', code: '', item: '15.3', text: 'To '+(mDestTank?tankLabel(mDestTank):'holding tank')+', retained in tank(s) '+fmt2(dAfter)+' m3' },
        ];
      } else if (['D-ows','D-sludge','D-slop'].includes(missedOp.id)) {
        const dAfter2 = mDestTank ? parseFloat(mDestTank.rob) + mQty : mQty;
        const item15 = missedOp.id==='D-sludge'?'15.2':'15.3';
        missedLines = [
          { date: origDateStr, code: missedOp.code, item: '13',   text: fmt2(mQty)+' m3 bilge water from '+(mSrcTank?tankLabel(mSrcTank):'source')+', '+fmt2(mRet)+' m3 retained' },
          { date: '', code: '', item: '14',   text: 'start: '+(mStart||'hh:mm')+' H LT, stop: '+(mStop||'hh:mm')+' H LT' },
          { date: '', code: '', item: item15, text: missedOp.id==='D-ows'?'overboard via OWS':'to '+(mDestTank?tankLabel(mDestTank):'destination tank')+'; retained in tank '+fmt2(dAfter2)+' m3' },
        ];
      } else if (['E-ows','E-tank'].includes(missedOp.id)) {
        const eAfter = mDestTank ? parseFloat(mDestTank.rob) + mQty : mQty;
        missedLines = [
          { date: origDateStr, code: missedOp.code, item: '16.1', text: fmt2(mQty)+' m3 bilge water from '+(mSrcTank?tankLabel(mSrcTank):'source')+', '+fmt2(mRet)+' m3 retained' },
          { date: '', code: '', item: '16.2', text: 'Start: '+(mStart||'hh:mm')+', Stop: '+(mStop||'hh:mm') },
          { date: '', code: '', item: missedOp.id==='E-tank'?'16.3':'16.4', text: missedOp.id==='E-ows'?'Overboard via OWS, effluent <15 ppm':'To '+(mDestTank?tankLabel(mDestTank):'holding tank')+' retained '+fmt2(eAfter)+' m3' },
        ];
      } else if (missedOp.id === 'F-fail') {
        missedLines = [{ date: origDateStr, code: missedOp.code, item: '19', text: 'Failure of '+(getT('wf-equip')||'equipment')+' -- '+(remarks||'description') }];
      } else if (missedOp.id === 'F-rest') {
        missedLines = [{ date: origDateStr, code: missedOp.code, item: '20', text: 'Restoration of '+(getT('wf-equip')||'equipment')+' -- '+(remarks||'description') }];
      } else if (missedOp.id === 'G-acc') {
        missedLines = [
          { date: origDateStr, code: missedOp.code, item: '22', text: remarks||'Description of accidental discharge' },
          { date: '', code: '', item: '23', text: 'Estimated quantity: '+fmt2(mQty)+' m3, position: '+(getT('wf-port')||'position') },
          { date: '', code: '', item: '24', text: 'Steps taken: '+(getT('wf-steps')||'see remarks') },
        ];
      } else if (missedOp.id.startsWith('H-')) {
        const hRows = document.querySelectorAll('#wf-bunk-tanks-list .bunk-tank-row');
        let hTotQty = 0, hBunkText = [];
        hRows.forEach(row => {
          const sel = row.querySelector('select'); const qa = row.querySelector('.bunk-qa'); const qn = row.querySelector('.bunk-qn');
          const t = tanks.find(t2 => t2.id === (sel?sel.value:''));
          const qa2 = parseFloat(qa?qa.value:0)||0; const qn2 = parseFloat(qn?qn.value:0)||0;
          if (t && qa2>0) { hTotQty+=qa2; hBunkText.push(fmt2(qa2)+' MT to '+tankLabel(t)+', now containing '+fmt2(qn2)+' MT'); }
        });
        const hGrade = getT('wf-iso')||missedOp.id.replace('H-','').toUpperCase();
        missedLines = [
          { date: origDateStr, code: missedOp.code, item: '26.1', text: 'Received '+fmt2(hTotQty)+' MT '+hGrade+' from "'+getT('wf-receiver')+'" in '+getT('wf-port') },
          { date: '', code: '', item: '26.2', text: hBunkText.join('; ')||'see tank details' },
          { date: '', code: '', item: '26.4', text: 'Start: '+mFmtDT(mStart)+' Stop: '+mFmtDT(mStop) },
        ];
      } else if (missedOp.id === 'I-cargo') {
        const dAfterC = mDestTank ? parseFloat(mDestTank.rob) + mQty : mQty;
        missedLines = [{ date: origDateStr, code: missedOp.code, item: '', text: fmt2(mQty)+' m3 oily bilge water from Cargo Hold bilge holding tank to '+(mDestTank?tankLabel(mDestTank):'holding tank') }];
      } else if (missedOp.id === 'I-debunk') {
        missedLines = [{ date: origDateStr, code: missedOp.code, item: '', text: fmt2(mQty)+' MT '+(getT('wf-iso')||'')+' de-bunkered from '+(mSrcTank?tankLabel(mSrcTank):'tank')+' now containing '+fmt2(mRet)+' MT. De-bunkered to "'+getT('wf-receiver')+'" in '+getT('wf-port')+(mFmtDT(mStart)?' Start '+mFmtDT(mStart):'')+(mFmtDT(mStop)?' Stop '+mFmtDT(mStop):'') }];
      } else if (missedOp.id === 'I-seal') {
        missedLines = [{ date: origDateStr, code: missedOp.code, item: '', text: 'Overboard valve '+getT('wf-valve')+' from 15 ppm bilge water separator unit sealed, seal No.: '+getT('wf-seal') }];
      } else if (missedOp.id === 'I-unseal') {
        missedLines = [{ date: origDateStr, code: missedOp.code, item: '', text: 'Overboard valve '+getT('wf-valve')+' from 15 ppm bilge water separator unit unsealed for '+getT('wf-reason')+', seal No.: '+getT('wf-seal') }];
      } else if (missedOp.id === 'I-inv') {
        missedLines = [{ date: origDateStr, code: missedOp.code, item: '', text: 'Bilge Holding Tank '+(mSrcTank?tankLabel(mSrcTank):'tank')+': ROB '+fmt2(mQty)+' m3' }];
      } else if (missedOp.id === 'I-owstest') {
        const mOwsMins = owsMinutesFromTimes(mStart, mStop);
        missedLines = [{ date: origDateStr, code: missedOp.code, item: '', text: 'Test of OWS through recirculation line for '+(mOwsMins||'__')+' minutes and test of OCM with satisfactory results.' }];
        if (remarks) missedLines.push({ date:'', code:'', item:'', text: remarks });
      } else if (missedOp.id === 'I-bunksample') {
        missedLines = [{ date: origDateStr, code: missedOp.code, item: '', text: remarks||'Bunker sample disposal' }];
      } else if (missedOp.id === 'I-bilgshore') {
        missedLines = [{ date: origDateStr, code: missedOp.code, item: '', text: fmt2(mQty)+' m3 oily bilge water from '+(mSrcTank?tankLabel(mSrcTank):'holding tank')+', '+fmt2(mRet)+' m3 retained, to shore reception "'+getT('wf-receiver')+'" in '+getT('wf-port') }];
      } else {
        missedLines = [{ date: origDateStr, code: missedOp.code, item: '', text: remarks||'Description of missed operation' }];
      }
    } else {
      missedLines = [{ date: origDateStr, code: '', item: '', text: remarks||'Description of missed operation' }];
    }
    lines = [
      { date: dateStr,   code: 'I', item: '', text: 'Entry pertaining to an earlier missed operational entry' },
      ...missedLines,
    ];
  } else if (op.id === 'I-debunk') {
    const iso = getT('wf-iso') || '';
    const recv = getT('wf-receiver') || 'receiver';
    const port = getT('wf-port') || 'port';
    const retained = isNaN(qtyRet) ? Math.max(0, (srcTank ? srcTank.rob : 0) - qty) : qtyRet;
    function fmtDebunkDT(dtVal) {
      if (!dtVal) return '';
      const d = new Date(dtVal);
      const M = ['JAN','FEB','MAR','APR','MAY','JUN','JUL','AUG','SEP','OCT','NOV','DEC'];
      return String(d.getDate()).padStart(2,'0') + '-' + M[d.getMonth()] + '-' + d.getFullYear()
        + '-' + String(d.getHours()).padStart(2,'0') + ':' + String(d.getMinutes()).padStart(2,'0') + ' H LT';
    }
    const startDT = fmtDebunkDT(startT);
    const stopDT  = fmtDebunkDT(stopT);
    lines = [
      { date: dateStr, code: 'I', item: '', text: fmt2(qty) + ' MT ' + iso + ' de-bunkered from ' + (srcTank?tankLabel(srcTank):'tank') + ' now containing ' + fmt2(retained) + ' MT. De-bunkered to "' + recv + '" in ' + port + (startDT ? ' Start ' + startDT : '') + (stopDT ? ' Stop ' + stopDT : '') },
    ];
    if (srcTank) robChanges.push({ tankId: srcTank.id, before: srcTank.rob, after: retained, reason: 'De-bunkering (Code I)' });
  } else if (op.id === 'I-seal') {
    lines = [
      { date: dateStr, code: 'I', item: '', text: 'Overboard valve ' + (getT('wf-valve')||'valve') + ' from 15 ppm bilge water separator unit sealed, seal No.: ' + (getT('wf-seal')||'xxxxxxx') },
    ];
  } else if (op.id === 'I-unseal') {
    lines = [
      { date: dateStr, code: 'I', item: '', text: 'Overboard valve ' + (getT('wf-valve')||'valve') + ' from 15 ppm bilge water separator unit unsealed for ' + (getT('wf-reason')||'normal operation') + ', seal No.: ' + (getT('wf-seal')||'xxxxxxx') },
    ];
  } else if (op.id === 'I-inv') {
    const cap = parseFloat(getT('wf-cap')) || (srcTank ? srcTank.capacity : 0);
    const rob2 = qty || (srcTank ? srcTank.rob : 0);
    lines = [
      { date: dateStr, code: 'I', item: '', text: 'Weekly Inventory of Bilge Holding Tank' + (srcTank ? ' ' + tankLabel(srcTank) : '') + '; Capacity ' + fmt3(cap) + ' m3, ' + fmt3(rob2) + ' m3 retained' },
    ];
  } else if (op.id === 'I-owstest') {
    const owsMins = parseInt(getT('wf-duration'), 10);
    lines = [
      { date: dateStr, code: 'I', item: '', text: 'Test of OWS through recirculation line for ' + (owsMins || '__') + ' minutes and test of OCM with satisfactory results.' },
    ];
    if (remarks) lines.push({ date:'',code:'',item:'',text: remarks });
  } else if (op.id === 'I-bunksample') {
    const grade  = getT('wf-grade')  || 'fuel oil';
    const bdnRef = getT('wf-seal')   || '';
    const method = getT('wf-reason') || 'disposed to sludge tank';
    lines = [
      { date: dateStr, code: 'I', item: '', text: 'Bunker sample (' + grade + ')' + (bdnRef ? ' BDN/Ref: ' + bdnRef : '') + '; ' + fmt2(qty) + ' liters ' + method },
    ];
  } else if (op.id === 'I-bilgshore') {
    const recv = getT('wf-receiver') || 'shore reception facility';
    const port = getT('wf-port')     || 'port';
    const retained = isNaN(qtyRet) ? Math.max(0, (srcTank ? srcTank.rob : 0) - qty) : qtyRet;
    lines = [
      { date: dateStr, code: 'I', item: '', text: fmt2(qty) + ' m3 bilge water from ' + (srcTank?tankLabel(srcTank):'bilge holding tank') + ', ' + fmt2(retained) + ' m3 retained, to ' + recv + ' during port stay ' + port },
    ];
    if (srcTank) robChanges.push({ tankId: srcTank.id, before: srcTank.rob, after: retained, reason: 'Bilge shore reception (Code I)' });
  } else if (op.id === 'M-correction') {
    const corrEntryId = getT('wf-corr-entry');
    const corrCEName  = getT('wf-corr-ce') || 'Chief Engineer';
    if (!corrEntryId) { alert('Please select an entry to correct.'); return; }
    const allEnt = loadEntries();
    const corrEntry = allEnt.find(e => e.id === corrEntryId);
    if (!corrEntry) { alert('Entry not found.'); return; }
    // Mark original as corrected immediately
    corrEntry.corrected   = true;
    corrEntry.correctedBy = corrCEName;
    corrEntry.correctedAt = dateStr;
    // Reverse original entry's ROB changes (nullify the incorrect entry, restore tanks
    // to the state they were in before the wrong entry was made). The new corrected
    // re-entry will then compute its own ROB delta from the restored state.
    const reversedTanks = [];
    if (corrEntry.robChg && corrEntry.robChg.length) {
      const tanks = getTanks();
      corrEntry.robChg.forEach(rc => {
        const t = tanks.find(x => x.id === rc.tankId);
        if (!t) return;
        t.rob = rc.before;
        if (!t.history) t.history = [];
        t.history.push({
          date:   now(),
          before: rc.after,
          after:  rc.before,
          reason: 'Reversed (entry corrected): ' + (corrEntry.operationType || ''),
          type:   'correction-reverse',
        });
        if (t.history.length > 20) t.history = t.history.slice(-20);
        reversedTanks.push(t.name);
      });
      saveTanks(tanks);
    }
    // Mark the original entry's ROB changes as reversed so they aren't double-applied
    corrEntry.robChgReversed = true;
    saveEntries(allEnt);
    renderLog();
    renderTankEditor && renderTankEditor();
    // Now launch the same operation's form so user re-enters correct data
    const origOpId = OPERATIONS.find(o => o.label === corrEntry.operationType)?.id || corrEntry.code;
    if (!origOpId || !OPERATIONS.find(o => o.id === origOpId)) {
      alert('Cannot find the original operation type to re-enter. Entry has been struck through. Please add the correct entry manually.');
      wizReset();
      return;
    }
    _activeOp = origOpId;
    wiz = { opId: origOpId, isCorrectionOf: corrEntryId, corrCEName };
    _formDirty = false;
    renderCatList();
    renderActList(_activeCat);
    renderFormPanel(origOpId);
    // Inject a banner at top of the form to remind user this is a correction
    const fc = document.getElementById('entry-form-content');
    const banner = document.createElement('div');
    banner.style.cssText = 'max-width:720px;background:rgba(220,53,69,0.1);border:1px solid rgba(220,53,69,0.4);border-radius:6px;padding:10px 14px;margin-bottom:14px;font-family:var(--sans);font-size:12px;color:#c0392b;';
    banner.innerHTML = '<strong>Correction of Entry:</strong> The incorrect entry has been struck through. Now re-enter the <strong>correct</strong> data below. This new entry will appear immediately after the struckthrough one in the Record Book.';
    fc.querySelector('.entry-form-inner')?.prepend(banner);
    return;
  }

  if (remarks && !['G-acc','I-missed','M-correction','I-owstest'].includes(op.id)) {
    lines.push({ date:'', code:'', item:'', text:'Remarks: ' + remarks });
  }

  // Save to wiz state for confirmation
  wiz.lines    = lines;
  wiz.robChg   = robChanges;
  wiz.dateStr  = dateStr;
  wiz.timeStr  = timeVal;
  wiz.remarks  = remarks;
  // OWS recirculation/OCM test duration — used by the manual-discharge prerequisite gate
  wiz.owsTestMinutes = 0;
  if (op.id === 'I-owstest') {
    const _d = parseInt(getT('wf-duration'), 10);
    wiz.owsTestMinutes = isNaN(_d) ? 0 : _d;
  } else if (op.id === 'I-missed' && getT('wf-missed-op') === 'I-owstest') {
    wiz.owsTestMinutes = owsMinutesFromTimes(getT('wf-start'), getT('wf-stop')) || 0;
  }

  // Item D — capacity overflow check. Block entries that would push a tank
  // above 100% capacity; warn (but allow) those landing in the 90-100% band.
  let capacityBlock = '';
  const capacityWarnings = [];
  if (robChanges.length) {
    const tanksNow = getTanks();
    robChanges.forEach(rc => {
      const tk = tanksNow.find(x => x.id === rc.tankId);
      if (!tk || !tk.capacity || tk.capacity <= 0) return;
      const cap = tk.capacity;
      const after = rc.after;
      if (after > cap) {
        capacityWarnings.push({
          type: 'block',
          tank: tk.name,
          pct: (after/cap*100),
          after, cap, unit: tk.unit
        });
      } else if (after >= cap * 0.9) {
        capacityWarnings.push({
          type: 'warn',
          tank: tk.name,
          pct: (after/cap*100),
          after, cap, unit: tk.unit
        });
      }
    });
  }
  wiz.capacityWarnings = capacityWarnings;
  const hasBlock = capacityWarnings.some(w => w.type === 'block');
  if (capacityWarnings.length) {
    const items = capacityWarnings.map(w => {
      const color = w.type === 'block' ? '#c70042' : '#a86d00';
      const label = w.type === 'block' ? 'OVER CAPACITY' : '90%+';
      const pct = w.pct.toFixed(1);
      return `<div style="font-family:var(--mono);font-size:12px;margin-bottom:4px;color:${color};">
        <strong>${label}</strong> &mdash; ${esc(w.tank)}: ${fmt2(w.after)} / ${fmt2(w.cap)} ${esc(w.unit)} (${pct}%)
      </div>`;
    }).join('');
    const bgColor = hasBlock ? 'rgba(224,0,85,0.08)' : 'rgba(246,173,85,0.12)';
    const borderColor = hasBlock ? '#e05' : '#f6ad55';
    capacityBlock = `<div style="margin-bottom:12px;padding:10px 12px;background:${bgColor};border-left:3px solid ${borderColor};border-radius:3px;">
      <strong style="color:${hasBlock?'#c70042':'#a86d00'};">${hasBlock ? 'Capacity violation' : 'Capacity warning'}</strong>
      <div style="margin-top:6px;">${items}</div>
      ${hasBlock ? '<div style="margin-top:8px;font-size:12px;color:#666;">Reduce the transferred volume or transfer to a different tank. This entry cannot be saved while the destination exceeds 100% capacity.</div>' : ''}
    </div>`;
  }

  // Item E — pump rate validation for OWS overboard + sludge shore transfer.
  // Effective rate (volume / duration) must not exceed configured pump capacity.
  let rateBlock = '';
  let rateViolation = false;
  (function() {
    let pumpType = '';
    if (op.id === 'D-ows' || op.id === 'E-ows') pumpType = 'ows';
    else if (op.id === 'C12-shore') pumpType = 'sludge';
    if (!pumpType) return;
    if (!qty || !startT || !stopT) return;
    // Compute hours; honor date fields if present, else assume same-day
    const startDate = (document.getElementById('wf-start-date') || {}).value || dateVal;
    const stopDate  = (document.getElementById('wf-stop-date')  || {}).value || dateVal;
    let hours = 0;
    try {
      const s = new Date(startDate + 'T' + startT);
      const e = new Date(stopDate + 'T' + stopT);
      hours = (e - s) / 3600000;
    } catch(e) { hours = 0; }
    if (!hours || hours <= 0) return;
    const check = validateTransferRate(pumpType, qty, hours);
    if (check.ok) return;
    rateViolation = true;
    rateBlock = `<div style="margin-bottom:12px;padding:10px 12px;background:rgba(224,0,85,0.08);border-left:3px solid #e05;border-radius:3px;">
      <strong style="color:#c70042;">Pump rate violation</strong>
      <div style="margin-top:6px;font-family:var(--mono);font-size:12px;color:#c70042;">${esc(check.msg)}</div>
      <div style="margin-top:8px;font-size:12px;color:#666;">This entry cannot be saved until the duration, volume, or pump capacity is corrected.
        <a href="#" onclick="switchTab('equipment');return false;" style="color:var(--blue);">Open Equipment tab</a>
      </div>
    </div>`;
  })();

  // Item E — burn rate validation for incinerator / boiler sludge burning.
  // Effective rate (volume / duration hours) must not exceed configured burn capacity.
  (function() {
    let burnType = '';
    if (op.id === 'C12-incin') burnType = 'incinerator';
    else if (op.id === 'C12-boil') burnType = 'boiler';
    if (!burnType) return;
    const hrs = parseFloat(getT('wf-hours')) || 0;
    if (!qty || qty <= 0 || !hrs || hrs <= 0) return;
    const check = validateTransferRate(burnType, qty, hrs);
    if (check.ok) return;
    rateViolation = true;
    rateBlock += `<div style="margin-bottom:12px;padding:10px 12px;background:rgba(224,0,85,0.08);border-left:3px solid #e05;border-radius:3px;">
      <strong style="color:#c70042;">Burner rate violation</strong>
      <div style="margin-top:6px;font-family:var(--mono);font-size:12px;color:#c70042;">${esc(check.msg)}</div>
      <div style="margin-top:8px;font-size:12px;color:#666;">This entry cannot be saved until the duration, volume, or burn capacity is corrected.
        <a href="#" onclick="switchTab('equipment');return false;" style="color:var(--blue);">Open Equipment tab</a>
      </div>
    </div>`;
  })();

  // Item D (D-tank) — bilge transfer pump rate validation.
  // Volume / duration must not exceed configured bilge pump capacity.
  (function() {
    if (op.id !== 'D-tank') return;
    const hrs = parseFloat(getT('wf-hours')) || 0;
    const wellInputs = wiz.bilgeWellInputs || [];
    const vol = wellInputs.reduce((s, r) => s + (parseFloat(r.vol) || 0), 0);
    if (!vol || vol <= 0 || !hrs || hrs <= 0) return;
    const check = validateTransferRate('bilge', vol, hrs);
    if (check.ok) return;
    rateViolation = true;
    rateBlock += `<div style="margin-bottom:12px;padding:10px 12px;background:rgba(224,0,85,0.08);border-left:3px solid #e05;border-radius:3px;">
      <strong style="color:#c70042;">Bilge pump rate violation</strong>
      <div style="margin-top:6px;font-family:var(--mono);font-size:12px;color:#c70042;">${esc(check.msg)}</div>
      <div style="margin-top:8px;font-size:12px;color:#666;">This entry cannot be saved until the duration, volume, or pump capacity is corrected.
        <a href="#" onclick="switchTab('equipment');return false;" style="color:var(--blue);">Open Equipment tab</a>
      </div>
    </div>`;
  })();

  // OWS discharge prerequisite gate — manual (D-ows) and auto (E-ows) overboard
  // discharge require a prior Code I OCM test + valve unsealing.
  let prereqBlock = '';
  let prereqViolation = false;
  if (op.id === 'D-ows' || op.id === 'E-ows') {
    const chk = checkOwsDischargePrereqs(dateStr);
    if (!chk.ok) {
      prereqViolation = true;
      prereqBlock = `<div style="margin-bottom:12px;padding:10px 12px;background:rgba(224,0,85,0.08);border-left:3px solid #e05;border-radius:3px;">
        <strong style="color:#c70042;">Manual OWS discharge cannot proceed. Required Code I preparation sequence incomplete.</strong>
        <div style="margin-top:6px;font-size:12px;color:#666;">Missing requirements:</div>
        <ul style="margin:6px 0 0 18px;font-family:var(--mono);font-size:12px;color:#c70042;">
          ${chk.missing.map(m => '<li>' + esc(m) + '</li>').join('')}
        </ul>
        <div style="margin-top:8px;font-size:12px;color:#666;">Record the Code I OCM test and valve unsealing entries first, then create this discharge.</div>
      </div>`;
    }
  }

  // Open-valve hard block — once the OWS overboard valve is unsealed, no entry of
  // any type may be created until a Code I valve-sealing entry reseals it.
  // Exempt: I-seal (the reseal itself), the OWS discharge ops (D-ows/E-ows) which
  // legitimately occur while the valve is open, and I-missed (a back-dated record
  // of a past operation, not a current entry). Corrections are also exempt.
  let valveOpenBlock = '';
  let valveOpenViolation = false;
  const _valveExemptOps = ['I-seal', 'D-ows', 'E-ows', 'I-missed'];
  if (!_valveExemptOps.includes(op.id) && !wiz.isCorrectionOf && owsValveState() === 'unsealed') {
    valveOpenViolation = true;
    valveOpenBlock = `<div style="margin-bottom:12px;padding:10px 12px;background:rgba(224,0,85,0.08);border-left:3px solid #e05;border-radius:3px;">
      <strong style="color:#c70042;">Overboard valve is currently UNSEALED.</strong>
      <div style="margin-top:6px;font-size:12px;color:#666;">The OWS overboard valve must be resealed (Code I &mdash; Valve Sealing) before any further Oil Record Book entry can be made.</div>
    </div>`;
  }

  // Promote rate violation into the same blocking gate as capacity overflow
  const hasViolation = hasBlock || rateViolation || prereqViolation || valveOpenViolation;

  // Build ROB summary
  let robHTML = '';
  if (robChanges.length) {
    const tanks2 = getTanks();
    robHTML = '<div style="margin-bottom:12px;">';
    robChanges.forEach(rc => {
      const t = tanks2.find(x=>x.id===rc.tankId);
      if (!t) return;
      const delta = rc.after - rc.before;
      robHTML += `<div class="rob-summary">
        <div><span style="font-family:var(--sans);font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--text3);display:block;margin-bottom:2px;">${esc(t.name)}</span>
          <span class="before">${fmt2(rc.before)} ${t.unit}</span></div>
        <div class="arrow">-></div>
        <div><span class="after">${fmt2(rc.after)} ${t.unit}</span></div>
        <div style="margin-left:auto;font-size:11px;color:${delta>=0?'var(--green)':'var(--red2)'};">${delta>=0?'+':''}${fmt2(delta)}</div>
      </div>`;
    });
    robHTML += '</div>';
  }

  // Attachment indicator
  let attachNote = '';
  if (wiz.attachment) {
    attachNote = `<div style="margin-bottom:10px;display:flex;align-items:center;gap:8px;font-family:var(--sans);font-size:12px;color:var(--green);">
      <span>&#128204;</span> Attachment: ${esc(wiz.attachment.name)}
    </div>`;
  }

  // Render into the popup modal. The modal has its own scrollable body and
  // a sticky footer so the Confirm button is ALWAYS reachable no matter how
  // long the preview content is — fixes the desktop-scroll bug where the
  // entry-form-panel scroll context hid the button below the fold.
  const modalBody = document.getElementById('preview-modal-body');
  const modalFoot = document.getElementById('preview-modal-foot');
  if (modalBody && modalFoot) {
    modalBody.innerHTML = `
      ${capacityBlock}
      ${rateBlock}
      ${prereqBlock}
      ${valveOpenBlock}
      ${robHTML}
      ${attachNote}
      ${buildOrbPreviewHTML({ formatted: lines, officer: '', rank: '', attachment: wiz.attachment || null })}
    `;
    modalFoot.innerHTML = `
      <button class="btn btn-secondary" onclick="closeModal('preview-modal')">Back to Edit</button>
      <button class="btn btn-green" onclick="closeModal('preview-modal');openSigModal()"${hasViolation ? ' disabled title="Resolve the flagged violation before saving"' : ''}>Confirm with Signature</button>
    `;
    openModal('preview-modal');
    // Reset modal body scroll so user starts at the top of the preview.
    requestAnimationFrame(() => { modalBody.scrollTop = 0; });
  } else {
    // Fallback for the (unused) inline area — kept so any external clearing
    // logic that targets wiz-preview-area still works without errors.
    el.innerHTML = '';
  }
}

// ============================================================
// SIGNATURE PAD
// ============================================================
const _sigPads = {}; // { canvasId: { drawing, lastX, lastY, ctx } }

function initSigPad(canvasId) {
  const canvas = document.getElementById(canvasId);
  if (!canvas) return;
  // Set actual pixel size to match CSS size
  const rect = canvas.parentElement.getBoundingClientRect();
  canvas.width  = rect.width  || 380;
  canvas.height = 80;
  const ctx = canvas.getContext('2d');
  ctx.strokeStyle = '#1a1a2e';
  ctx.lineWidth   = 2;
  ctx.lineCap     = 'round';
  ctx.lineJoin    = 'round';
  // Clear white background
  ctx.fillStyle = '#fff';
  ctx.fillRect(0, 0, canvas.width, canvas.height);

  const state = { drawing: false, lastX: 0, lastY: 0, ctx, canvas, hasStrokes: false };
  _sigPads[canvasId] = state;

  function getPos(e) {
    const r = canvas.getBoundingClientRect();
    const src = e.touches ? e.touches[0] : e;
    return { x: src.clientX - r.left, y: src.clientY - r.top };
  }
  function start(e) { e.preventDefault(); const p = getPos(e); state.drawing = true; state.lastX = p.x; state.lastY = p.y; }
  function move(e)  {
    e.preventDefault();
    if (!state.drawing) return;
    const p = getPos(e);
    ctx.beginPath();
    ctx.moveTo(state.lastX, state.lastY);
    ctx.lineTo(p.x, p.y);
    ctx.stroke();
    state.lastX = p.x; state.lastY = p.y;
    state.hasStrokes = true;
  }
  function stop() { state.drawing = false; }

  canvas.addEventListener('mousedown',  start);
  canvas.addEventListener('mousemove',  move);
  canvas.addEventListener('mouseup',    stop);
  canvas.addEventListener('mouseleave', stop);
  canvas.addEventListener('touchstart', start, { passive: false });
  canvas.addEventListener('touchmove',  move,  { passive: false });
  canvas.addEventListener('touchend',   stop);
}

function clearSigPad(canvasId) {
  const state = _sigPads[canvasId];
  if (!state) return;
  state.ctx.fillStyle = '#fff';
  state.ctx.fillRect(0, 0, state.canvas.width, state.canvas.height);
  state.hasStrokes = false;
}

function getSigDataUrl(canvasId) {
  const state = _sigPads[canvasId];
  if (!state || !state.hasStrokes) return null;
  return state.canvas.toDataURL('image/png');
}

// ============================================================
// SIGNATURE MODAL
// ============================================================
function openSigModal() {
  const s = loadSettings();
  const isMultiSig = wiz.opId === 'C11-inv';
  const crew = loadCrew();

  // Populate officer dropdown (non-CE crew)
  const officerSel = document.getElementById('sig-name-select');
  if (officerSel) {
    const nonCE = crew.filter(c => c.rank !== 'Chief Engineer');
    if (nonCE.length) {
      officerSel.innerHTML = `<option value="">-- select officer --</option>` +
        nonCE.map(c => {
          const val = `${c.name}|${c.rank}`;
          const sel = c.name === (s.lastOfficer || '') ? ' selected' : '';
          return `<option value="${esc(val)}"${sel}>${esc(c.name)} (${esc(c.rank)})</option>`;
        }).join('');
    } else {
      officerSel.innerHTML = `<option value="">-- no crew added (go to Crew tab) --</option>`;
    }
    // Sync hidden fields on change
    officerSel.onchange = function() {
      const parts = this.value.split('|');
      document.getElementById('sig-name').value = parts[0] || '';
      document.getElementById('sig-rank').value = parts[1] || '';
    };
    // Trigger once to populate hidden fields with current selection
    officerSel.onchange();
  }

  // Populate CE dropdown (CE only)
  const ceSel = document.getElementById('sig-ce-name-select');
  if (ceSel) {
    const ceList = crew.filter(c => c.rank === 'Chief Engineer');
    const ceLine = (wiz.lines || []).find(l => l._sigTank);
    const prefilledCE = (ceLine && ceLine.ceName) ? ceLine.ceName : (s.ceName || '');
    if (ceList.length) {
      ceSel.innerHTML = `<option value="">-- select Chief Engineer --</option>` +
        ceList.map(c => {
          const sel = c.name === prefilledCE ? ' selected' : '';
          return `<option value="${esc(c.name)}"${sel}>${esc(c.name)}</option>`;
        }).join('');
    } else {
      ceSel.innerHTML = `<option value="">-- no CE in crew roster --</option>`;
    }
    ceSel.onchange = function() {
      document.getElementById('sig-ce-name').value = this.value;
    };
    ceSel.onchange();
  }

  // Hide officer name/rank + officer sig pad for C11-inv (per-tank officers in form)
  const officerBlock   = document.getElementById('sig-officer-block');
  const officerPadBlk  = document.getElementById('sig-officer-pad-block');
  const ceNameBlock    = document.getElementById('sig-ce-name-block');
  if (officerBlock)  officerBlock.style.display  = isMultiSig ? 'none' : '';
  if (officerPadBlk) officerPadBlk.style.display = isMultiSig ? 'none' : '';
  if (ceNameBlock)   ceNameBlock.style.display   = isMultiSig ? '' : 'none';
  // Update CE sig pad label
  const cePadLabel = document.getElementById('sig-ce-pad-label');
  if (cePadLabel) cePadLabel.textContent = isMultiSig ? 'Chief Engineer Signature (applied to all tanks)' : 'Chief Engineer Signature';
  // Build summary
  const op = OPERATIONS.find(o => o.id === wiz.opId);
  const tankCount = isMultiSig ? (wiz.lines || []).filter(l => l._sigTank).length : 0;
  document.getElementById('sig-preview-summary').innerHTML = `
    <div style="background:var(--bg3);border:1px solid var(--border);border-radius:2px;padding:12px 16px;font-family:var(--mono);font-size:12px;">
      <div style="color:var(--amber);margin-bottom:4px;">${esc(op ? op.label : '')}</div>
      <div style="color:var(--text2);">Date: ${esc(wiz.dateStr||'')} &nbsp; Time: ${esc(wiz.timeStr||'')}</div>
      ${isMultiSig ? `<div style="color:var(--text3);margin-top:4px;">${tankCount} tank(s) — CE signature replicated to all</div>` : ''}
      ${wiz.robChg && wiz.robChg.length ? '<div style="color:var(--text3);margin-top:4px;">'+wiz.robChg.length+' tank ROB(s) will be updated</div>' : ''}
    </div>`;
  openModal('sig-modal');
  // Init pads after modal is visible (so getBoundingClientRect works)
  requestAnimationFrame(() => {
    if (!isMultiSig) initSigPad('sig-canvas-officer');
    initSigPad('sig-canvas-ce');
  });
}

function confirmEntry() {
  const isMultiSig = wiz.opId === 'C11-inv';
  const nameEl  = isMultiSig ? document.getElementById('sig-ce-name') : document.getElementById('sig-name');
  const name    = nameEl ? nameEl.value.trim() : '';
  const rank = document.getElementById('sig-rank').value;
  if (!isMultiSig && !name) {
    const crew = loadCrew();
    const hasNonCE = crew.some(c => c.rank !== 'Chief Engineer');
    if (!hasNonCE) {
      alert('No crew added yet.\n\nGo to the Crew tab and add at least one officer (2nd/3rd/4th Engineer) before saving an entry.');
    } else {
      alert('Please select an officer from the dropdown.');
    }
    return;
  }

  const officerSigImg = isMultiSig ? null : getSigDataUrl('sig-canvas-officer');
  const ceSigImg      = getSigDataUrl('sig-canvas-ce');

  const op = OPERATIONS.find(o => o.id === wiz.opId);
  // For C11-inv: CE name is the confirming officer; per-tank officers are in formatted lines
  const entryOfficer = isMultiSig ? (name || 'Chief Engineer') : name;
  const entryRank    = isMultiSig ? 'Chief Engineer' : rank;
  const entry = {
    id:            uid(),
    attachment:    wiz.attachment || null,
    date:          wiz.dateStr || fmtDateInput(),
    time:          wiz.timeStr || fmtTimeInput(),
    code:          op ? op.code : '',
    operationType: op ? op.label : '',
    officer:       entryOfficer,
    rank:          entryRank,
    remarks:       wiz.remarks || '',
    formatted:     wiz.lines   || [],
    officerSigImg: officerSigImg || null,
    ceSigImg:      ceSigImg      || null,
    savedAt:       now(),
    correctedEntryId: wiz.correctedEntryId || null,
    corrCEName:       wiz.corrCEName || null,
    robChg:        wiz.robChg || [],
    owsTestMinutes: wiz.owsTestMinutes || 0,
  };

  // Save entry
  const entries = loadEntries();
  // If this is the correct re-entry following a correction, link it back to the original
  if (wiz.isCorrectionOf) {
    const orig = entries.find(e => e.id === wiz.isCorrectionOf);
    if (orig) orig.correctionEntryId = entry.id;
    entry.isCorrectEntryFor = wiz.isCorrectionOf;
  }
  entries.push(entry);
  saveEntries(entries);

  // Update ROBs
  if (wiz.robChg && wiz.robChg.length) {
    const tanks = getTanks();
    wiz.robChg.forEach(rc => {
      const t = tanks.find(x => x.id === rc.tankId);
      if (!t) return;
      t.rob = rc.after;
      if (!t.history) t.history = [];
      t.history.push({ date: now(), before: rc.before, after: rc.after, reason: entry.operationType, type: 'transfer' });
      if (t.history.length > 20) t.history = t.history.slice(-20);
    });
    saveTanks(tanks);
  }

  // Save for next time
  const s = loadSettings();
  if (!isMultiSig) { s.lastOfficer = name; s.lastRank = rank; }
  saveSettings(s);

  closeModal('sig-modal');
  _formDirty = false;
  const wasCorrectionReentry = !!wiz.isCorrectionOf;
  wizReset();
  if (wasCorrectionReentry) {
    alert('Correction complete.\n\nThe incorrect entry has been struck through in the ORB Log. The correct entry has been saved and will appear immediately after it in the Record Book.\n\nRemember: This is an educational record only.');
  } else {
    alert('Entry saved to ORB Log. ROBs updated.\n\nRemember: This is an educational record only.');
  }
}

// ============================================================
// THEME
// ============================================================
function applyTheme(isLight) {
  document.body.classList.toggle('light', isLight);
  const lbl = document.getElementById('theme-toggle-label');
  if (lbl) lbl.textContent = isLight ? 'Dark Mode' : 'Light Mode';
}

function toggleTheme() {
  const s = loadSettings();
  s.lightMode = !s.lightMode;
  saveSettings(s);
  applyTheme(s.lightMode);
}

// Signature metadata D — stored reversed for reference integrity
const _sigVersion = 2;
const _sigMeta = '5dcebd3bcefd';

// Key reassembly
function _k() {
  const a = _schV.map(function(b) { return String.fromCharCode(b); }).join('');
  const d = _sigMeta.split('').reverse().join('');
  return a + _palB + _logFmtKey + d;
}

// ============================================================
// DEVICE FINGERPRINT
// ============================================================
async function computeDeviceFingerprint() {
  var signals = [];
  signals.push('ua:' + navigator.userAgent);
  signals.push('scr:' + screen.width + 'x' + screen.height + 'x' + screen.colorDepth);
  signals.push('tz:' + Intl.DateTimeFormat().resolvedOptions().timeZone);
  signals.push('lang:' + navigator.language);
  signals.push('cpu:' + (navigator.hardwareConcurrency || 0));
  signals.push('mem:' + (navigator.deviceMemory || 0));
  signals.push('plat:' + navigator.platform);
  try {
    var canvas = document.createElement('canvas');
    var gl = canvas.getContext('webgl') || canvas.getContext('experimental-webgl');
    if (gl) {
      var dbg = gl.getExtension('WEBGL_debug_renderer_info');
      if (dbg) {
        signals.push('gl:' + gl.getParameter(dbg.UNMASKED_RENDERER_WEBGL));
        signals.push('glv:' + gl.getParameter(dbg.UNMASKED_VENDOR_WEBGL));
      }
    }
  } catch(e) {}
  try {
    var c = document.createElement('canvas');
    c.width = 200; c.height = 40;
    var ctx = c.getContext('2d');
    ctx.textBaseline = 'alphabetic';
    ctx.font = '14px Arial';
    ctx.fillStyle = '#f60';
    ctx.fillRect(125, 1, 62, 20);
    ctx.fillStyle = '#069';
    ctx.fillText('ChiefEngineerPRO-ORB', 2, 15);
    ctx.fillStyle = 'rgba(102,204,0,0.7)';
    ctx.fillText('ChiefEngineerPRO-ORB', 4, 17);
    signals.push('cv:' + c.toDataURL().slice(-50));
  } catch(e) {}
  try {
    var testFonts = ['Courier New', 'Arial Black', 'Comic Sans MS'];
    var testDiv = document.createElement('span');
    testDiv.style.cssText = 'position:absolute;left:-9999px;visibility:hidden;font-size:72px;';
    testDiv.textContent = 'mmmmmmmmmmlli';
    document.body.appendChild(testDiv);
    var fontSig = '';
    testFonts.forEach(function(f) {
      testDiv.style.fontFamily = f + ',monospace';
      fontSig += testDiv.offsetWidth + ',';
    });
    document.body.removeChild(testDiv);
    signals.push('fnt:' + fontSig);
  } catch(e) {}
  var raw = signals.join('|');
  var encoded = new TextEncoder().encode(raw);
  var hashBuf = await crypto.subtle.digest('SHA-256', encoded);
  return Array.from(new Uint8Array(hashBuf)).map(function(b) { return b.toString(16).padStart(2,'0'); }).join('');
}

// ============================================================
// FINGERPRINT V2 — split into stable (must-match) + drift (N-of-M)
// Returns: { stableHash, driftHashes[10], fp8 }
// fp8 = first 16 hex chars of stableHash, used in token payload binding
// ============================================================
async function _sha256Hex(s) {
  var b = new TextEncoder().encode(s);
  var h = await crypto.subtle.digest('SHA-256', b);
  return Array.from(new Uint8Array(h)).map(function(x){return x.toString(16).padStart(2,'0');}).join('');
}

async function computeFpV2() {
  // ---- STABLE BUCKET (3 signals, must match exactly) ----
  var glVendor = '';
  try {
    var cv = document.createElement('canvas');
    var gl = cv.getContext('webgl') || cv.getContext('experimental-webgl');
    if (gl) {
      var dbg = gl.getExtension('WEBGL_debug_renderer_info');
      if (dbg) glVendor = String(gl.getParameter(dbg.UNMASKED_VENDOR_WEBGL) || '');
    }
  } catch(e) {}
  var platMajor = (navigator.platform || '').replace(/[0-9._\s-]+$/, '').slice(0, 10);
  var stableRaw = 'cd:' + screen.colorDepth + '|pl:' + platMajor + '|glv:' + glVendor;
  var stableHash = await _sha256Hex(stableRaw);
  var fp8 = stableHash.slice(0, 16);

  // ---- DRIFT BUCKET (10 signals, require N=7 of M=10 match) ----
  var drift = [];
  drift.push('ua:' + (navigator.userAgent || '').split(' ')[0]);  // browser family only
  drift.push('sw:' + screen.width);
  drift.push('sh:' + screen.height);
  drift.push('tz:' + (Intl.DateTimeFormat().resolvedOptions().timeZone || ''));
  drift.push('ln:' + (navigator.language || ''));
  drift.push('cpu:' + (navigator.hardwareConcurrency || 0));
  drift.push('mem:' + (navigator.deviceMemory || 0));
  var glRenderer = '';
  try {
    var cv2 = document.createElement('canvas');
    var gl2 = cv2.getContext('webgl') || cv2.getContext('experimental-webgl');
    if (gl2) {
      var dbg2 = gl2.getExtension('WEBGL_debug_renderer_info');
      if (dbg2) glRenderer = String(gl2.getParameter(dbg2.UNMASKED_RENDERER_WEBGL) || '');
    }
  } catch(e) {}
  drift.push('glr:' + glRenderer);
  try {
    var c = document.createElement('canvas');
    c.width = 200; c.height = 40;
    var ctx = c.getContext('2d');
    ctx.textBaseline = 'alphabetic'; ctx.font = '14px Arial';
    ctx.fillStyle = '#f60'; ctx.fillRect(125, 1, 62, 20);
    ctx.fillStyle = '#069'; ctx.fillText('ChiefEngineerPRO-ORB', 2, 15);
    ctx.fillStyle = 'rgba(102,204,0,0.7)'; ctx.fillText('ChiefEngineerPRO-ORB', 4, 17);
    drift.push('cv:' + c.toDataURL().slice(-50));
  } catch(e) { drift.push('cv:'); }
  try {
    var testFonts = ['Courier New', 'Arial Black', 'Comic Sans MS'];
    var testDiv = document.createElement('span');
    testDiv.style.cssText = 'position:absolute;left:-9999px;visibility:hidden;font-size:72px;';
    testDiv.textContent = 'mmmmmmmmmmlli';
    document.body.appendChild(testDiv);
    var fontSig = '';
    testFonts.forEach(function(f) {
      testDiv.style.fontFamily = f + ',monospace';
      fontSig += testDiv.offsetWidth + ',';
    });
    document.body.removeChild(testDiv);
    drift.push('fnt:' + fontSig);
  } catch(e) { drift.push('fnt:'); }

  // Hash each drift signal individually so we can score N-of-M
  var driftHashes = [];
  for (var i = 0; i < drift.length; i++) {
    driftHashes.push((await _sha256Hex(drift[i])).slice(0, 16));
  }
  return { stableHash: stableHash, driftHashes: driftHashes, fp8: fp8 };
}

// Returns drift score (0..10) against stored bind record
function _scoreFpDrift(current, stored) {
  if (!current || !stored || !Array.isArray(stored.driftHashes)) return 0;
  var score = 0;
  for (var i = 0; i < current.driftHashes.length && i < stored.driftHashes.length; i++) {
    if (current.driftHashes[i] === stored.driftHashes[i]) score++;
  }
  return score;
}

// ============================================================
// TOKEN-AT-REST ENCRYPTION (v2 only) — AES-GCM, key bound to stableHash
// Storage: ciphertext (iv + payload) split into two halves, XOR-masked,
// written to orb_lic_a and orb_lic_b. Useless on another machine.
// ============================================================
async function _deriveAesKey(stableHash) {
  var material = new TextEncoder().encode(stableHash + '|orb-aes-salt');
  var raw = await crypto.subtle.digest('SHA-256', material);
  return crypto.subtle.importKey('raw', raw, { name: 'AES-GCM' }, false, ['encrypt', 'decrypt']);
}
function _xorMask(bytes) {
  // Per-session XOR mask derived from non-secret signals — slows token-export attacks
  var m = (screen.colorDepth + '|' + (navigator.platform || '')).split('');
  var out = new Uint8Array(bytes.length);
  for (var i = 0; i < bytes.length; i++) out[i] = bytes[i] ^ m[i % m.length].charCodeAt(0);
  return out;
}
function _bytesToB64(bytes) {
  var s = ''; for (var i = 0; i < bytes.length; i++) s += String.fromCharCode(bytes[i]);
  return btoa(s);
}
function _b64ToBytes(b64) {
  var s = atob(b64); var out = new Uint8Array(s.length);
  for (var i = 0; i < s.length; i++) out[i] = s.charCodeAt(i);
  return out;
}

// Portable Edition: the license is bound to the user's email, not the device.
// Device-derived AES-at-rest encryption is intentionally dropped — its key was
// derived from the device fingerprint, which would make the token unreadable
// after copying the USB to a different desktop. The token is stored plainly;
// its HMAC signature still proves it came from our server and was not forged.

// ============================================================
// MASTER SECRET — assembled at call time from 4 DOM contexts
// (Do not refactor: each fragment lives in a different surface
// so a single grep against the file recovers nothing useful.)
// ============================================================
const _bldZ = [0x39,0x69,0x38,0x37,0x69,0x6B,0x6A,0x68];
function _masterSecret() {
  return (function() {
    var a = (getComputedStyle(document.documentElement).getPropertyValue('--_z') || '').replace(/['"\s]/g,'');
    var b = (document.querySelector('meta[name="generator"]') || {}).dataset || {};
    var bb = b.bld || '';
    var cc = String.fromCharCode.apply(null, _bldZ.map(function(x){return x-5;}));
    var t = (document.querySelector('#_bm title') || {}).textContent || '';
    var m = t.match(/-([A-Za-z0-9+/=]{8,16})-/);
    var dd = '';
    try { dd = atob((m && m[1]) || ''); } catch(e) {}
    return a + bb + cc + dd;
  })();
}

// ============================================================
// TOKEN VERIFY — dual-format (v2 derives per-token key from kid; v1 legacy)
// ============================================================
function _hexToBytes(hex) {
  var out = new Uint8Array(hex.length / 2);
  for (var i = 0; i < out.length; i++) out[i] = parseInt(hex.substr(i*2, 2), 16);
  return out;
}
function _bytesToHex(bytes) {
  return Array.from(bytes).map(function(b) { return b.toString(16).padStart(2,'0'); }).join('');
}

async function verifyLicenseToken(rawToken) {
  try {
    var parts = rawToken.split('.');
    if (parts.length !== 2) return { valid: false, reason: 'malformed' };
    var payloadB64 = parts[0], storedSig = parts[1];
    // Decode payload first to determine version
    var json = atob(payloadB64.replace(/-/g,'+').replace(/_/g,'/'));
    var payload = JSON.parse(json);

    if (payload.v === 2) {
      // ---- v2 PATH: verifyKey = HMAC(master, kid), then verify sig ----
      if (!payload.kid || !payload.fp8) return { valid: false, reason: 'malformed' };
      var masterBytes = new TextEncoder().encode(_masterSecret());
      var masterKey = await crypto.subtle.importKey('raw', masterBytes, { name: 'HMAC', hash: 'SHA-256' }, false, ['sign']);
      var derivedBytes = await crypto.subtle.sign('HMAC', masterKey, new TextEncoder().encode(payload.kid));
      var verifyKey = await crypto.subtle.importKey('raw', derivedBytes, { name: 'HMAC', hash: 'SHA-256' }, false, ['verify']);
      var sigOk = await crypto.subtle.verify('HMAC', verifyKey, _hexToBytes(storedSig), new TextEncoder().encode(payloadB64));
      if (!sigOk) return { valid: false, reason: 'sig_mismatch' };
      return { valid: true, version: 2, email: payload.em, tier: payload.ti, kid: payload.kid, fp8: payload.fp8 };
    }

    // ---- v1 PATH (legacy): key = _k(), HMAC sign + string compare ----
    var keyBytes = new TextEncoder().encode(_k());
    var cryptoKey = await crypto.subtle.importKey('raw', keyBytes, { name: 'HMAC', hash: 'SHA-256' }, false, ['sign']);
    var sigBytes = await crypto.subtle.sign('HMAC', cryptoKey, new TextEncoder().encode(payloadB64));
    var computedSig = _bytesToHex(new Uint8Array(sigBytes));
    if (computedSig !== storedSig) return { valid: false, reason: 'sig_mismatch' };
    return { valid: true, version: 1, email: payload.em, tier: payload.ti };
  } catch(e) {
    return { valid: false, reason: 'parse_error' };
  }
}

// ============================================================
// ACTIVATION — calls n8n webhook (Portable Edition: email-bound, no device lock)
// ============================================================
async function activateDevice(email) {
  var controller = new AbortController();
  var timer = setTimeout(function() { controller.abort(); }, 10000);
  var resp, data;
  try {
    resp = await fetch(ORB_ACTIVATE_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        email: email,
        // Portable build has no device fingerprint — sent blank so the
        // existing webhook payload shape stays intact.
        fingerprint: '',
        fp8: '',
        appVersion: _fmtV,        // 'orb-portable'
        clientVersion: APP_VERSION
      }),
      signal: controller.signal
    });
    data = await resp.json();
  } catch(e) {
    clearTimeout(timer);
    if (e && e.name === 'AbortError') {
      return { ok: false, error: 'timeout' };
    }
    return { ok: false, error: 'network' };
  }
  clearTimeout(timer);
  if (!resp.ok || !data.success) {
    return { ok: false, error: data.error || 'unknown' };
  }
  // Store the token plainly — no device-derived encryption (see note above).
  localStorage.setItem(STORE_LICENSE, data.token);
  // Clean up any leftover v2 encrypted halves from a prior install on this browser.
  localStorage.removeItem(STORE_LIC_A);
  localStorage.removeItem(STORE_LIC_B);
  localStorage.removeItem(STORE_FP_BIND);
  localStorage.setItem(STORE_ACT_EMAIL, email);
  localStorage.setItem(STORE_CHECKED_AT, String(Date.now()));
  return { ok: true, token: data.token };
}

// Days since the last successful online license check.
function _portableDaysSinceCheck() {
  var raw = localStorage.getItem(STORE_CHECKED_AT);
  if (!raw) return Infinity;
  var then = parseInt(raw, 10);
  if (!then || isNaN(then)) return Infinity;
  return (Date.now() - then) / 86400000;
}

// ============================================================
// ACTIVATION GATE UI
// ============================================================
function showActivationGate(reason) {
  var gate = document.getElementById('activation-gate');
  gate.classList.remove('hidden');
  var errBox = document.getElementById('act-error-box');
  errBox.className = 'act-error';
  if (reason) {
    var msgs = {
      sig_mismatch: 'License verification failed. Please re-activate.',
      malformed: 'License code corrupted. Please re-activate or paste a valid code.',
      parse_error: 'License read error. Please re-activate.',
      timeout: 'Activation server timed out. Check your internet connection and try again.',
      network: 'Could not reach the activation server. Check your internet connection and try again.',
      recheck_due: 'Your license needs its 6-month online check. Connect to the internet once and enter your CEP email to renew. Your saved records are safe.',
      revoked: 'This license has been deactivated. Contact support@chiefengineerpro.com'
    };
    errBox.textContent = msgs[reason] || 'Activation required. Enter your CEP email.';
    errBox.className = 'act-error visible';
  }
  var saved = localStorage.getItem(STORE_ACT_EMAIL);
  if (saved) document.getElementById('act-email-input').value = saved;
  document.getElementById('act-email-input').addEventListener('keydown', function(e) {
    if (e.key === 'Enter') handleActivationSubmit();
  });
}

function hideActivationGate() {
  document.getElementById('activation-gate').classList.add('hidden');
}

// ============================================================
// FIRST-VISIT ONBOARDING CONTROLLER
// Shown once per device after successful activation.
// Skip enabled on slides 1-3; slide 4 forces "Got it" so the
// device-limit copy is always acknowledged before dismissal.
// ============================================================
function showOnboarding() {
  var el = document.getElementById('orb-onboard');
  if (!el) return;
  var total = 4;
  var slide = 1;
  var stepLabel = document.getElementById('onb-step-label');
  var nextBtn = document.getElementById('onb-next');
  var skipBtn = document.getElementById('onb-skip');

  function pad(n) { return n < 10 ? '0' + n : String(n); }

  function render() {
    var slides = el.querySelectorAll('.onb-slide');
    for (var i = 0; i < slides.length; i++) {
      var idx = parseInt(slides[i].getAttribute('data-slide'), 10);
      slides[i].classList.toggle('active', idx === slide);
    }
    var dots = el.querySelectorAll('.onb-dot');
    for (var j = 0; j < dots.length; j++) {
      var d = parseInt(dots[j].getAttribute('data-dot'), 10);
      dots[j].classList.toggle('active', d === slide);
      dots[j].classList.toggle('done', d < slide);
    }
    stepLabel.textContent = pad(slide) + ' · ' + pad(total);
    if (slide === total) {
      nextBtn.textContent = 'Got it';
      skipBtn.style.visibility = 'hidden';
    } else {
      nextBtn.textContent = 'Next';
      skipBtn.style.visibility = 'visible';
    }
  }

  function dismiss() {
    try { localStorage.setItem('orb_onboard_seen_v1', String(Date.now())); } catch(e) {}
    el.classList.add('hidden');
    document.removeEventListener('keydown', onKey);
  }

  function onKey(e) {
    if (e.key === 'Escape') { dismiss(); return; }
    if (e.key === 'Enter' || e.key === ' ' || e.key === 'ArrowRight') {
      e.preventDefault();
      advance();
    } else if (e.key === 'ArrowLeft' && slide > 1) {
      e.preventDefault();
      slide--; render();
    }
  }

  function advance() {
    if (slide < total) { slide++; render(); }
    else { dismiss(); }
  }

  nextBtn.onclick = advance;
  skipBtn.onclick = dismiss;
  document.addEventListener('keydown', onKey);

  el.classList.remove('hidden');
  render();
}

async function handleActivationSubmit() {
  var emailEl = document.getElementById('act-email-input');
  var btnText = document.getElementById('act-btn-text');
  var spinner = document.getElementById('act-spinner');
  var btn = document.getElementById('act-submit-btn');
  var errBox = document.getElementById('act-error-box');
  var successBox = document.getElementById('act-success-box');
  var email = (emailEl.value || '').trim().toLowerCase();
  if (!email || !email.includes('@')) {
    emailEl.classList.add('error');
    errBox.textContent = 'Enter a valid email address.';
    errBox.className = 'act-error visible';
    return;
  }
  emailEl.classList.remove('error');
  errBox.className = 'act-error';
  successBox.className = 'act-success';
  btnText.textContent = 'Verifying...';
  spinner.style.display = 'block';
  btn.disabled = true;
  emailEl.disabled = true;
  try {
    var result = await activateDevice(email);
    if (result.ok) {
      successBox.className = 'act-success visible';
      setTimeout(function() {
        hideActivationGate();
        // Portable Edition: show the license code so the user can save it
        // and paste it on other desktops without going online again.
        showLicenseSavePanel(result.token);
      }, 900);
    } else {
      var errMsgs = {
        not_member: 'No CEP account found for this email. Check your email or register at chiefengineerpro.com',
        free_tier: 'ORB Simulator requires Accelerator tier or higher. Upgrade at chiefengineerpro.com',
        device_limit: 'Max 2 devices reached. Email support@chiefengineerpro.com to manage your devices.',
        revoked: 'This license has been deactivated. Contact support@chiefengineerpro.com',
        unknown: 'Activation failed. Please try again.'
      };
      errBox.textContent = errMsgs[result.error] || errMsgs.unknown;
      errBox.className = 'act-error visible';
      btnText.textContent = 'Activate';
      spinner.style.display = 'none';
      btn.disabled = false;
      emailEl.disabled = false;
    }
  } catch(e) {
    errBox.textContent = 'Cannot reach activation server. Check your internet connection and try again.';
    errBox.className = 'act-error visible';
    btnText.textContent = 'Activate';
    spinner.style.display = 'none';
    btn.disabled = false;
    emailEl.disabled = false;
  }
}

// ============================================================
// PORTABLE EDITION — paste license, save panel, update banner
// ============================================================

// Toggle the "paste an existing license code" zone in the activation gate.
function togglePasteLicense() {
  var zone = document.getElementById('act-paste-zone');
  var toggle = document.getElementById('act-paste-toggle');
  if (zone.classList.contains('hidden')) {
    zone.classList.remove('hidden');
    toggle.textContent = 'Hide license code box';
    document.getElementById('act-license-input').focus();
  } else {
    zone.classList.add('hidden');
    toggle.innerHTML = 'I already have a license code — paste it';
  }
}

// Verify a pasted license code offline and, if genuine, store it on this desktop.
async function handlePasteLicenseSubmit() {
  var input = document.getElementById('act-license-input');
  var btn = document.getElementById('act-paste-submit');
  var btnText = document.getElementById('act-paste-btn-text');
  var spinner = document.getElementById('act-paste-spinner');
  var errBox = document.getElementById('act-error-box');
  var successBox = document.getElementById('act-success-box');
  var code = (input.value || '').trim();
  if (!code) {
    errBox.textContent = 'Paste your license code first.';
    errBox.className = 'act-error visible';
    return;
  }
  errBox.className = 'act-error';
  btnText.textContent = 'Checking...';
  spinner.style.display = 'block';
  btn.disabled = true;
  input.disabled = true;

  var result = await verifyLicenseToken(code);
  if (!result.valid) {
    errBox.textContent = 'That license code is not valid. Check you copied the whole code.';
    errBox.className = 'act-error visible';
    btnText.textContent = 'Use This License';
    spinner.style.display = 'none';
    btn.disabled = false;
    input.disabled = false;
    return;
  }

  // Genuine token — store it on this desktop. Set the re-check clock to now so
  // a freshly-pasted license gets a full 6-month offline window before renewal.
  localStorage.setItem(STORE_LICENSE, code);
  if (result.email) localStorage.setItem(STORE_ACT_EMAIL, result.email);
  localStorage.setItem(STORE_CHECKED_AT, String(Date.now()));
  localStorage.removeItem(STORE_LIC_A);
  localStorage.removeItem(STORE_LIC_B);
  localStorage.removeItem(STORE_FP_BIND);

  successBox.className = 'act-success visible';
  setTimeout(function() {
    hideActivationGate();
    bootApp();
  }, 700);
}

// Show the one-time "save your license code" panel after a successful activation.
function showLicenseSavePanel(token) {
  var panel = document.getElementById('license-save-panel');
  document.getElementById('license-save-text').value = token || localStorage.getItem(STORE_LICENSE) || '';
  panel.classList.remove('hidden');
}

function copyLicenseCode() {
  var ta = document.getElementById('license-save-text');
  ta.select();
  ta.setSelectionRange(0, 99999);
  var label = document.getElementById('license-copy-text');
  function done() { label.textContent = 'Copied'; setTimeout(function() { label.textContent = 'Copy License Code'; }, 2000); }
  if (navigator.clipboard && navigator.clipboard.writeText) {
    navigator.clipboard.writeText(ta.value).then(done, function() { try { document.execCommand('copy'); done(); } catch(e) {} });
  } else {
    try { document.execCommand('copy'); done(); } catch(e) {}
  }
}

function closeLicenseSavePanel() {
  document.getElementById('license-save-panel').classList.add('hidden');
  bootApp();
  try {
    if (!localStorage.getItem('orb_onboard_seen_v1')) showOnboarding();
  } catch(e) { /* localStorage blocked — skip onboarding silently */ }
}

// ============================================================
// ONLINE UPDATE CHECK
// Electron build: uses IPC bridge (window.eORB.updates.check) which
// fetches chiefengineerpro.com/orb/electron-version.json via main process.
// Portable build: falls back to fetch() against portable-version.json.
// Silent + non-blocking on failure in both cases.
// ============================================================
var ORB_VERSION_URL = 'https://chiefengineerpro.com/orb/portable-version.json';
var ELECTRON_VERSION_URL = 'https://chiefengineerpro.com/orb/electron-version.json';

function _verNum(v) {
  var m = String(v || '').match(/(\d+)\.(\d+)\.(\d+)/);
  if (!m) return 0;
  return parseInt(m[1], 10) * 10000 + parseInt(m[2], 10) * 100 + parseInt(m[3], 10);
}

function _showUpdateBanner(info, isElectron) {
  var banner = document.getElementById('orb-update-banner');
  var headline = document.getElementById('orb-update-headline');
  var notes = document.getElementById('orb-update-notes');
  var size = document.getElementById('orb-update-size');
  var link = document.getElementById('orb-update-link');
  if (!banner) return;

  var edition = isElectron ? 'eORB CEP' : 'Portable Edition';
  var ver = info.version || info.latest || '?';
  var mb = info.sizeMb ? info.sizeMb + ' MB' : null;

  headline.textContent = info.headline ||
    (edition + ' v' + ver + ' is available -- update now for the latest logic improvements.');
  notes.textContent = info.notes || '';
  size.textContent = mb ? 'Download size: ' + mb + ' -- quick install, no data loss.' : '';
  if (info.downloadUrl) {
    link.onclick = function(e) {
      e.preventDefault();
      if (isElectron && window.eORB && window.eORB.updates && window.eORB.updates.openUrl) {
        window.eORB.updates.openUrl(info.downloadUrl);
      } else {
        window.open(info.downloadUrl, '_blank');
      }
    };
  }
  banner.classList.remove('hidden');
}

async function checkForUpdate() {
  if (sessionStorage.getItem('orb_update_dismissed') === '1') return;

  // Electron path -- use IPC so the fetch goes through the main process
  // (renderer CSP blocks outbound connect-src in the packaged app).
  if (window.eORB && window.eORB.updates && window.eORB.updates.check) {
    try {
      var result = await window.eORB.updates.check();
      if (!result || !result.ok) return;
      var latest = result.latestVersion || result.version;
      if (_verNum(latest) > _verNum(APP_VERSION)) {
        _showUpdateBanner({
          version: latest,
          sizeMb: result.sizeMb || null,
          headline: result.headline || null,
          notes: result.notes || '',
          downloadUrl: result.downloadUrl || null,
          urgency: result.urgency || 'recommended'
        }, true);
      }
    } catch(e) { /* offline -- silently skip */ }
    return;
  }

  // Portable / browser path -- direct fetch.
  try {
    var controller = new AbortController();
    var timer = setTimeout(function() { controller.abort(); }, 6000);
    var resp = await fetch(ORB_VERSION_URL + '?t=' + Date.now(), { signal: controller.signal, cache: 'no-store' });
    clearTimeout(timer);
    if (!resp.ok) return;
    var info = await resp.json();
    var portableLatest = info.version || info.latest;
    if (_verNum(portableLatest) > _verNum(APP_VERSION)) {
      _showUpdateBanner(info, false);
    }
  } catch(e) { /* offline -- silently skip */ }
}

function dismissUpdateBanner() {
  document.getElementById('orb-update-banner').classList.add('hidden');
  try { sessionStorage.setItem('orb_update_dismissed', '1'); } catch(e) {}
}

// ============================================================
// Force-inject sample data (callable anytime from sidebar button)
function loadSampleDataNow() {
  if (!confirm('Load sample data?\n\nThis will delete ALL your current entries and replace them with sample records. This cannot be undone.')) return;
  localStorage.removeItem(STORE_SEEDED);
  localStorage.removeItem(STORE_ENTRIES);
  localStorage.removeItem(STORE_CREW);
  seedSampleData();
  renderDashboard();
  switchTab('log');
  alert('Sample data loaded — 10 actual ORB entries added (MEPC.1/Circ.736 format).');
}

