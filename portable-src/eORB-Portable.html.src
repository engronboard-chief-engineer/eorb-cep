<div class="modal-overlay hidden" id="entry-view-modal">
  <div class="modal-box wide">
    <div class="modal-head">
      <h3>ORB Entry — Educational Preview</h3>
      <button class="modal-close" onclick="closeModal('entry-view-modal')">&times;</button>
    </div>
    <div class="modal-body" id="entry-view-body"></div>
    <div class="modal-foot">
