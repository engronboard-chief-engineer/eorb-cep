  ];

  if (!loadEntries().length) saveEntries(sampleEntries);

  localStorage.setItem(STORE_SEEDED, '1');
}

// ============================================================
// INIT
// ============================================================
function bootApp() {
  if (!localStorage.getItem(STORE_DISC)) {
    document.getElementById('disclaimer-modal').classList.remove('hidden');
  } else {
    document.getElementById('disclaimer-modal').classList.add('hidden');
  }
  const s = loadSettings();
  const vesselName = (s.vesselName || 'MV PRACTICE VESSEL').toUpperCase();
  const sidebarVname = document.getElementById('sidebar-vessel-name-text');
  if (sidebarVname) sidebarVname.textContent = vesselName;
  applyTheme(!!s.lightMode);
  seedSampleData();
  renderDashboard();
  updateMasterClockDisplay();
  // Only fire the changelog modal once the disclaimer is acknowledged
  if (localStorage.getItem(STORE_DISC)) {
    checkChangelogModal();
  }
}

// ============================================================
// PORTABLE INIT — email-bound license, no device fingerprint check.
// On launch: verify the stored token's signature, then enforce the
// 6-month online re-check. Runs the same on every desktop the USB
// is plugged into.
// ============================================================
async function init() {
  // Clean up any leftover device-bound v2 encrypted halves (not used in this build).
  localStorage.removeItem(STORE_LIC_A);
  localStorage.removeItem(STORE_LIC_B);
  localStorage.removeItem(STORE_FP_BIND);

  var rawToken = localStorage.getItem(STORE_LICENSE);
  if (!rawToken) {
    // No license on this desktop yet — activate online or paste an existing code.
    showActivationGate(null);
    checkForUpdate();
    return;
  }

  var result = await verifyLicenseToken(rawToken);
  if (!result.valid) {
    // Signature failed — token is corrupt or forged.
    localStorage.removeItem(STORE_LICENSE);
    localStorage.removeItem(STORE_CHECKED_AT);
    showActivationGate(result.reason || 'sig_mismatch');
    checkForUpdate();
    return;
  }

  // Token is genuine. Enforce the 6-month online re-check.
  if (_portableDaysSinceCheck() > PORTABLE_RECHECK_DAYS) {
    var email = localStorage.getItem(STORE_ACT_EMAIL) || (result.email || '');
    var renewed = await runPortableRecheck(email);
    if (!renewed.ok) {
      // Re-check failed — show the gate with a renewal-specific message.
      // The user's records are untouched; only booting is blocked.
      showActivationGate(renewed.error === 'revoked' ? 'revoked' : 'recheck_due');
      checkForUpdate();
      return;
    }
  }

  bootApp();
  checkForUpdate();
}

// Re-validate the license email against the server. On success, refresh the
// stored token + re-check timestamp. Returns {ok:true} or {ok:false,error}.
async function runPortableRecheck(email) {
  if (!email || !email.includes('@')) return { ok: false, error: 'no_email' };
  var result = await activateDevice(email);
  // activateDevice already refreshes STORE_LICENSE + STORE_CHECKED_AT on success.
  return result;
}

document.addEventListener('DOMContentLoaded', init);

// ============================================================
// BOOK INLINE SIGN MODAL
// ============================================================
let _bookSignState = { entryId: null, sigType: null, pad: null };

function openBookSigModal(entryId, sigType) {
  _bookSignState.entryId = entryId;
  _bookSignState.sigType = sigType;
  const label = sigType === 'officer' ? 'Officer-in-Charge Signature' : 'Chief Engineer Signature';

  // Build modal DOM if not present
  let overlay = document.getElementById('book-sign-modal-overlay');
  if (!overlay) {
    overlay = document.createElement('div');
    overlay.id = 'book-sign-modal-overlay';
    overlay.innerHTML = `
      <div id="book-sign-modal-box">
        <h4 id="book-sign-modal-label"></h4>
        <div id="book-sign-canvas-wrap">
          <canvas id="book-sign-canvas" height="100"></canvas>
        </div>
        <div id="book-sign-modal-actions">
          <button class="bsm-clear" onclick="clearBookSignPad()">Clear</button>
          <div style="display:flex;gap:8px;">
            <button class="bsm-cancel" onclick="closeBookSignModal()">Cancel</button>
            <button class="bsm-save" onclick="saveBookSignature()">Save Signature</button>
          </div>
        </div>
      </div>`;
    document.body.appendChild(overlay);
  }
  document.getElementById('book-sign-modal-label').textContent = label;
  overlay.style.display = 'flex';

  requestAnimationFrame(() => {
    const canvas = document.getElementById('book-sign-canvas');
    const wrap   = document.getElementById('book-sign-canvas-wrap');
    canvas.width  = wrap.getBoundingClientRect().width || 340;
    canvas.height = 100;
    const ctx = canvas.getContext('2d');
    ctx.strokeStyle = '#111';
    ctx.lineWidth = 2;
    ctx.lineCap = 'round';
    ctx.lineJoin = 'round';
    ctx.fillStyle = '#fff';
    ctx.fillRect(0, 0, canvas.width, canvas.height);
    const pad = { ctx, canvas, drawing: false, lastX: 0, lastY: 0, hasStrokes: false };
    _bookSignState.pad = pad;

    function getPos(e) {
      const r = canvas.getBoundingClientRect();
      const src = e.touches ? e.touches[0] : e;
      return { x: src.clientX - r.left, y: src.clientY - r.top };
    }
    canvas.onmousedown  = e => { const p = getPos(e); pad.drawing = true; pad.lastX = p.x; pad.lastY = p.y; };
    canvas.onmousemove  = e => { if (!pad.drawing) return; const p = getPos(e); ctx.beginPath(); ctx.moveTo(pad.lastX, pad.lastY); ctx.lineTo(p.x, p.y); ctx.stroke(); pad.lastX = p.x; pad.lastY = p.y; pad.hasStrokes = true; };
    canvas.onmouseup    = () => { pad.drawing = false; };
    canvas.onmouseleave = () => { pad.drawing = false; };
    canvas.ontouchstart = e => { e.preventDefault(); const p = getPos(e); pad.drawing = true; pad.lastX = p.x; pad.lastY = p.y; };
    canvas.ontouchmove  = e => { e.preventDefault(); if (!pad.drawing) return; const p = getPos(e); ctx.beginPath(); ctx.moveTo(pad.lastX, pad.lastY); ctx.lineTo(p.x, p.y); ctx.stroke(); pad.lastX = p.x; pad.lastY = p.y; pad.hasStrokes = true; };
    canvas.ontouchend   = () => { pad.drawing = false; };
  });
}

function clearBookSignPad() {
  const pad = _bookSignState.pad;
  if (!pad) return;
  pad.ctx.fillStyle = '#fff';
  pad.ctx.fillRect(0, 0, pad.canvas.width, pad.canvas.height);
  pad.hasStrokes = false;
}

function closeBookSignModal() {
  const overlay = document.getElementById('book-sign-modal-overlay');
  if (overlay) overlay.style.display = 'none';
}

function saveBookSignature() {
  const { entryId, sigType, pad } = _bookSignState;
  if (!pad || !pad.hasStrokes) { alert('Please draw your signature first.'); return; }
  const dataUrl = pad.canvas.toDataURL('image/png');
  const entries = loadEntries();
  const entry = entries.find(e => e.id === entryId);
  if (!entry) return;
  if (sigType === 'officer') entry.officerSigImg = dataUrl;
  else                       entry.ceSigImg      = dataUrl;
  saveEntries(entries);
  closeBookSignModal();
  // Refresh book preview in place
  openBookPreview();
}
</script>

<!-- Portable Edition is a standalone file, not a PWA — no service worker. -->

<!-- ============================================================
     FIRST-VISIT ONBOARDING OVERLAY
     Shown once per device, after successful activation.
     Persistence: localStorage key 'orb_onboard_seen_v1'.
     ============================================================ -->
<div class="onb-overlay hidden" id="orb-onboard" role="dialog" aria-modal="true" aria-labelledby="onb-title-1">
  <div class="onb-card">

    <div class="onb-step" id="onb-step-label">01 &middot; 04</div>

    <!-- Slide 1: What this is -->
    <div class="onb-slide active" data-slide="1">
      <h2 class="onb-title" id="onb-title-1">Practice the real Oil Record Book.</h2>
      <p class="onb-body">Every entry follows <strong>MEPC.1/Circ.736</strong> wording exactly &mdash; all 14 operation categories, formatted the way PSC inspectors read them. Drill until inspection day feels routine.</p>
    </div>

    <!-- Slide 2: Activate once -->
    <div class="onb-slide" data-slide="2">
      <h2 class="onb-title">Activate once &mdash; get your license code.</h2>
      <p class="onb-body">The first time you open this on <strong>any one computer</strong>, enter your CEP email. It verifies online in a second &mdash; that&rsquo;s the only time you need internet to start. Right after, the app shows you a <span class="onb-amber">license code</span>. Copy it and keep it somewhere safe.</p>
    </div>

    <!-- Slide 3: Run it on any desktop -->
    <div class="onb-slide" data-slide="3">
      <h2 class="onb-title">Run it on any desktop &mdash; your choice.</h2>
      <p class="onb-body">On every other computer you use, pick whichever is less hassle:</p>
      <div class="onb-install">
        <div><span class="onb-os">Offline</span> Open the app &rarr; <strong>&ldquo;I already have a license code&rdquo;</strong> &rarr; paste your code. No internet needed.</div>
        <div style="margin-top:6px"><span class="onb-os">Online</span> Or just enter your CEP email again &mdash; it re-verifies in a second. No code to manage.</div>
      </div>
    </div>

    <!-- Slide 4: 6-month check + fair use -->
    <div class="onb-slide" data-slide="4">
      <h2 class="onb-title">A quick check every 6 months.</h2>
      <p class="onb-body">Every 6 months the app asks for one short online check to confirm your license is still valid &mdash; <span class="onb-amber">your saved records stay safe</span> through it. Your license is tied to your CEP email, and the app keeps light activation telemetry &mdash; that&rsquo;s how we support you fast and tell genuine members apart. Please don&rsquo;t share or redistribute the file; questions any time at <span class="onb-amber">support@chiefengineerpro.com</span>.</p>
    </div>

    <div class="onb-foot">
      <div class="onb-dots" aria-hidden="true">
        <span class="onb-dot active" data-dot="1"></span>
        <span class="onb-dot" data-dot="2"></span>
        <span class="onb-dot" data-dot="3"></span>
        <span class="onb-dot" data-dot="4"></span>
      </div>
      <div class="onb-actions">
        <button type="button" id="onb-skip" class="onb-btn onb-btn-ghost">Skip</button>
        <button type="button" id="onb-next" class="onb-btn onb-btn-primary">Next</button>
      </div>
    </div>

  </div>
</div>

</body>
</html>
