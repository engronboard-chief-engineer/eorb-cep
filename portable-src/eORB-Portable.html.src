function getTanks() {
  const t = loadTanks();
  if (t) return t;
  const defaults = dryFleetDefaults();
  saveTanks(defaults);
  return defaults;
}

const TYPE_LABELS = {
  bilge: 'Bilge Holding', sludge: 'Sludge', waste: 'Waste Oil', dirty: 'Dirty Oil',
  hfo: 'HFO', vlsfo: 'VLSFO', ulsfo: 'ULSFO', mdo: 'MDO', mgo: 'MGO', lsmgo: 'LSMGO',
  lo: 'Lube Oil', 'lo-settle': 'LO Settling', 'lo-service': 'LO Service',
  'fo-settle': 'FO Settling', 'fo-service': 'FO Service', 'do-service': 'DO Service',
  scav: 'Scavenge Drain', slop: 'Slop', cargo: 'Cargo Oil',
  'dirty-ballast': 'Dirty Ballast', pumproom: 'Pump Room Bilge',
  bilgewell: 'Bilge Well', other: 'Other'
};

function typeBadgeClass(type) {
  if (['hfo','vlsfo','ulsfo','mdo','mgo','lsmgo'].includes(type)) return 'badge-amber';
  if (['sludge','waste','dirty','scav'].includes(type)) return 'badge-red';
  if (['bilge','bilgewell','pumproom'].includes(type)) return 'badge-blue';
  if (['lo','lo-settle','lo-service'].includes(type)) return 'badge-green';
  if (['fo-settle','fo-service','do-service'].includes(type)) return 'badge-green';
  return 'badge-grey';
}

// ============================================================
// DISCLAIMER
// ============================================================
function acknowledgeDisclaimer() {
  if (!document.getElementById('disc-check').checked) return;
  localStorage.setItem(STORE_DISC, '1');
  document.getElementById('disclaimer-modal').classList.add('hidden');
}

// ============================================================
// TAB ROUTING
// ============================================================
const TAB_TITLES = {
  dashboard: 'ROB Dashboard',
  entry:     'New Entry',
  log:       'ORB Log',
  tanks:     'Tank Editor',
  crew:      'Crew Roster',
  reference: 'MARPOL Reference',
  tankmap:   'Tank Condition',
  equipment: 'Equipment'
};
function switchTab(name) {
  if (name !== 'entry' && _formDirty) {
    if (!confirm('You have unsaved changes in the current form. Discard and continue?')) return;
    _formDirty = false;
  }
  document.querySelectorAll('.tab-pane').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(b => b.classList.remove('active'));
  document.getElementById('tab-' + name).classList.add('active');
  const navBtn = document.getElementById('nav-btn-' + name);
  if (navBtn) navBtn.classList.add('active');
  const titleEl = document.getElementById('topbar-page-title');
  if (titleEl) titleEl.textContent = TAB_TITLES[name] || name;
  if (name === 'dashboard') renderDashboard();
  if (name === 'log')       renderLog();
  if (name === 'tanks')     renderTankEditor();
  if (name === 'crew')      renderCrew();
  if (name === 'reference') renderReference();
  if (name === 'tankmap')   renderTankDiagram();
  if (name === 'entry')     renderEntryWizard();
  if (name === 'equipment') { renderEquipment(); syncOwsMinMinutesField(); }
  if (typeof closeMobileSidebar === 'function') closeMobileSidebar();
}

// OWS discharge sequence rule — adjustable minimum OCM/recirculation test duration.
function syncOwsMinMinutesField() {
  const inp = document.getElementById('eq-ows-min-minutes');
  if (!inp) return;
  const s = loadSettings();
  inp.value = (s.owsMinTestMinutes != null && !isNaN(s.owsMinTestMinutes)) ? s.owsMinTestMinutes : 1;
}
function saveOwsMinMinutes() {
  const inp = document.getElementById('eq-ows-min-minutes');
  if (!inp) return;
  const s = loadSettings();
  const v = parseInt(inp.value, 10);
  s.owsMinTestMinutes = (isNaN(v) || v < 0) ? 1 : v;
  saveSettings(s);
}

// ============================================================
// MODALS
// ============================================================
function openModal(id)  { document.getElementById(id).classList.remove('hidden'); }
function closeModal(id) { document.getElementById(id).classList.add('hidden'); }

// Click outside to close
document.querySelectorAll('.modal-overlay').forEach(m => {
  m.addEventListener('click', e => { if (e.target === m) closeModal(m.id); });
});

// ============================================================
// VESSEL SETTINGS
// ============================================================
function openVesselModal() {
  const s = loadSettings();
  document.getElementById('vs-name').value    = s.vesselName || '';
  document.getElementById('vs-type').value    = s.vesselType || 'dry';
  document.getElementById('vs-flag').value    = s.flag || '';
  document.getElementById('vs-imo').value     = s.imo  || '';
  openModal('vessel-modal');
}
function saveVesselSettings() {
  const s = loadSettings();
  s.vesselName = document.getElementById('vs-name').value.trim() || 'MV PRACTICE VESSEL';
  s.vesselType = document.getElementById('vs-type').value;
  s.flag       = document.getElementById('vs-flag').value.trim();
  s.imo        = document.getElementById('vs-imo').value.trim();
  delete s.ceName;
  saveSettings(s);
  const nameText = s.vesselName.toUpperCase();
  const sidebarName = document.getElementById('sidebar-vessel-name-text');
  if (sidebarName) sidebarName.textContent = nameText;
  closeModal('vessel-modal');
}

// ============================================================
// VESSEL TYPE TOGGLE (dashboard)
// ============================================================
function setVesselType(type) {
  const s = loadSettings(); s.vesselType = type; saveSettings(s);
  document.getElementById('vtype-dry').className    = 'btn btn-sm ' + (type==='dry'    ? 'btn-primary' : 'btn-secondary');
  document.getElementById('vtype-tanker').className = 'btn btn-sm ' + (type==='tanker' ? 'btn-primary' : 'btn-secondary');
}
function syncVesselTypeButtons() {
  const s = loadSettings();
  const type = s.vesselType || 'dry';
  document.getElementById('vtype-dry').className    = 'btn btn-sm ' + (type==='dry'    ? 'btn-primary' : 'btn-secondary');
  document.getElementById('vtype-tanker').className = 'btn btn-sm ' + (type==='tanker' ? 'btn-primary' : 'btn-secondary');
}

// ============================================================
// ROB DASHBOARD RENDERER
// ============================================================
function renderDashboard() {
  syncVesselTypeButtons();
  const tanks = getTanks();
  const el = document.getElementById('rob-dashboard-table');
  if (!tanks.length) { el.innerHTML = '<p style="color:var(--text3);font-family:var(--sans);font-size:13px;">No tanks configured. Go to Tank Editor to add tanks.</p>'; return; }

  // Stat cards
  const fuelTanks   = tanks.filter(t => tankGroup(t.type) === 'Fuel Oils');
  const lubeTanks   = tanks.filter(t => tankGroup(t.type) === 'Lube Oils');
  const sludgeTanks = tanks.filter(t => tankGroup(t.type) === 'Sludge / Waste');
  const bilgeTanks  = tanks.filter(t => tankGroup(t.type) === 'Bilge / Holding');
  const totalFuelROB   = fuelTanks.reduce((s,t)=>s+(parseFloat(t.rob)||0), 0);
  const totalLubeROB   = lubeTanks.reduce((s,t)=>s+(parseFloat(t.rob)||0), 0);
  const totalSludgeROB = sludgeTanks.reduce((s,t)=>s+(parseFloat(t.rob)||0), 0);
  const totalBilgeROB  = bilgeTanks.reduce((s,t)=>s+(parseFloat(t.rob)||0), 0);
  const entries = loadEntries();
  const highTanks = tanks.filter(t => {
    const cap = parseFloat(t.capacity)||0;
    const rob = parseFloat(t.rob)||0;
    return !t.isBilgeWell && cap > 0 && (rob/cap) >= 0.80;
  });

  const statCardsHtml = `<div class="stat-cards">
    <div class="stat-card blue">
      <div class="stat-card-row">
        <div class="stat-card-label">Total Fuel ROB</div>
        <div class="stat-card-icon blue"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M18 17V9"/><path d="M13 17V5"/><path d="M8 17v-3"/></svg></div>
      </div>
      <div class="stat-card-value">${totalFuelROB.toFixed(3)}</div>
      <div class="stat-card-sub">${fuelTanks[0]?.unit || 'm3'} across ${fuelTanks.length} tank${fuelTanks.length!==1?'s':''}</div>
    </div>
    <div class="stat-card purple">
      <div class="stat-card-row">
        <div class="stat-card-label">Total Lube ROB</div>
        <div class="stat-card-icon purple"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v6"/><path d="m4.93 10.93 1.41 1.41"/><path d="M2 18h2"/><path d="M20 18h2"/><path d="m19.07 10.93-1.41 1.41"/><path d="M22 22H2"/><path d="m16 6-4 4-4-4"/><path d="M16 18a4 4 0 0 0-8 0"/></svg></div>
      </div>
      <div class="stat-card-value">${totalLubeROB.toFixed(3)}</div>
      <div class="stat-card-sub">${lubeTanks[0]?.unit || 'm3'} across ${lubeTanks.length} tank${lubeTanks.length!==1?'s':''}</div>
    </div>
    <div class="stat-card amber">
      <div class="stat-card-row">
        <div class="stat-card-label">Sludge / Waste</div>
        <div class="stat-card-icon amber"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg></div>
      </div>
      <div class="stat-card-value">${totalSludgeROB.toFixed(3)}</div>
      <div class="stat-card-sub">${sludgeTanks.length} sludge tank${sludgeTanks.length!==1?'s':''}</div>
    </div>
    <div class="stat-card green">
      <div class="stat-card-row">
        <div class="stat-card-label">Bilge ROB</div>
        <div class="stat-card-icon green"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22a7 7 0 0 0 7-7c0-2-1-3.9-3-5.5s-3.5-4-4-6.5c-.5 2.5-2 4.9-4 6.5C6 11.1 5 13 5 15a7 7 0 0 0 7 7z"/></svg></div>
      </div>
      <div class="stat-card-value">${totalBilgeROB.toFixed(3)}</div>
      <div class="stat-card-sub">${bilgeTanks.length} holding tank${bilgeTanks.length!==1?'s':''}</div>
    </div>
    <div class="stat-card ${highTanks.length > 0 ? 'red' : 'blue'}">
      <div class="stat-card-row">
        <div class="stat-card-label">High Fill Tanks</div>
        <div class="stat-card-icon ${highTanks.length > 0 ? 'red' : 'blue'}"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg></div>
      </div>
      <div class="stat-card-value">${highTanks.length}</div>
      <div class="stat-card-sub">${highTanks.length ? 'tanks at 80%+ capacity' : 'No high-fill alerts'}</div>
    </div>
    <div class="stat-card blue">
      <div class="stat-card-row">
        <div class="stat-card-label">Log Entries</div>
        <div class="stat-card-icon blue"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg></div>
      </div>
      <div class="stat-card-value">${entries.length}</div>
      <div class="stat-card-sub">ORB entries recorded</div>
    </div>
  </div>`;

  const groups = {};
  tanks.forEach(t => {
    const g = tankGroup(t.type);
    if (!groups[g]) groups[g] = [];
    groups[g].push(t);
  });

  // Helper to build a table for a group's tanks
  function buildGroupTable(tList) {
    let rows = '';
    tList.forEach(t => {
      const pct = (t.isBilgeWell || !t.capacity) ? null : Math.min(100, Math.round((t.rob / t.capacity) * 100));
      const barClass = pct === null ? '' : pct < 40 ? 'low' : pct < 75 ? 'mid' : 'high';
      const lastH = t.history && t.history.length ? t.history[t.history.length-1] : null;
      const lastUp = lastH ? fmtDate(lastH.date) + ' ' + fmtTime(lastH.date) : '<span style="color:var(--text3)">—</span>';
      rows += `<tr>
        <td class="col-tank-name"><strong>${esc(t.name)}</strong>${t.ioppc ? ' <span class="badge badge-grey" style="margin-left:6px;">IOPPC '+esc(t.ioppc)+'</span>' : ''}</td>
        <td><span class="badge ${typeBadgeClass(t.type)}">${TYPE_LABELS[t.type]||t.type}</span></td>
        <td class="mono col-r">${t.isBilgeWell ? '<span style="color:var(--text3)">—</span>' : fmt2(t.capacity)}</td>
        <td class="mono amber col-r">${t.isBilgeWell ? '<span style="color:var(--text3)">N/A</span>' : fmt3(t.rob)}</td>
        <td class="mono muted">${t.unit}</td>
        <td class="mono col-r">${pct === null ? '<span style="color:var(--text3)">—</span>' : pct + '%'}</td>
        <td>${pct === null ? '' : '<div class="rob-bar"><div class="rob-bar-fill '+barClass+'" style="width:'+pct+'%"></div></div>'}</td>
        <td class="mono" style="font-size:11px;">${lastUp}</td>
        <td class="col-actions">
          <button class="btn btn-secondary btn-sm" onclick="openRobEditModal('${t.id}')" style="margin-right:4px;">Edit ROB</button>
          <button class="btn btn-secondary btn-sm" onclick="showTankHistory('${t.id}')">History</button>
        </td>
      </tr>`;
    });
    return `<table class="data-table rob-dashboard-table" style="width:100%;table-layout:fixed;">
      <colgroup>
        <col style="width:200px">
        <col style="width:130px">
        <col style="width:90px">
        <col style="width:90px">
        <col style="width:55px">
        <col style="width:60px">
        <col style="width:120px">
        <col style="width:150px">
        <col style="width:180px">
      </colgroup>
      <thead><tr>
        <th>Tank Name</th>
        <th>Type</th>
        <th class="col-r">Capacity</th>
        <th class="col-r">ROB</th>
        <th>Unit</th>
        <th class="col-r">% Full</th>
        <th>Fill Level</th>
        <th>Last Updated</th>
        <th></th>
      </tr></thead><tbody>${rows}</tbody></table>`;
  }

  let tableHtml = '';
  const groupOrder = ['Fuel Oils', 'Lube Oils', 'Sludge / Waste', 'Bilge / Holding', 'Cargo / Slop', 'Bilge Wells', 'Other'];
  groupOrder.forEach(g => {
    if (!groups[g] || !groups[g].length) return;
    const totalRob = groups[g].reduce((s,t) => s + (t.isBilgeWell ? 0 : parseFloat(t.rob)||0), 0);
    const robLabel = groups[g][0] ? groups[g][0].unit : 'm3';
    tableHtml += `<div class="accordion-group open" style="margin-bottom:12px;">
      <div class="accordion-header" onclick="toggleAccordion(this)">
        <div class="accordion-header-title">${g}</div>
        <div class="accordion-header-meta">${groups[g].length} tank${groups[g].length!==1?'s':''} &nbsp;|&nbsp; ${totalRob.toFixed(3)} ${robLabel} total ROB</div>
        <svg class="accordion-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
      </div>
      <div class="accordion-body">
        <div style="overflow-x:auto;">${buildGroupTable(groups[g])}</div>
      </div>
    </div>`;
  });

  el.innerHTML = statCardsHtml + tableHtml;
}

function tankGroup(type) {
  if (['hfo','vlsfo','ulsfo','mdo','mgo','lsmgo','fo-settle','fo-service','do-service'].includes(type)) return 'Fuel Oils';
  if (['lo','lo-settle','lo-service'].includes(type)) return 'Lube Oils';
  if (['sludge','waste','dirty','scav'].includes(type)) return 'Sludge / Waste';
  if (['bilge','pumproom'].includes(type)) return 'Bilge / Holding';
  if (['slop','cargo','dirty-ballast'].includes(type)) return 'Cargo / Slop';
  if (type === 'bilgewell') return 'Bilge Wells';
  return 'Other';
}

function fmt2(v) { return (parseFloat(v)||0).toFixed(3); }
function fmt3(v) { return (parseFloat(v)||0).toFixed(3); }
function esc(s) { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

function rankAbbr(rank) {
  const MAP = {
    'Chief Engineer':            'CE',
    '2nd Engineer':              '2E',
    '3rd Engineer':              '3E',
    '4th Engineer':              '4E',
    'Junior 4th Engineer':       'J4E',
    'Electrician':               'ELC',
    'Motorman':                  'MTM',
    'Oiler':                     'OLR',
    'First Assistant Engineer':  '1AE',
    'Second Assistant Engineer': '2AE',
    'Third Assistant Engineer':  '3AE',
    'Fourth Assistant Engineer': '4AE',
    'Other':                     'OTH',
  };
  return MAP[rank] || rank;
}

// "Denis Garcia"             -> "D. GARCIA"
// "Maria Lourdes Santos"     -> "M. SANTOS"
// "Reyes"  (single token)    -> "REYES"
// "" / null                  -> ""
function nameInitial(fullName) {
  const s = String(fullName || '').trim();
  if (!s) return '';
  const parts = s.split(/\s+/).filter(Boolean);
  if (parts.length === 1) return parts[0].toUpperCase();
  const first = parts[0];
  const last  = parts[parts.length - 1];
  return first.charAt(0).toUpperCase() + '. ' + last.toUpperCase();
}

// ============================================================
// ROB EDIT MODAL
// ============================================================
function openRobEditModal(tankId) {
  const tanks = getTanks();
  const sel = document.getElementById('rob-edit-tank');
  sel.innerHTML = tanks.filter(t => !t.isBilgeWell).map(t =>
    `<option value="${t.id}" ${t.id===tankId?'selected':''}>${esc(t.name)}</option>`
  ).join('');
  updateRobEditFields();
  openModal('rob-edit-modal');
}

function updateRobEditFields() {
  const tanks = getTanks();
  const id = document.getElementById('rob-edit-tank').value;
  const t = tanks.find(x => x.id === id);
  if (!t) return;
  document.getElementById('rob-edit-value').value = t.rob;
  document.getElementById('rob-edit-unit').value  = t.unit;
  document.getElementById('rob-edit-current').textContent =
    'Current: ' + fmt2(t.rob) + ' ' + t.unit + '  |  Capacity: ' + (t.capacity ? fmt2(t.capacity) + ' ' + t.unit : 'N/A');
  updateRobDownReasonVisibility();
}

// Item 4c — show "ROB decrease justification" textarea only when the new ROB
// is less than the current ROB. Manual ROB-down breaks mass-balance and must
// be justified. Normal losses (evaporation, transfers, discharges) are not
// handled here — those have proper ORB activity entries that auto-update the
// tank via robChg. The sounding-edit modal is the manual override path only.
function updateRobDownReasonVisibility() {
  const tanks = getTanks();
  const id = (document.getElementById('rob-edit-tank') || {}).value || '';
  const t = tanks.find(x => x.id === id);
  const group = document.getElementById('rob-edit-downreason-group');
  if (!t || !group) return;
  const newVal = parseFloat((document.getElementById('rob-edit-value') || {}).value);
  const isDown = !isNaN(newVal) && newVal < t.rob;
  group.style.display = isDown ? '' : 'none';
}

function saveRobEdit() {
  const tanks = getTanks();
  const id     = document.getElementById('rob-edit-tank').value;
  const newRob = parseFloat(document.getElementById('rob-edit-value').value);
  const unit   = document.getElementById('rob-edit-unit').value;
  const reason = document.getElementById('rob-edit-reason').value;
  const remark = document.getElementById('rob-edit-remarks').value.trim();
  if (isNaN(newRob) || newRob < 0) { alert('Enter a valid ROB value.'); return; }
  const t = tanks.find(x => x.id === id);
  if (!t) return;
  const before = t.rob;
  // Item 4c — enforce justification when ROB is manually decreased
  let downReason = '';
  if (newRob < before) {
    const txta = document.getElementById('rob-edit-downreason');
    downReason = txta ? txta.value.trim() : '';
    if (!downReason) {
      alert('ROB-DOWN requires a written justification.\n\nLowering a tank ROB without a corresponding transfer or discharge breaks mass-balance. Type the reason in the "Justification for ROB Decrease" box, then try again.');
      if (txta) txta.focus();
      return;
    }
  }
  t.rob = newRob;
  t.unit = unit;
  if (!t.history) t.history = [];
  t.history.push({
    date: now(),
    before, after: newRob,
    reason,
    remarks: remark,
    type: 'manual',
    direction: newRob < before ? 'down' : (newRob > before ? 'up' : 'flat'),
    downReason: downReason || undefined
  });
  if (t.history.length > 20) t.history = t.history.slice(-20);
  saveTanks(tanks);
  // Reset the textarea + hide for next open
  const txta = document.getElementById('rob-edit-downreason');
  if (txta) txta.value = '';
  const group = document.getElementById('rob-edit-downreason-group');
  if (group) group.style.display = 'none';
  closeModal('rob-edit-modal');
  renderDashboard();
}

// ============================================================
// TANK HISTORY
// ============================================================
function showTankHistory(tankId) {
  const tanks = getTanks();
  const t = tanks.find(x => x.id === tankId);
  if (!t) return;
  const hist = (t.history || []).slice().reverse();
  let html = `<div style="font-family:var(--sans);font-size:13px;font-weight:700;color:var(--text);margin-bottom:12px;">${esc(t.name)}</div>`;
  if (!hist.length) {
    html += '<p style="color:var(--text3);font-size:13px;">No history recorded yet.</p>';
  } else {
    html += '<ul class="history-list">';
    hist.forEach(h => {
      const change = (h.after - h.before);
      const sign   = change >= 0 ? '+' : '';
      html += `<li class="history-item">
        <div class="history-dot"></div>
        <div>
          <div class="history-time">${fmtDate(h.date)} ${fmtTime(h.date)}</div>
          <div class="history-desc">${esc(h.reason || 'Transfer')}${h.remarks ? ' — ' + esc(h.remarks) : ''}</div>
          <div style="font-family:var(--mono);font-size:12px;margin-top:3px;">
            <span style="color:var(--text2)">${fmt2(h.before)}</span>
            <span style="color:var(--amber);margin:0 6px;">-></span>
            <span style="color:var(--green)">${fmt2(h.after)}</span>
            <span style="color:${change>=0?'var(--green)':'var(--red2)'};margin-left:8px;">(${sign}${fmt2(change)}) ${esc(t.unit)}</span>
          </div>
        </div>
      </li>`;
    });
    html += '</ul>';
  }
  document.getElementById('history-modal-body').innerHTML = html;
  openModal('history-modal');
}

// ============================================================
// TANK EDITOR
// ============================================================
// ============================================================
// CREW ROSTER
// ============================================================
function renderCrew() {
  const crew = loadCrew();
  const el = document.getElementById('crew-list-container');
  const countEl = document.getElementById('crew-count-label');
  if (countEl) countEl.textContent = crew.length ? crew.length + ' member' + (crew.length !== 1 ? 's' : '') : '';
  if (!el) return;
  if (!crew.length) {
    el.innerHTML = '<p style="color:var(--text3);font-family:var(--sans);font-size:13px;">No crew added yet. Click Add Crew Member to start.</p>';
    return;
  }
  // Group by rank category
  const rankOrder = ['Chief Engineer','2nd Engineer','3rd Engineer','4th Engineer','Junior 4th Engineer','First Assistant Engineer','Second Assistant Engineer','Third Assistant Engineer','Fourth Assistant Engineer','Electrician','Motorman','Oiler','Other'];
  const byRank = {};
  crew.forEach(c => {
    if (!byRank[c.rank]) byRank[c.rank] = [];
    byRank[c.rank].push(c);
  });
  let html = '<div class="crew-list">';
  rankOrder.forEach(rank => {
    if (!byRank[rank] || !byRank[rank].length) return;
    byRank[rank].forEach(c => {
      html += `<div class="crew-item">
        <div class="crew-item-name">${esc(c.name)}</div>
        <div class="crew-item-rank">${esc(c.rank)}</div>
        <div class="crew-item-actions">
          <button class="btn btn-secondary btn-sm" onclick="openCrewModal('${c.id}')">Edit</button>
          <button class="btn btn-danger btn-sm" onclick="deleteCrew('${c.id}')">Delete</button>
        </div>
      </div>`;
    });
  });
  html += '</div>';
  el.innerHTML = html;
}

function openCrewModal(id) {
  const crew = loadCrew();
  document.getElementById('crew-modal-title').textContent = id ? 'Edit Crew Member' : 'Add Crew Member';
  document.getElementById('crew-edit-id').value = id || '';
  if (id) {
    const c = crew.find(x => x.id === id);
    if (c) {
      document.getElementById('crew-name').value = c.name;
      document.getElementById('crew-rank').value = c.rank;
    }
  } else {
    document.getElementById('crew-name').value = '';
    document.getElementById('crew-rank').value = '2nd Engineer';
  }
  openModal('crew-modal');
}

function saveCrew() {
  const id   = document.getElementById('crew-edit-id').value;
  const name = document.getElementById('crew-name').value.trim().toUpperCase();
  const rank = document.getElementById('crew-rank').value;
  if (!name) { alert('Name is required.'); return; }
  const crew = loadCrew();
  if (id) {
    const c = crew.find(x => x.id === id);
    if (c) { c.name = name; c.rank = rank; }
  } else {
    crew.push({ id: uid(), name, rank });
  }
  localStorage.setItem(STORE_CREW, JSON.stringify(crew));
  closeModal('crew-modal');
  renderCrew();
}

function deleteCrew(id) {
  if (!confirm('Remove this crew member?')) return;
  const crew = loadCrew().filter(c => c.id !== id);
  localStorage.setItem(STORE_CREW, JSON.stringify(crew));
  renderCrew();
}

function crewOptsForRank(selectedName) {
  const crew = loadCrew();
  if (!crew.length) return `<option value="">-- no crew added --</option>`;
  return `<option value="">-- select officer --</option>` +
    crew.filter(c => c.rank !== 'Chief Engineer').map(c =>
      `<option value="${esc(c.name)}|${esc(c.rank)}" ${c.name === selectedName ? 'selected' : ''}>${esc(c.name)} (${esc(c.rank)})</option>`
    ).join('');
}

function toggleAccordion(el) {
  const group = el.closest('.accordion-group');
  if (group) group.classList.toggle('open');
}

function syncInvOfficerRank(i) { /* rank parsed from combined value on preview */ }

// ============================================================
// EQUIPMENT (item E)
// ============================================================
function renderEquipment() {
  const list = loadEquipment();
  const el = document.getElementById('equipment-list-container');
  if (!el) return;
  if (!list.length) {
    el.innerHTML = '<p style="color:var(--text3);font-family:var(--sans);font-size:13px;">No equipment configured.</p>';
    return;
  }
  const typeLabel = { ows: 'OWS / Overboard', sludge: 'Sludge Pump', cargo: 'Cargo Pump', other: 'Other' };
  let html = `<div class="table-wrap"><table class="data-table" style="width:100%;">
    <thead><tr><th>Name</th><th>Type</th><th style="text-align:right;">Rated (m3/h)</th><th>Notes</th><th></th></tr></thead><tbody>`;
  list.forEach(e => {
    html += `<tr>
      <td><strong>${esc(e.name)}</strong>${e.builtin ? ' <span class="badge badge-blue" style="margin-left:6px;">built-in</span>' : ''}</td>
      <td><span class="badge badge-amber">${esc(typeLabel[e.type] || e.type)}</span></td>
      <td class="mono" style="text-align:right;">${fmt2(e.rate)}</td>
      <td class="muted" style="font-size:12px;">${esc(e.notes || '')}</td>
      <td style="white-space:nowrap;">
        <button class="btn btn-secondary btn-sm" onclick="openEquipmentModal('${e.id}')" style="margin-right:4px;">Edit</button>
        ${e.builtin ? '' : `<button class="btn btn-danger btn-sm" onclick="deleteEquipment('${e.id}')">Delete</button>`}
      </td>
    </tr>`;
  });
  html += '</tbody></table></div>';
  el.innerHTML = html;
}

function openEquipmentModal(id) {
  const list = loadEquipment();
  document.getElementById('equipment-modal-title').textContent = id ? 'Edit Equipment' : 'Add Equipment';
  document.getElementById('equipment-edit-id').value = id || '';
  if (id) {
    const e = list.find(x => x.id === id);
    if (e) {
      document.getElementById('equipment-name').value  = e.name;
      document.getElementById('equipment-type').value  = e.type;
      document.getElementById('equipment-rate').value  = e.rate;
      document.getElementById('equipment-notes').value = e.notes || '';
    }
  } else {
    document.getElementById('equipment-name').value  = '';
    document.getElementById('equipment-type').value  = 'other';
    document.getElementById('equipment-rate').value  = '';
    document.getElementById('equipment-notes').value = '';
  }
  openModal('equipment-modal');
}

function saveEquipment() {
  const id    = document.getElementById('equipment-edit-id').value;
  const name  = document.getElementById('equipment-name').value.trim();
  const type  = document.getElementById('equipment-type').value;
  const rate  = parseFloat(document.getElementById('equipment-rate').value);
  const notes = document.getElementById('equipment-notes').value.trim();
  if (!name) { alert('Equipment name is required.'); return; }
  if (isNaN(rate) || rate <= 0) { alert('Rated capacity must be a positive number.'); return; }
  const list = loadEquipment();
  if (id) {
    const e = list.find(x => x.id === id);
    if (e) { e.name = name; e.type = type; e.rate = rate; e.notes = notes; }
  } else {
    list.push({ id: uid(), name, type, rate, notes, builtin: false });
  }
  saveEquipmentData(list);
  closeModal('equipment-modal');
  renderEquipment();
}

function deleteEquipment(id) {
  const list = loadEquipment();
  const e = list.find(x => x.id === id);
  if (!e) return;
  if (e.builtin) { alert('Built-in equipment cannot be deleted. You can edit its rated capacity instead.'); return; }
  if (!confirm('Delete "' + e.name + '"? This cannot be undone.')) return;
  saveEquipmentData(list.filter(x => x.id !== id));
  renderEquipment();
}

// Lookup helper used by transfer-rate validation
function getEquipmentByType(type) {
  return loadEquipment().filter(e => e.type === type);
}

// Validate that a transfer's vol/hours doesn't exceed any pump rate for the given type.
// Returns { ok: bool, msg: string }.
function validateTransferRate(type, volume, hours) {
  if (!hours || hours <= 0 || !volume || volume <= 0) return { ok: true, msg: '' };
  const eqs = getEquipmentByType(type);
  if (!eqs.length) return { ok: true, msg: '' };
  const rate = volume / hours;
  // Take the highest configured rate as the ceiling
  const maxRate = Math.max.apply(null, eqs.map(e => e.rate));
  if (rate > maxRate) {
    const unitLabel = type === 'ows'         ? 'OWS pump'
                    : type === 'sludge'      ? 'sludge pump'
                    : type === 'incinerator' ? 'incinerator burn'
                    : type === 'boiler'      ? 'boiler burn'
                    : type + ' unit';
    return {
      ok: false,
      msg: `Effective rate ${rate.toFixed(2)} m3/h exceeds the configured ${unitLabel} capacity of ${maxRate.toFixed(2)} m3/h. Re-check the duration or volume, or update the rated capacity in the Equipment tab.`
    };
  }
  return { ok: true, msg: '' };
}

function renderTankEditor() {
  const tanks = getTanks();
  const el = document.getElementById('tank-editor-table');
  if (!tanks.length) { el.innerHTML = '<p style="color:var(--text3);font-family:var(--sans);font-size:13px;">No tanks. Click Add Tank to begin.</p>'; return; }

  const groups = {};
  tanks.forEach(t => {
    const g = tankGroup(t.type);
    if (!groups[g]) groups[g] = [];
    groups[g].push(t);
  });

  function buildEditorRows(tList) {
    return tList.map(t => `<tr>
      <td style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><strong>${esc(t.name)}</strong>${t.isBilgeWell ? ' <span class="badge badge-blue" style="margin-left:6px;">Well</span>' : ''}</td>
      <td><span class="badge ${typeBadgeClass(t.type)}">${TYPE_LABELS[t.type]||t.type}</span></td>
      <td class="mono" style="text-align:right;">${t.isBilgeWell ? '<span style="color:var(--text3)">—</span>' : fmt2(t.capacity)}</td>
      <td class="mono amber" style="text-align:right;">${t.isBilgeWell ? '<span style="color:var(--text3)">—</span>' : fmt2(t.rob)}</td>
      <td class="mono muted">${t.unit}</td>
      <td class="mono muted">${t.ioppc || '—'}</td>
      <td class="mono muted" style="font-size:11px;">${t.frameNo || '—'}</td>
      <td style="white-space:nowrap;">
        <button class="btn btn-secondary btn-sm" onclick="openEditTankModal('${t.id}')" style="margin-right:4px;">Edit</button>
        <button class="btn btn-danger btn-sm" onclick="deleteTank('${t.id}')">Delete</button>
      </td>
    </tr>`).join('');
  }

  const groupOrder = ['Fuel Oils', 'Lube Oils', 'Sludge / Waste', 'Bilge / Holding', 'Cargo / Slop', 'Bilge Wells', 'Other'];
  let html = '';
  groupOrder.forEach(g => {
    if (!groups[g] || !groups[g].length) return;
    html += `<div class="accordion-group open" style="margin-bottom:12px;">
      <div class="accordion-header" onclick="toggleAccordion(this)">
        <div class="accordion-header-title">${g}</div>
        <div class="accordion-header-meta">${groups[g].length} tank${groups[g].length!==1?'s':''}</div>
        <svg class="accordion-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
      </div>
      <div class="accordion-body">
        <div style="overflow-x:auto;">
          <table class="data-table" style="width:100%;table-layout:fixed;">
            <colgroup><col style="width:180px"><col style="width:120px"><col style="width:85px"><col style="width:85px"><col style="width:55px"><col style="width:65px"><col style="width:80px"><col style="width:120px"></colgroup>
            <thead><tr>
              <th>Name</th><th>Type</th><th style="text-align:right;">Capacity</th><th style="text-align:right;">ROB</th><th>Unit</th><th>IOPPC</th><th>Frames</th><th></th>
            </tr></thead>
            <tbody>${buildEditorRows(groups[g])}</tbody>
          </table>
        </div>
      </div>
    </div>`;
  });
  el.innerHTML = html;
}

function openAddTankModal() {
  document.getElementById('tank-modal-title').textContent = 'Add Tank';
  document.getElementById('tank-edit-id').value = '';
  document.getElementById('tank-name').value = '';
  document.getElementById('tank-type').value = 'bilge';
  document.getElementById('tank-unit').value = 'm3';
  document.getElementById('tank-capacity').value = '';
  document.getElementById('tank-rob').value = '';
  document.getElementById('tank-ioppc').value = '';
  document.getElementById('tank-frameno').value = '';
  document.getElementById('tank-capacity-row').style.display = '';
  openModal('tank-modal');
}

function openEditTankModal(id) {
  const t = getTanks().find(x => x.id === id);
  if (!t) return;
  document.getElementById('tank-modal-title').textContent = 'Edit Tank';
  document.getElementById('tank-edit-id').value  = t.id;
  document.getElementById('tank-name').value     = t.name;
  document.getElementById('tank-type').value     = t.type;
  document.getElementById('tank-unit').value     = t.unit;
  document.getElementById('tank-capacity').value = t.capacity;
  document.getElementById('tank-rob').value      = t.rob;
  document.getElementById('tank-ioppc').value    = t.ioppc || '';
  document.getElementById('tank-frameno').value  = t.frameNo || '';
  document.getElementById('tank-capacity-row').style.display = t.isBilgeWell ? 'none' : '';
  openModal('tank-modal');
}

// Buffer for the tank-impact-modal flow. Holds the pending edit until the user confirms.
var _pendingTankEdit = null;

function saveTank() {
  const id   = document.getElementById('tank-edit-id').value;
  // Preserve the tank name EXACTLY as typed — no auto-trim, no case change, no
  // whitespace normalization. Tank names appear verbatim in the legal ORB and
  // even a capitalization difference can be flagged as a PSC deficiency.
  const name = document.getElementById('tank-name').value;
  const type = document.getElementById('tank-type').value;
  if (!name || !name.trim()) { alert('Tank name required.'); return; }
  const isBilgeWell = (type === 'bilgewell');
  const unit     = document.getElementById('tank-unit').value;
  const capacity = parseFloat(document.getElementById('tank-capacity').value) || 0;
  const rob      = parseFloat(document.getElementById('tank-rob').value) || 0;
  const ioppc    = document.getElementById('tank-ioppc').value.trim();
  const frameNoRaw = document.getElementById('tank-frameno').value.trim();
  const frameNo = (function() {
    if (!frameNoRaw) return '';
    const nums = frameNoRaw.replace(/[^0-9]+/g, ' ').trim().split(/\s+/).filter(Boolean).map(Number);
    if (nums.length >= 2) return 'FR: ' + nums[0] + ' - ' + nums[1];
    if (nums.length === 1) return 'FR: ' + nums[0];
    return frameNoRaw;
  })();
  const tanks    = getTanks();

  if (!id) {
    // Adding a new tank — no impact to check
    tanks.push({ id: uid(), name, type, isBilgeWell, capacity, rob, unit, ioppc, frameNo, history: [] });
    saveTanks(tanks);
    closeModal('tank-modal');
    renderTankEditor();
    return;
  }

  const t = tanks.find(x => x.id === id);
  if (!t) { closeModal('tank-modal'); return; }
  const oldName     = t.name;
  const oldCapacity = t.capacity || 0;

  // Item 4a — rename detection. Build the affected-entries list.
  const renamed = (oldName !== name) && !!oldName;
  const entries = renamed ? loadEntries() : [];
  const affected = [];
  if (renamed) {
    entries.forEach(e => {
      (e.formatted || []).forEach(f => {
        if (f.text && f.text.includes(oldName)) {
          affected.push({
            entryId: e.id,
            date: e.date,
            code: e.code,
            op: e.operationType,
            preview: f.text.length > 80 ? f.text.slice(0, 77) + '...' : f.text
          });
        }
      });
    });
  }

  // Item 4b — capacity-vs-history detection. Past ROB values, current ROB, and any future expected entries.
  const capacityWarns = [];
  if (capacity > 0 && oldCapacity !== capacity) {
    // Walk past tank history to find any value above the new capacity
    (t.history || []).forEach(h => {
      if (typeof h.after === 'number' && h.after > capacity) {
        capacityWarns.push({ when: h.date || 'unknown', value: h.after, what: 'historical ROB exceeded new capacity' });
      }
    });
    if (rob > capacity) {
      capacityWarns.push({ when: 'current', value: rob, what: 'current ROB exceeds new capacity — this will save anyway, fix manually' });
    }
  }

  _pendingTankEdit = {
    id, name, type, isBilgeWell, unit, capacity, rob, ioppc, frameNo,
    oldName, renamed, affected, capacityWarns
  };

  if (!renamed && capacityWarns.length === 0) {
    // No impact — save straight through
    applyTankEdit(true);
    return;
  }

  // Render the impact modal
  let body = '';
  if (renamed) {
    body += `<div style="margin-bottom:14px;"><strong style="color:var(--text);">Rename:</strong> &ldquo;${esc(oldName)}&rdquo; &rarr; &ldquo;${esc(name)}&rdquo;</div>`;
    if (affected.length) {
      body += `<div style="margin-bottom:8px;">${affected.length} ORB entry line${affected.length===1?'':'s'} mention the old name. Choose:</div>`;
      body += `<ul style="margin:0 0 14px 18px;font-family:var(--mono);font-size:12px;color:var(--text2);max-height:180px;overflow-y:auto;">`;
      affected.slice(0, 12).forEach(a => {
        body += `<li style="margin-bottom:4px;"><span style="color:var(--text3);">${esc(a.date)} ${esc(a.code)}</span> ${esc(a.preview)}</li>`;
      });
      if (affected.length > 12) body += `<li style="color:var(--text3);">... and ${affected.length - 12} more</li>`;
      body += `</ul>`;
    } else {
      body += `<div style="color:var(--text3);margin-bottom:14px;">No existing ORB log entries reference the old name.</div>`;
    }
  }
  if (capacityWarns.length) {
    body += `<div style="margin-top:8px;padding:10px 12px;background:rgba(224,0,85,0.06);border-left:3px solid #e05;border-radius:3px;">`;
    body += `<strong style="color:#c70042;">Capacity conflict:</strong> ${esc(oldCapacity)} &rarr; ${esc(capacity)} ${esc(unit)}<br>`;
    capacityWarns.forEach(w => {
      body += `<div style="font-family:var(--mono);font-size:12px;margin-top:4px;">${esc(String(w.when))}: ${esc(String(w.value))} ${esc(unit)} &mdash; ${esc(w.what)}</div>`;
    });
    body += `</div>`;
  }
  document.getElementById('tank-impact-body').innerHTML = body;

  // Show the "skip rewrite" button only when there are entries to rewrite
  const skipBtn = document.getElementById('tank-impact-skip');
  if (skipBtn) skipBtn.style.display = (renamed && affected.length) ? '' : 'none';

  openModal('tank-impact-modal');
}

function confirmSaveTank(rewriteEntries) {
  applyTankEdit(!!rewriteEntries);
}

function applyTankEdit(rewriteEntries) {
  const p = _pendingTankEdit;
  if (!p) { closeModal('tank-impact-modal'); closeModal('tank-modal'); return; }
  const tanks = getTanks();
  const t = tanks.find(x => x.id === p.id);
  if (t) {
    t.name = p.name; t.type = p.type; t.isBilgeWell = p.isBilgeWell;
    t.unit = p.unit; t.capacity = p.capacity; t.rob = p.rob; t.ioppc = p.ioppc; t.frameNo = p.frameNo || '';
    if (p.renamed && rewriteEntries) {
      const entries = loadEntries();
      let changed = false;
      entries.forEach(e => {
        (e.formatted || []).forEach(f => {
          if (f.text && f.text.includes(p.oldName)) {
            f.text = f.text.split(p.oldName).join(p.name);
            changed = true;
          }
        });
      });
      if (changed) saveEntries(entries);
    }
  }
  saveTanks(tanks);
  _pendingTankEdit = null;
  closeModal('tank-impact-modal');
  closeModal('tank-modal');
  renderTankEditor();
  var bookModal = document.getElementById('book-modal');
  if (bookModal && !bookModal.classList.contains('hidden')) {
    if (typeof openBookPreview === 'function') openBookPreview();
  }
}

// Buffer for the tank-delete-modal flow
var _pendingTankDeleteId = null;

function deleteTank(id) {
  const tank = getTanks().find(t => t.id === id);
  if (!tank) return;
  const tankName = tank.name;
  const entries = loadEntries();
  const refs = [];
  entries.forEach(e => {
    let mentioned = false;
    (e.formatted || []).forEach(f => {
      if (f.tankId === id) mentioned = true;
      if (f.text && f.text.includes(tankName)) mentioned = true;
    });
    if ((e.robChg || []).some(rc => rc.tankId === id)) mentioned = true;
    if (mentioned) refs.push({ id: e.id, date: e.date, code: e.code, op: e.operationType });
  });
  _pendingTankDeleteId = id;
  let body = `<div style="margin-bottom:12px;"><strong style="color:var(--text);">Delete:</strong> &ldquo;${esc(tankName)}&rdquo;</div>`;
  if (refs.length) {
    body += `<div style="margin-bottom:8px;">${refs.length} ORB log ${refs.length===1?'entry references':'entries reference'} this tank:</div>`;
    body += `<ul style="margin:0 0 8px 18px;font-family:var(--mono);font-size:12px;color:var(--text2);max-height:180px;overflow-y:auto;">`;
    refs.slice(0, 15).forEach(r => {
      body += `<li style="margin-bottom:3px;"><span style="color:var(--text3);">${esc(r.date)} ${esc(r.code)}</span> ${esc(r.op || '')}</li>`;
    });
    if (refs.length > 15) body += `<li style="color:var(--text3);">... and ${refs.length - 15} more</li>`;
    body += `</ul>`;
    body += `<div style="color:var(--text3);font-size:12px;">Deleting the tank does NOT modify these entries. They remain in your log with the tank name preserved.</div>`;
  } else {
    body += `<div style="color:var(--text3);">No ORB log entries reference this tank.</div>`;
  }
  document.getElementById('tank-delete-body').innerHTML = body;
  openModal('tank-delete-modal');
}

function confirmDeleteTank() {
  const id = _pendingTankDeleteId;
  if (!id) { closeModal('tank-delete-modal'); return; }
  const tanks = getTanks().filter(t => t.id !== id);
  saveTanks(tanks);
  _pendingTankDeleteId = null;
  closeModal('tank-delete-modal');
  renderTankEditor();
}

function resetDefaultTanks(type) {
  if (!confirm('This will replace all tanks with ' + (type==='dry'?'Dry Fleet':'Tanker') + ' defaults. Continue?')) return;
  saveTanks(type === 'dry' ? dryFleetDefaults() : tankerDefaults());
  renderTankEditor();
}

// ============================================================
// ORB LOG RENDERER
// ============================================================
function renderLog() {
  const entries = loadEntries();
  const el = document.getElementById('orb-log-table');
  if (!entries.length) {
    el.innerHTML = '<p style="color:var(--text3);font-family:var(--sans);font-size:13px;">No entries yet. Use New Entry to record operations.</p>';
    return;
  }
  const sorted = [...entries].reverse();
  let html = `<div class="table-wrap"><table class="data-table">
    <thead><tr><th>Date</th><th>Time</th><th>Code</th><th>Operation</th><th>Officer</th><th>Rank</th><th></th></tr></thead><tbody>`;
  sorted.forEach(e => {
    const isCorrected = !!e.corrected;
    const rowStyle = isCorrected ? 'opacity:0.55;' : '';
    const textStyle = isCorrected ? 'text-decoration:line-through;' : '';
    const corrStamp = isCorrected ? `<div style="display:inline-block;margin-left:6px;padding:1px 7px;border:1.5px solid var(--red2,#e05);border-radius:3px;font-family:var(--mono);font-size:10px;font-weight:700;color:var(--red2,#e05);letter-spacing:0.1em;transform:rotate(-2deg);white-space:nowrap;">CORRECTED — ${esc(e.correctedBy||'CE')} ${esc(e.correctedAt||'')}</div>` : '';
    html += `<tr style="${rowStyle}">
      <td class="mono" style="${textStyle}">${esc(e.date)}</td>
      <td class="mono muted" style="${textStyle}">${esc(e.time)}</td>
      <td><span class="badge badge-amber" style="${textStyle}">${esc(e.code)}</span></td>
      <td style="${textStyle}">${esc(e.operationType)}${corrStamp}</td>
      <td class="mono" style="${textStyle}">${esc(e.officer||'—')}</td>
      <td class="muted" style="${textStyle}">${esc(rankAbbr(e.rank||'—'))}</td>
      <td style="white-space:nowrap;">
        <button class="btn btn-secondary btn-sm" onclick="viewEntry('${e.id}')" style="margin-right:4px;">View</button>
        <button class="btn btn-danger btn-sm" onclick="deleteEntry('${e.id}')">Delete</button>
      </td>
    </tr>`;
  });
  html += '</tbody></table></div>';
  el.innerHTML = html;
}

function viewEntry(id) {
  const e = loadEntries().find(x => x.id === id);
  if (!e) return;
  document.getElementById('entry-view-body').innerHTML =
    buildOrbPreviewHTML({ formatted: e.formatted || [], officer: e.officer, rank: e.rank, date: e.date, attachment: e.attachment || null }) +
    `<div class="orb-disclaimer" style="margin-top:16px;padding:12px 16px;background:var(--bg3);border:1px solid var(--border);border-radius:2px;font-family:var(--body);font-size:12px;color:var(--text3);line-height:1.6;">
      <strong style="color:var(--amber)">EDUCATIONAL SAMPLE ONLY.</strong> This entry is for practice and familiarization purposes. It is not a legal Oil Record Book entry. Actual ORB entries must follow vessel procedures, company SMS, MARPOL regulations, flag state requirements, and Chief Engineer instructions.
    </div>`;
  openModal('entry-view-modal');
}

function deleteEntry(id) {
  if (!confirm('Delete this entry? Cannot be undone.')) return;
  const entries = loadEntries().filter(e => e.id !== id);
  saveEntries(entries);
  renderLog();
}

function clearLog() {
  const entries = loadEntries();
  if (!entries.length) { alert('No entries to clear.'); return; }
  if (!confirm('Clear ALL ' + entries.length + ' ORB log entries?\n\nA backup file will be downloaded automatically before clearing.')) return;
  if (!confirm('Are you sure? This cannot be undone.')) return;
  // Auto-export backup before clearing
  try {
    const data = { tanks: getTanks(), entries: entries, settings: loadSettings(), exportedAt: now(), note: 'Auto-backup before Clear All' };
    const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = 'orb-backup-before-clear-' + new Date().toISOString().slice(0,10) + '.json';
    a.click();
  } catch(e) { /* backup failed — still allow clear */ }
  saveEntries([]);
  renderLog();
}

function exportLog() {
  const data = { tanks: getTanks(), entries: loadEntries(), settings: loadSettings(), exportedAt: now() };
  const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'orb-backup-' + new Date().toISOString().slice(0,10) + '.json';
  a.click();
}

function importLog() { document.getElementById('import-file').click(); }

function handleImport(e) {
  const file = e.target.files[0];
  if (!file) return;
  const r = new FileReader();
  r.onload = ev => {
    // Snapshot current data for rollback
    const backup = {
      tanks:    localStorage.getItem(STORE_TANKS),
      entries:  localStorage.getItem(STORE_ENTRIES),
      settings: localStorage.getItem(STORE_SETTINGS)
    };
    function rollback() {
      try {
        if (backup.tanks    !== null) localStorage.setItem(STORE_TANKS,    backup.tanks);
        if (backup.entries  !== null) localStorage.setItem(STORE_ENTRIES,  backup.entries);
        if (backup.settings !== null) localStorage.setItem(STORE_SETTINGS, backup.settings);
      } catch(re) { /* best effort */ }
    }
    try {
      const d = JSON.parse(ev.target.result);
      if (!d || typeof d !== 'object') throw new Error('File is not a valid ORB backup.');
      if (!d.entries && !d.tanks && !d.settings) throw new Error('File does not contain any recognizable ORB data.');
      if (d.tanks    && !Array.isArray(d.tanks))    throw new Error('tanks field is not an array.');
      if (d.entries  && !Array.isArray(d.entries))  throw new Error('entries field is not an array.');
      if (d.tanks)    saveTanks(d.tanks);
      if (d.entries)  saveEntries(d.entries);
      if (d.settings) saveSettings(d.settings);
      alert('Import successful. ' + (d.entries||[]).length + ' entries loaded.');
      renderLog();
      renderDashboard();
    } catch(err) {
      rollback();
      alert('Import failed: ' + err.message + '\n\nYour previous data has been restored.');
    }
  };
  r.onerror = function() {
    alert('Could not read the file. Please try again.');
  };
  r.readAsText(file);
  e.target.value = '';
}

// ============================================================
// BOOK PREVIEW (Electronic Record Book View)
// ============================================================
function printRecordBook() {
  const entries = loadEntries();
  const settings = loadSettings();
  const vesselName = (settings.vesselName || 'MV PRACTICE VESSEL').toUpperCase();
  const officialNo = settings.imo || '';
  const container = document.getElementById('print-record-container');
  if (!entries.length) {
    alert('No entries recorded yet.');
    return;
  }
  container.innerHTML = buildBookPages(entries, vesselName, officialNo);
  window.print();
  window.addEventListener('afterprint', function cleanup() {
    container.innerHTML = '';
    window.removeEventListener('afterprint', cleanup);
  });
}

function openBookPreview() {
  const entries = loadEntries();
  const settings = loadSettings();
  const vesselName = (settings.vesselName || 'MV PRACTICE VESSEL').toUpperCase();
  const officialNo = settings.imo || '';
  const container = document.getElementById('book-pages-container');
  if (!entries.length) {
    container.innerHTML = '<div class="book-empty">No entries recorded yet.<br>Use New Entry to begin.</div>';
    openModal('book-modal');
    maybeShowSigAbbrevModal();
    return;
  }
  const sortedForBook = [...entries].sort((a, b) => new Date(a.date) - new Date(b.date));
  container.innerHTML = buildBookPages(sortedForBook, vesselName, officialNo);
  openModal('book-modal');
  maybeShowSigAbbrevModal();
}

function maybeShowSigAbbrevModal() {
  try {
    if (window.matchMedia && !window.matchMedia('(max-width: 768px)').matches) return;
    if (localStorage.getItem('orb_seen_sig_abbrev') === '1') return;
    setTimeout(() => openModal('sig-abbrev-modal'), 400);
  } catch (e) {}
}

function dismissSigAbbrevModal() {
  try { localStorage.setItem('orb_seen_sig_abbrev', '1'); } catch (e) {}
  closeModal('sig-abbrev-modal');
}

function buildBookPages(entries, vesselName, officialNo) {
  // Flatten all formatted lines, preserving entry metadata per row.
  // _sigTank lines become inline sig rows (per-tank, C11-inv).
  // All other entries get one sig pair at end (_lastInEntry).
  const _settings = loadSettings();
  const _defaultCEName = (_settings.ceName || '').trim() || (loadCrew().find(c => c.rank === 'Chief Engineer') || {}).name || '';
  const allRows = [];
  entries.forEach(entry => {
    const lines = entry.formatted || [];
    const isCorrected    = !!entry.corrected;
    const correctedBy    = entry.correctedBy  || 'CE';
    const correctedAt    = entry.correctedAt  || '';
    // Detect C11-inv multi-sig style:
    // Either has explicit _sigTank markers (new entries),
    // or is Code C inventory with multiple 11.1/11.2/11.3 groups (old entries).
    // C11-coll also has 11.3 but is followed by 11.4 — exclude it.
    const hasExplicitSigTank = lines.some(l => l._sigTank);
    const count111 = lines.filter(l => (l.item || '').trim() === '11.1').length;
    const hasItem114 = lines.some(l => (l.item || '').trim() === '11.4');
    // isMultiSig: explicit markers OR Code C inventory (has 11.1+11.3, no 11.4 = not C11-coll)
    const hasItem113 = lines.some(l => (l.item || '').trim() === '11.3');
    const isMultiSig = hasExplicitSigTank || (count111 >= 1 && hasItem113 && !hasItem114);
    if (isMultiSig) {
      // Rebuild lines: inject synthetic _sigTank after each 11.3 if no explicit markers
      const processedLines = hasExplicitSigTank ? lines : (() => {
        const out = [];
        lines.forEach((l, li) => {
          out.push(l);
          if ((l.item || '').trim() === '11.3') {
            // Find the per-tank officer from the next _sigTank marker or use entry officer
            const nextSig = lines.slice(li + 1).find(x => x._sigTank);
            out.push({
              _sigTank: true,
              officer:   nextSig ? nextSig.officer  : (entry.officer || ''),
              rank:      nextSig ? nextSig.rank     : (entry.rank    || ''),
              ceName:    nextSig ? nextSig.ceName   : (entry.ceName  || _defaultCEName || ''),
              entryDate: entry.date || '',
            });
          }
        });
        return out;
      })();

      // Each _sigTank line becomes a sig-row-pair; data lines are normal rows
      processedLines.forEach(l => {
        if (l._sigTank) {
          // Inline per-tank sig pair
          allRows.push({
            _isSigTankRow: true,
            _officer:  l.officer  || '',
            _rank:     l.rank     || '',
            _ceName:   l.ceName   || _defaultCEName || '',
            _entryId:  entry.id,
            _officerSig: entry.officerSigImg || null,
            _ceSig:      entry.ceSigImg      || null,
            _date:     l.entryDate || entry.date || '',
            _corrected:   isCorrected,
            _correctedBy: correctedBy,
            _correctedAt: correctedAt,
          });
        } else {
          const subLines = (l.text || '').split('\n');
          subLines.forEach((sl, si) => {
            // Code-letter rows must always carry a date. Fall back to entry.date when row data omits it.
            const rowCode = (si === 0) ? (l.code || '') : '';
            const rowDate = (si === 0) ? ((l.date || '') || (rowCode ? (entry.date || '') : '')) : '';
            allRows.push({
              date: esc(rowDate),
              code: esc(rowCode),
              item: (si === 0) ? esc(l.item || '') : '',
              text: esc(sl),
              _entryId: entry.id,
              _lastInEntry: false,
              _corrected:   isCorrected,
              _correctedBy: correctedBy,
              _correctedAt: correctedAt,
            });
          });
        }
      });
    } else {
      lines.forEach((l, li) => {
        const subLines = (l.text || '').replace(/\s*\[Sec\.3\.3\]/g, '').split('\n');
        subLines.forEach((sl, si) => {
          const isLast = (li === lines.length - 1) && (si === subLines.length - 1);
          // Code-letter rows must always carry a date. Per-line date falls back to entry.date.
          const rowCode = (li === 0 && si === 0) ? (l.code || '') : ((si === 0) ? (l.code || '') : '');
          const rowDateRaw = (si === 0) ? (l.date || '') : '';
          const rowDate = rowDateRaw || (rowCode ? (entry.date || '') : '');
          allRows.push({
            date:    esc(rowDate),
            code:    esc(rowCode),
            item:    (si === 0)             ? esc(l.item || '')  : '',
            text:    esc(sl),
            _officer:      entry.officer || '',
            _rank:         entry.rank    || '',
            _ceName:       entry.ceName || _defaultCEName || '',
            _entryId:      entry.id,
            _lastInEntry:  isLast,
            _officerSig:   isLast ? (entry.officerSigImg || null) : null,
            _ceSig:        isLast ? (entry.ceSigImg      || null) : null,
            _date:         entry.date || '',
            _corrected:    isCorrected,
            _correctedBy:  correctedBy,
            _correctedAt:  correctedAt,
          });
        });
      });
    }
  });

  // Each signature pair counts as 2 rows toward page capacity
  const ROWS_PER_PAGE = 18;
  const pages         = [];
  let   cur           = [];
  let   curCount      = 0;

  allRows.forEach(row => {
    // _isSigTankRow = 2 rows (officer + CE); _lastInEntry = data+2 sigs = 3; else 1
    const rowCost = row._isSigTankRow ? 2 : (row._lastInEntry ? 3 : 1);
    if (curCount + rowCost > ROWS_PER_PAGE && cur.length) {
      pages.push(cur);
      cur = []; curCount = 0;
    }
    cur.push(row);
    curCount += rowCost;
  });
  if (cur.length) pages.push(cur);

  // Item B (revised 2026-05-19): NO "(continued)" marker is injected.
  //   Per Roy: the Record Book view mirrors the physical logbook; MARPOL does
  //   not recognize a "(continued)" annotation and PSC could flag it as a
  //   non-conformant entry. When an entry spans pages, content + signatures
  //   simply flow to the next page with no synthetic header row.
  //
  //   To avoid orphaned signature pairs (sig row alone at top of next page),
  //   keep the last data row glued to its signatures: if a page break would
  //   land between the final data row of an entry and its sig row, pull the
  //   sig pair back onto the previous page when the previous page has room,
  //   else push the trailing data row forward to sit with its sigs.
  for (let pi = 0; pi < pages.length - 1; pi++) {
    const thisPage = pages[pi];
    const nextPage = pages[pi + 1];
    if (!thisPage.length || !nextPage.length) continue;
    const nextFirst = nextPage[0];
    // Orphan sig row at top of next page (sig follows immediately, no preceding data)
    if (nextFirst._lastInEntry && nextFirst._officer !== undefined) {
      const thisPageEntryRows = thisPage.filter(r => r._entryId === nextFirst._entryId);
      if (thisPageEntryRows.length > 0) {
        // The data is on this page; pull last data row forward so it sits with its sig
        const lastDataIdx = (() => {
          for (let i = thisPage.length - 1; i >= 0; i--) {
            if (thisPage[i]._entryId === nextFirst._entryId) return i;
          }
          return -1;
        })();
        if (lastDataIdx >= 0) {
          const moved = thisPage.splice(lastDataIdx, 1)[0];
          nextPage.unshift(moved);
        }
      }
    }
  }

  function sigCell(dataUrl, roleLabel, officer, rank, entryId, sigType, entryDate) {
    const editBtn = `<button class="book-sig-edit-btn" onclick="openBookSigModal('${entryId}','${sigType}')" title="Sign here">&#9998;</button>`;
    // Build full + short role tags; CSS picks one based on viewport
    const shortLabel = roleLabel === 'Officer in Charge' ? 'OIC' : (roleLabel === 'Chief Engineer' ? 'CE' : roleLabel);
    const roleFull   = `<span class="sig-role-full">${esc(roleLabel)}</span>`;
    const roleShort  = `<span class="sig-role-short">${esc(shortLabel)}</span>`;
    const officerSpan = officer ? `<span class="sig-officer-name"> &mdash; ${esc(nameInitial(officer))}${rank ? ' / ' + esc(rankAbbr(rank)) : ''}</span>` : '';
    const roleBlock  = `<span class="sig-role-inline">${roleFull}${roleShort}${officerSpan}</span>`;
    const sigBlock  = dataUrl
      ? `<img src="${dataUrl}" class="book-sig-img" style="max-height:22px;max-width:100px;display:block;mix-blend-mode:multiply;">`
      : `<span class="sig-blank-line" style="display:inline-block;width:80px;height:14px;border-bottom:1px solid #aaa;"></span>`;
    const dateBlock = `<span class="book-sig-date" style="color:#444;white-space:nowrap;">${esc(entryDate)}</span>`;
    return `<div class="book-sig-row" style="display:flex;align-items:center;gap:8px;padding:0;line-height:1.2;overflow:hidden;width:100%;">
      <div class="book-sig-role-wrap" style="flex:0 0 auto;max-width:55%;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${roleBlock}</div>
      <div class="book-sig-mid" style="flex:1;display:flex;align-items:center;gap:4px;min-width:0;">${editBtn}${sigBlock}</div>
      <div class="book-sig-date-wrap" style="flex:0 0 auto;text-align:right;white-space:nowrap;">${dateBlock}</div>
    </div>`;
  }

  let html = '';
  pages.forEach((pageRows, pi) => {
    let lastOfficer = '', lastRank = '';
    for (let i = pageRows.length - 1; i >= 0; i--) {
      if (pageRows[i]._officer) { lastOfficer = pageRows[i]._officer; lastRank = pageRows[i]._rank; break; }
    }
    const pageNum = pi + 1;

    html += `<div class="book-page">
      <div class="book-page-watermark">EDUCATIONAL SAMPLE</div>

      <div class="book-page-header">
        <div class="book-page-header-field">
          <span class="book-field-label">NAME OF SHIP :</span>
          <span class="book-field-value">${esc(vesselName)}</span>
        </div>
        <div class="book-page-header-field" style="max-width:260px;flex:0 0 260px;">
          <span class="book-field-label">OFFICIAL NUMBER :</span>
          <span class="book-field-value">${esc(officialNo) || ''}</span>
        </div>
      </div>

      <div class="book-page-title">
        <span class="title-big">MACHINERY SPACE OPERATIONS</span>
      </div>

      <table class="book-table">
        <thead>
          <tr>
            <th class="book-th-date">Date</th>
            <th class="book-th-code">Code<span class="th-sub">(letter)</span></th>
            <th class="book-th-item">Item<span class="th-sub">(number)</span></th>
            <th class="book-th-rec">Record of operations / signature of officer in charge</th>
          </tr>
        </thead>
        <tbody>`;

    // Pre-compute middle row index for each corrected entry on this page
    // (so the stamp lands at center-middle over the strikethrough block)
    const correctedMiddleByEntry = {};
    const correctedRowsByEntry = {};
    pageRows.forEach((row, idx) => {
      if (row._corrected && row._entryId) {
        if (!correctedRowsByEntry[row._entryId]) correctedRowsByEntry[row._entryId] = [];
        correctedRowsByEntry[row._entryId].push(idx);
      }
    });
    Object.keys(correctedRowsByEntry).forEach(eid => {
      const arr = correctedRowsByEntry[eid];
      correctedMiddleByEntry[eid] = arr[Math.floor(arr.length / 2)];
    });

    pageRows.forEach((row, idx) => {
      const isCorrMiddle = row._corrected && row._entryId && correctedMiddleByEntry[row._entryId] === idx;
      const corrSigImg = (isCorrMiddle && row._ceSig)
        ? `<img src="${row._ceSig}" style="max-height:22px;max-width:90px;display:inline-block;mix-blend-mode:multiply;vertical-align:middle;margin-left:4px;">`
        : (isCorrMiddle ? `<span style="display:inline-block;width:60px;border-bottom:1px solid #e05;margin-left:4px;vertical-align:middle;"></span>` : '');
      const corrStampOverlay = isCorrMiddle
        ? `<div class="book-stamp-wrap" style="position:absolute;left:50%;top:50%;transform:translate(-50%,-50%) rotate(-4deg);z-index:5;pointer-events:none;text-decoration:none !important;"><span class="book-stamp-corrected" style="display:inline-flex;align-items:center;padding:4px 12px;background:rgba(255,255,255,0.82);border:2px solid #e05;border-radius:4px;font-family:monospace;font-size:10.5px;font-weight:700;color:#e05;letter-spacing:0.08em;white-space:nowrap;line-height:1.2;box-shadow:0 1px 2px rgba(224,0,85,0.15);text-decoration:none;">CORRECTED &mdash; CE ${esc(row._correctedBy)} ${esc(row._correctedAt)}${corrSigImg}</span></div>`
        : '';

      if (row._isSigTankRow) {
        // Per-tank sig pair (C11-inv multi-sig)
        const sigRowStyle = row._corrected ? ' style="opacity:0.55;"' : '';
        const sigTdStyle  = row._corrected ? ' style="text-decoration:line-through;"' : '';
        const stampCellStyle = isCorrMiddle ? ' style="position:relative;overflow:visible;"' : '';
        const stampInner = isCorrMiddle
          ? `<div style="position:relative;overflow:visible;">${sigCell(row._officerSig, 'Officer in Charge', row._officer, row._rank, row._entryId, 'officer', row._date)}${corrStampOverlay}</div>`
          : sigCell(row._officerSig, 'Officer in Charge', row._officer, row._rank, row._entryId, 'officer', row._date);
        html += `<tr class="book-sig-row"${sigRowStyle}>
          <td class="sig-blank-left"${sigTdStyle}></td>
          <td class="sig-blank-left"${sigTdStyle}></td>
          <td class="sig-blank-left"${sigTdStyle}></td>
          <td class="sig-img-cell"${stampCellStyle}>${stampInner}</td>
        </tr>`;
        html += `<tr class="book-sig-row"${sigRowStyle}>
          <td class="sig-blank-left"${sigTdStyle}></td>
          <td class="sig-blank-left"${sigTdStyle}></td>
          <td class="sig-blank-left"${sigTdStyle}></td>
          <td class="sig-img-cell">${sigCell(row._ceSig, 'Chief Engineer', row._ceName || '', '', row._entryId, 'ce', row._date)}</td>
        </tr>`;
        return;
      }

      const rowStyle   = row._corrected ? ' style="opacity:0.55;"' : '';
      const cellStyle  = row._corrected ? ' style="text-decoration:line-through;"' : '';
      const recCellStyle = isCorrMiddle
        ? ` style="text-decoration:line-through;position:relative;overflow:visible;"`
        : cellStyle;
      const recCellInner = isCorrMiddle
        ? `<div style="position:relative;overflow:visible;">${row.text}${corrStampOverlay}</div>`
        : row.text;
      html += `<tr${rowStyle}>
        <td class="book-td-date"${cellStyle}>${row.date}</td>
        <td class="book-td-code"${cellStyle}>${row.code}</td>
        <td class="book-td-item"${cellStyle}>${row.item}</td>
        <td class="book-td-rec"${recCellStyle}>${recCellInner}</td>
      </tr>`;

      if (row._lastInEntry) {
        // Officer-in-Charge signature row
        html += `<tr class="book-sig-row"${rowStyle}>
          <td class="sig-blank-left"${cellStyle}></td>
          <td class="sig-blank-left"${cellStyle}></td>
          <td class="sig-blank-left"${cellStyle}></td>
          <td class="sig-img-cell">${sigCell(row._officerSig, 'Officer in Charge', row._officer, row._rank, row._entryId, 'officer', row._date)}</td>
        </tr>`;
        // Chief Engineer signature row
        html += `<tr class="book-sig-row"${rowStyle}>
          <td class="sig-blank-left"${cellStyle}></td>
          <td class="sig-blank-left"${cellStyle}></td>
          <td class="sig-blank-left"${cellStyle}></td>
          <td class="sig-img-cell">${sigCell(row._ceSig, 'Chief Engineer', row._ceName || '', '', row._entryId, 'ce', row._date)}</td>
        </tr>`;
      }
    });

    // Count actual rows rendered
    let renderedCount = 0;
    pageRows.forEach(r => { renderedCount += r._isSigTankRow ? 2 : (r._lastInEntry ? 3 : 1); });
    const blankCount = Math.max(0, ROWS_PER_PAGE - renderedCount);
    for (let b = 0; b < blankCount; b++) {
      html += `<tr class="book-row-blank"><td class="book-td-date"></td><td class="book-td-code"></td><td class="book-td-item"></td><td class="book-td-rec"></td></tr>`;
    }

    html += `</tbody></table>

      <div class="book-page-footer">
        <div class="book-master-sig">
          <span class="sig-label">Signature of Master</span>
          <span class="sig-line">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span>
        </div>
      </div>
      <div class="book-page-legal">Sole property of Chief Engineer Pro under the Fast Track System. Redistribution detectable via fingerprinting + activation telemetry.</div>
      <div class="book-page-num">${pageNum}</div>
    </div>`;
  });

  return html;
}

// ============================================================
// ORB PREVIEW HTML BUILDER
// ============================================================
function buildOrbPreviewHTML(e) {
  let html = `<div class="orb-preview">
    <div class="orb-preview-watermark">EDUCATIONAL</div>`;
  const lines = (e.formatted || []);
  lines.forEach(l => {
    if (l._sigTank) {
      // Per-tank sig indicator in preview
      const officerLabel = l.officer ? `${esc(nameInitial(l.officer))} / ${esc(rankAbbr(l.rank||''))}` : `Officer-in-Charge`;
      const ceLabel      = l.ceName  ? esc(nameInitial(l.ceName))               : `Chief Engineer`;
      html += `<div class="orb-row" style="background:rgba(99,179,237,0.04);border-top:1px dashed var(--border);">
        <div class="orb-col-date"></div>
        <div class="orb-col-code"></div>
        <div class="orb-col-item"></div>
        <div class="orb-col-text" style="color:var(--text3);font-size:11px;padding:4px 0;">
          <span style="margin-right:24px;">&#9998; ${officerLabel}</span>
          <span>&#9998; ${ceLabel}</span>
        </div>
      </div>`;
      return;
    }
    // Preserve newlines in text (e.g. tank lines for bunkering)
    const textLines = (l.text||'').split('\n');
    textLines.forEach((tl, ti) => {
      html += `<div class="orb-row">
        <div class="orb-col-date">${ti===0 ? esc(l.date||'') : ''}</div>
        <div class="orb-col-code">${ti===0 ? esc(l.code||'') : ''}</div>
        <div class="orb-col-item">${ti===0 ? esc(l.item||'') : ''}</div>
        <div class="orb-col-text">${esc(tl)}</div>
      </div>`;
    });
  });
  if (e.officer) {
    html += `<div class="orb-sig">Signed: ${esc(e.officer)} (${esc(e.rank||'')}) &nbsp;&nbsp; ${esc(e.date)}</div>`;
  }
  // Attachment
  if (e.attachment) {
    const a = e.attachment;
    const isImage = a.type && a.type.startsWith('image/');
    html += `<div class="orb-attach-section">
      <div style="font-family:var(--sans);font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--text3);margin-bottom:6px;">Attached Document</div>`;
    if (isImage) {
      html += `<img class="orb-attach-img" src="${a.dataUrl}" alt="${esc(a.name)}">
        <div style="font-family:var(--mono);font-size:11px;color:var(--text3);margin-top:4px;">${esc(a.name)}</div>`;
    } else {
      html += `<a class="orb-attach-link" href="${a.dataUrl}" download="${esc(a.name)}">
        <span>&#128196;</span> ${esc(a.name)}
      </a>`;
    }
    html += '</div>';
  }
  html += `<div class="orb-disclaimer">EDUCATIONAL SAMPLE ONLY — MEPC.1/Circ.736/Rev.6 format reference. Not a legal ORB entry.</div>`;
  html += `</div>`;
  return html;
}

// Log format key C — entry serialization reference
const _logFmtKey = '4c7a4d32';

// ============================================================
// REFERENCE TAB
// ============================================================
function renderReference() {
  const el = document.getElementById('reference-content');
  el.innerHTML = `
  <div class="card">
    <div class="card-title">MARPOL Annex I — ORB Code Quick Reference</div>
    <div class="table-wrap"><table class="data-table">
      <thead><tr><th>Code</th><th>Operation Category</th><th>Item Numbers</th><th>MARPOL Reg.</th><th>Key Requirement</th></tr></thead>
      <tbody>
        <tr><td><span class="badge badge-amber">C</span></td><td>Oil Residues (Sludge)</td><td>11.1–11.4, 12.1–12.4</td><td>Reg 17</td><td>Weekly inventory + all disposal methods</td></tr>
        <tr><td><span class="badge badge-amber">D</span></td><td>Manual Bilge Discharge</td><td>13, 14, 15.1–15.3</td><td>Reg 15</td><td>Time, quantity, position if OWS overboard</td></tr>
        <tr><td><span class="badge badge-amber">E</span></td><td>Automatic Bilge Discharge</td><td>16, 17, 18</td><td>Reg 15</td><td>Auto-start time, position, stop time</td></tr>
        <tr><td><span class="badge badge-amber">F</span></td><td>OWS Equipment Condition</td><td>19, 20, 21</td><td>Reg 14</td><td>Failure time, restoration time, reason</td></tr>
        <tr><td><span class="badge badge-amber">G</span></td><td>Accidental Discharge</td><td>22, 23, 24, 25</td><td>Reg 15</td><td>Time, position, type, quantity, circumstances</td></tr>
        <tr><td><span class="badge badge-amber">H</span></td><td>Bunkering</td><td>26.1–26.4</td><td>Reg 17</td><td>Port, time, grade, sulphur %, each tank receiving</td></tr>
        <tr><td><span class="badge badge-amber">I</span></td><td>Additional Remarks</td><td>—</td><td>Various</td><td>Missed entries, debunkering, valve sealing, cargo hold bilge</td></tr>
      </tbody>
    </table></div>
  </div>

  <div class="card">
    <div class="card-title">IOPPC Supplement — Tank Section References</div>
    <div class="table-wrap"><table class="data-table">
      <thead><tr><th>Section</th><th>Tank Category</th><th>ORB Code</th><th>Notes</th></tr></thead>
      <tbody>
        <tr><td class="mono amber">3.1</td><td>Oil Residue (Sludge) Tanks</td><td>C</td><td>All disposal/transfer/incineration of sludge. Capacity must match IOPPC.</td></tr>
        <tr><td class="mono amber">3.2</td><td>OWS / Overboard Systems</td><td>D, E, F</td><td>15 ppm equipment, OCM, overboard valve, auto-stop device</td></tr>
        <tr><td class="mono amber">3.2.3</td><td>Transfer to Slop Tank</td><td>D, C</td><td>Tankers only. Requires IOPP supplement item. Also needs ORB Part II entry.</td></tr>
        <tr><td class="mono amber">3.3</td><td>Bilge Water Holding Tanks</td><td>D, E</td><td>Quantity retained voluntary but recommended. Capacity must match IOPPC.</td></tr>
      </tbody>
    </table></div>
  </div>

  <div class="card">
    <div class="card-title">Dry Fleet — Educational Tank Arrangement Example</div>
    <p style="color:var(--text3);font-size:12px;margin-bottom:12px;font-family:var(--body);">Note: Actual tank arrangements vary by vessel, company, flag state, and SMS. This is an example only.</p>
    <div class="table-wrap"><table class="data-table">
      <thead><tr><th>Tank Name</th><th>IOPPC Sec.</th><th>Typical ORB Code</th><th>Purpose</th></tr></thead>
      <tbody>
        <tr><td>Bilge Holding Tank</td><td class="mono amber">3.3</td><td>D, E</td><td>Collects bilge water from ER bilge wells before OWS processing or shore discharge</td></tr>
        <tr><td>Sludge Tank</td><td class="mono amber">3.1</td><td>C</td><td>Receives sludge from separators, drain tanks, manual collections</td></tr>
        <tr><td>Waste Oil Tank</td><td class="mono amber">3.1</td><td>C</td><td>Used lube oil, drain oil — treated as sludge for ORB purposes</td></tr>
        <tr><td>Dirty Oil Tank</td><td class="mono amber">3.1</td><td>C</td><td>Oil-contaminated water or dirty residues from maintenance</td></tr>
        <tr><td>FO Settling Tank</td><td class="mono muted">—</td><td>H (bunkering)</td><td>Receives bunker fuel; drains water/sludge to sludge tank</td></tr>
        <tr><td>FO Service Tank</td><td class="mono muted">—</td><td>H, internal transfer</td><td>Feeds main engine; filled from settling tank</td></tr>
        <tr><td>DO Service Tank</td><td class="mono muted">—</td><td>H, internal transfer</td><td>Diesel oil for generators and auxiliaries</td></tr>
        <tr><td>Scavenge Air Box Drain Tank</td><td class="mono amber">3.1</td><td>C</td><td>Drains from scavenge spaces — transferred to sludge/waste oil tank</td></tr>
        <tr><td>Port / Stbd / Aft Bilge Wells</td><td class="mono muted">—</td><td>D, E</td><td>Collection points only. No ROB tracked. Pumped to bilge holding tank.</td></tr>
      </tbody>
    </table></div>
  </div>

  <div class="card">
    <div class="card-title">Tanker — Educational Tank Arrangement Example</div>
    <p style="color:var(--text3);font-size:12px;margin-bottom:12px;font-family:var(--body);">Note: Tankers have additional MARPOL requirements. ORB Part II covers cargo-related operations. This is a general overview for awareness only.</p>
    <div class="table-wrap"><table class="data-table">
      <thead><tr><th>Tank Name</th><th>IOPPC Sec.</th><th>Typical ORB Code</th><th>Purpose</th></tr></thead>
      <tbody>
        <tr><td>Slop Tank</td><td class="mono amber">3.2.3</td><td>C.12.4, D.15.3</td><td>Receives cargo residues, dirty ballast washings. ORB Part II entry required for cargo-related ops.</td></tr>
        <tr><td>Dirty Ballast Tank</td><td class="mono muted">—</td><td>ORB Part II</td><td>Cargo tanks used for ballast. Covered mainly by ORB Part II.</td></tr>
        <tr><td>Bilge Holding Tank</td><td class="mono amber">3.3</td><td>D, E</td><td>Same as dry fleet. Collects ER bilge water.</td></tr>
        <tr><td>Sludge Tank</td><td class="mono amber">3.1</td><td>C</td><td>Receives sludge from FO/LO separators and drain tanks</td></tr>
        <tr><td>Pump Room Bilge Tank</td><td class="mono amber">3.3</td><td>D</td><td>Collects bilge from cargo pump room — treated same as ER bilge for ORB purposes</td></tr>
      </tbody>
    </table></div>
  </div>

  <div class="card">
    <div class="card-title">PSC Inspection — Common ORB Mistakes</div>
    <div class="table-wrap"><table class="data-table">
      <thead><tr><th>#</th><th>Common Mistake</th><th>Why It Matters</th></tr></thead>
      <tbody>
        <tr><td>1</td><td>Wrong date format (e.g. 14/05/2026 instead of 14-MAY-2026)</td><td>MEPC guidance requires dd-MONTH-yyyy format. PSC may flag non-compliance.</td></tr>
        <tr><td>2</td><td>Leaving blank lines between entries</td><td>Guidance specifically states: do not leave full blank lines between successive entries.</td></tr>
        <tr><td>3</td><td>Tank names do not match IOPPC Supplement</td><td>Tank nomenclature must match the IOPPC exactly — not vessel nickname or local name.</td></tr>
        <tr><td>4</td><td>Missing position for OWS overboard discharge (Code D/E)</td><td>Position at start and stop of overboard discharge is mandatory.</td></tr>
        <tr><td>5</td><td>Correcting an error by erasing or using white-out</td><td>Corrections must use single strikethrough (error still legible), re-signed and dated.</td></tr>
        <tr><td>6</td><td>Sludge tank quantities inconsistent with entries</td><td>PSC will check running total. Inventory entries must add up across collection and disposal.</td></tr>
        <tr><td>7</td><td>Missing OWS failure entry (Code F) when unit was not working</td><td>If OWS was not operational, failure and restoration must be recorded even if no discharge occurred.</td></tr>
        <tr><td>8</td><td>Pages not signed by Master</td><td>Each completed page requires Master's signature, not just officer-in-charge.</td></tr>
        <tr><td>9</td><td>Gap in entries (missing operations)</td><td>PSC will look for continuity. Gaps raise immediate suspicion. Use Code I for missed entries.</td></tr>
        <tr><td>10</td><td>Bunkering entries missing tank-by-tank breakdown</td><td>Code H requires quantity per tank received and quantity now retained per tank.</td></tr>
      </tbody>
    </table></div>
  </div>

  <div class="card">
    <div class="card-title">Correction Procedure — How to Fix a Wrong ORB Entry</div>
    <div style="font-family:var(--body);font-size:14px;color:var(--text2);line-height:1.8;">
      <p style="margin-bottom:10px;">Per MEPC.1/Circ.736/Rev.6 General Guidance:</p>
      <ul style="margin-left:20px;">
        <li>Draw a single line through the wrong entry — the original text must still be legible.</li>
        <li>Sign and date the correction.</li>
        <li>Write the correct entry immediately following.</li>
        <li>Never use correction fluid, erasers, or obliteration of any kind.</li>
        <li>Never remove or destroy pages from the ORB.</li>
      </ul>
      <p style="margin-top:12px;color:var(--text3);font-size:12px;">For a missed entry from a previous date, use Code I to note the missed entry, then record the actual operation with Code I referencing the original date.</p>
    </div>
  </div>
  `;
}

// ============================================================
// TANK DIAGRAM
// ============================================================
const TM_COLORS = {
  hfo: { fill: '#5a2800', label: 'HFO', group: 'fuel' },
  vlsfo: { fill: '#6b3010', label: 'VLSFO', group: 'fuel' },
  ulsfo: { fill: '#7a3818', label: 'ULSFO', group: 'fuel' },
  mdo: { fill: '#c97080', label: 'MDO', group: 'fuel' },
  mgo: { fill: '#d48090', label: 'MGO', group: 'fuel' },
  lsmgo: { fill: '#bf6070', label: 'LSMGO', group: 'fuel' },
  'fo-settle': { fill: '#6b3010', label: 'FO Settle', group: 'fuel' },
  'fo-service': { fill: '#5a2800', label: 'FO Service', group: 'fuel' },
  'do-service': { fill: '#c97080', label: 'DO Service', group: 'fuel' },
  lo: { fill: '#b8920a', label: 'Lube Oil', group: 'lube' },
  'lo-settle': { fill: '#c49a10', label: 'LO Settling', group: 'lube' },
  'lo-service': { fill: '#c49a10', label: 'LO Service', group: 'lube' },
  sludge: { fill: '#1e1e1e', label: 'Sludge', group: 'sludge' },
  waste: { fill: '#222', label: 'Waste Oil', group: 'sludge' },
  dirty: { fill: '#2a2010', label: 'Dirty Oil', group: 'sludge' },
  scav: { fill: '#181818', label: 'Scavenge Drain', group: 'sludge' },
  bilge: { fill: '#1a3a5c', label: 'Bilge Water', group: 'bilge' },
  pumproom: { fill: '#1a3a5c', label: 'Pump Room Bilge', group: 'bilge' },
  bilgewell: { fill: '#1a3a5c', label: 'Bilge Well', group: 'bilge' },
  slop: { fill: '#4a2a00', label: 'Slop', group: 'other' },
  cargo: { fill: '#4a2a00', label: 'Cargo', group: 'other' },
  'dirty-ballast': { fill: '#2c3a20', label: 'Dirty Ballast', group: 'other' },
  other: { fill: '#3a3a3a', label: 'Other', group: 'other' }
};

const TM_GROUP_LABELS = {
  fuel: 'Fuel Oils',
  lube: 'Lube Oils',
  sludge: 'Sludge / Waste Oil',
  bilge: 'Bilge / Holding',
  other: 'Other / Slop / Cargo'
};

const TM_LEGEND_DEFS = [
  { fill: '#5a2800', label: 'Fuel Oil (HFO/MDO)' },
  { fill: '#c97080', label: 'Diesel Oil (MDO/MGO)' },
  { fill: '#b8920a', label: 'Lube Oil' },
  { fill: '#1e1e1e', label: 'Sludge / Waste' },
  { fill: '#1a3a5c', label: 'Bilge Water' },
  { fill: '#4a2a00', label: 'Slop / Cargo' }
];

function renderTankDiagram() {
  const tanks = getTanks();

  // Legend
  const legendEl = document.getElementById('tankmap-legend');
  legendEl.innerHTML = TM_LEGEND_DEFS.map(d =>
    `<div class="tm-legend-item">
      <div class="tm-legend-dot" style="background:${d.fill};border:1px solid rgba(255,255,255,0.1)"></div>
      <span>${d.label}</span>
    </div>`
  ).join('');

  // Group tanks
  const grouped = {};
  const groupOrder = ['fuel','lube','sludge','bilge','other'];
  groupOrder.forEach(g => { grouped[g] = []; });
  tanks.forEach(t => {
    const c = TM_COLORS[t.type] || TM_COLORS.other;
    const g = c.group || 'other';
    if (!grouped[g]) grouped[g] = [];
    grouped[g].push(t);
  });

  const groupsEl = document.getElementById('tankmap-groups');
  let html = '';
  groupOrder.forEach(g => {
    const list = grouped[g];
    if (!list || list.length === 0) return;
    html += `<div class="tm-group">
      <div class="tm-group-title">${TM_GROUP_LABELS[g]}</div>
      <div class="tm-grid">`;
    list.forEach(t => {
      const c = TM_COLORS[t.type] || TM_COLORS.other;
      const isWell = !!t.isBilgeWell;
      const cap = parseFloat(t.capacity) || 0;
      const rob = parseFloat(t.rob) || 0;
      const pct = cap > 0 ? Math.min(100, Math.round((rob / cap) * 100)) : 0;
      const alertClass = pct >= 80 ? 'tm-alert' : (pct < 20 && cap > 0 ? 'tm-low' : '');

      if (isWell) {
        html += `<div class="tm-tank${alertClass ? ' ' + alertClass : ''}">
          <div class="tm-tank-header">
            <div class="tm-tank-name">${esc(t.name)}</div>
          </div>
          <div class="tm-well-indicator">
            <div class="tm-well-dot" style="background:${c.fill}22;border-color:${c.fill}88"></div>
            <div class="tm-well-label">Bilge Well</div>
          </div>
          <div class="tm-tank-footer">
            <span class="tm-cap-val" style="color:var(--text3)">No capacity tracking</span>
          </div>
        </div>`;
      } else {
        const fillH = cap > 0 ? Math.max(2, Math.round(pct * 0.8)) : 0;
        html += `<div class="tm-tank${alertClass ? ' ' + alertClass : ''}">
          <div class="tm-tank-header">
            <div class="tm-tank-name">${esc(t.name)}</div>
            <div class="tm-tank-pct">${pct}%</div>
          </div>
          <div class="tm-vessel">
            <div class="tm-fill" style="height:${fillH}%;background:${c.fill};">
              <svg class="tm-wave" viewBox="0 0 1200 30" preserveAspectRatio="none">
                <path d="M0,14 C150,6 350,22 600,14 C850,6 1050,22 1200,14 L1200,30 L0,30 Z" fill="${c.fill}"/>
                <path d="M0,14 C150,6 350,22 600,14 C850,6 1050,22 1200,14" fill="none" stroke="rgba(255,255,255,0.3)" stroke-width="1.5"/>
              </svg>
              <svg class="tm-wave2" viewBox="0 0 1200 24" preserveAspectRatio="none">
                <path d="M0,10 C200,18 400,4 600,10 C800,18 1000,4 1200,10 L1200,24 L0,24 Z" fill="${c.fill}" opacity="0.6"/>
              </svg>
              <div class="tm-fill-body"></div>
            </div>
          </div>
          <div class="tm-tank-footer">
            <span class="tm-rob-val">${fmt2(rob)} ${esc(t.unit)}</span>
            <span class="tm-cap-val">/ ${fmt2(cap)}</span>
          </div>
        </div>`;
      }
    });
    html += `</div></div>`;
  });

  if (!html) html = '<div style="color:var(--text3);font-family:var(--sans);font-size:13px;">No tanks configured. Add tanks in the Tank Editor tab.</div>';
  groupsEl.innerHTML = html;
}

// ============================================================
// ENTRY — 3-PANEL LAYOUT
// ============================================================
let _activeCat = null;
let _activeOp  = null;

function renderEntryWizard() {
  wiz = {};
  _activeCat = null;
  _activeOp  = null;
  renderCatList();
  renderActList(null);
  document.getElementById('entry-form-content').innerHTML =
    '<div style="color:var(--text3);font-family:var(--sans);font-size:13px;padding-top:20px;">Select an activity from the left panels to begin recording.</div>';
}

function renderCatList() {
  const el = document.getElementById('cat-list');
  const codeMode = (localStorage.getItem('orb_actMode') === 'code');
  el.innerHTML = CATEGORIES.map(c => {
    const display = (codeMode && c.code)
      ? `<span class="act-code" style="font-size:13px;font-weight:700;">${esc(c.code)}</span><span style="font-size:10px;color:var(--text3);margin-left:4px;">${esc(c.label)}</span>`
      : esc(c.label);
    return `<div class="cat-item${_activeCat===c.id?' active':''}" onclick="selectCat('${c.id}')">${display}</div>`;
  }).join('');
}

function renderActList(catId) {
  const el = document.getElementById('act-list');
  if (!catId) {
    el.innerHTML = '<div class="act-info-panel">Select a category to view activities.</div>';
    return;
  }
  const cat = CATEGORIES.find(c => c.id === catId);
  if (!cat) return;
  if (cat.info && (!cat.ops || !cat.ops.length)) {
    el.innerHTML = `<div class="act-info-panel">${esc(cat.info)}</div>`;
    return;
  }
  if (!cat.ops || !cat.ops.length) {
    el.innerHTML = '<div class="act-info-panel">No operations configured for this category.</div>';
    return;
  }
  const codeMode = (localStorage.getItem('orb_actMode') === 'code');
  el.innerHTML = cat.ops.map(opId => {
    const op = OPERATIONS.find(o => o.id === opId);
    if (!op) return '';
    const label = op.label.replace(/ \([A-Z].*\)$/, '');
    if (codeMode) {
      return `<div class="act-item${_activeOp===opId?' active':''}" onclick="selectActivity('${opId}')">
        <span class="act-code" style="font-size:14px;font-weight:700;">${esc(op.code)}</span><span style="font-size:11px;color:var(--text3);margin-left:4px;">${esc(label)}</span>
      </div>`;
    }
    return `<div class="act-item${_activeOp===opId?' active':''}" onclick="selectActivity('${opId}')">
      <span class="act-code">${esc(op.code)}</span>${esc(label)}
    </div>`;
  }).join('');
  if (cat.info) {
    el.innerHTML += `<div class="act-info-panel" style="border-top:1px solid var(--border);">${esc(cat.info)}</div>`;
  }
  const btn = document.getElementById('act-mode-toggle');
  if (btn) btn.textContent = codeMode ? 'Activity' : 'Code';
}

function toggleActMode() {
  const cur = localStorage.getItem('orb_actMode') || 'activity';
  localStorage.setItem('orb_actMode', cur === 'code' ? 'activity' : 'code');
  renderCatList();
  renderActList(_activeCat);
}

function selectCat(catId) {
  guardDirtyForm(() => {
    _activeCat = catId;
    _activeOp  = null;
    wiz = {};
    _formDirty = false;
    renderCatList();
    renderActList(catId);
    document.getElementById('entry-form-content').innerHTML =
      '<div style="color:var(--text3);font-family:var(--sans);font-size:13px;padding-top:20px;">Select an activity to begin.</div>';
    setWizardStep('act');
  });
}

function selectActivity(opId) {
  guardDirtyForm(() => {
    _activeOp = opId;
    wiz = { opId };
    _formDirty = false;
    renderCatList();
    renderActList(_activeCat);
    renderFormPanel(opId);
    setWizardStep('form');
  });
}

/* Mobile wizard step controller — drives data-mobile-step on .entry-layout.
   Desktop CSS ignores the attribute (3-column grid stays); mobile CSS uses it
   to show one active pane at a time (cat → act → form). */
function setWizardStep(step) {
  const layout = document.getElementById('entry-layout');
  if (!layout) return;
  if (step !== 'cat' && step !== 'act' && step !== 'form') step = 'cat';
  layout.setAttribute('data-mobile-step', step);
  try { layout.scrollIntoView({ behavior: 'smooth', block: 'start' }); } catch(_) {}
}

/* Mobile sidebar overlay */
function toggleMobileSidebar() {
  const sb = document.querySelector('.sidebar');
  const scrim = document.getElementById('sidebar-scrim');
  if (!sb) return;
  const isOpen = sb.classList.toggle('open');
  if (scrim) scrim.classList.toggle('visible', isOpen);
  document.body.style.overflow = isOpen ? 'hidden' : '';
}
function closeMobileSidebar() {
  const sb = document.querySelector('.sidebar');
  const scrim = document.getElementById('sidebar-scrim');
  if (sb) sb.classList.remove('open');
  if (scrim) scrim.classList.remove('visible');
  document.body.style.overflow = '';
}

function renderFormPanel(opId) {
  const op = OPERATIONS.find(o => o.id === opId);
  if (!op) return;
  const fc = document.getElementById('entry-form-content');
  fc.innerHTML = `
    <div class="entry-form-inner">
      <div style="display:flex;align-items:center;gap:10px;margin-bottom:18px;">
        <span class="badge badge-amber">${esc(op.code)}</span>
        <span style="font-family:var(--sans);font-size:14px;font-weight:600;color:var(--text);">${esc(op.label)}</span>
        <span class="badge badge-grey" style="margin-left:auto;">${esc(op.marpol)}</span>
      </div>
      <div id="wiz-form"></div>
    </div>
    <div id="wiz-preview-area"></div>`;
  buildWizForm(op);
}

