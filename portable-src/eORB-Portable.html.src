        <img src="data:image/png;base64," alt="Chief Engineer Pro" style="height:32px;width:auto;object-fit:contain;flex-shrink:0;">
        <div style="font-size:10px;font-weight:700;letter-spacing:0.08em;color:#d4aa28;font-family:var(--mono);">CHIEF ENGINEER PRO</div>
